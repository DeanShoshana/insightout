---
export type ServiceVisualVariant = 'product' | 'behavior' | 'data' | 'market' | 'advisory';

interface Props {
  variant: ServiceVisualVariant;
  size?: 'card' | 'feature';
}

const { variant, size = 'card' } = Astro.props;
---

<figure class:list={['service-visual', `service-visual--${variant}`, `service-visual--${size}`]} aria-hidden="true">
  <span class="service-visual__plane service-visual__plane--one"></span>
  <span class="service-visual__plane service-visual__plane--two"></span>
  <span class="service-visual__plane service-visual__plane--three"></span>
  <svg class="service-visual__svg" viewBox="0 0 360 220" focusable="false">
    {variant === 'product' && (
      <g>
        <rect class="visual-panel visual-panel--large" x="54" y="56" width="168" height="96" rx="22" />
        <path class="visual-path visual-path--accent" pathLength="1" d="M 82 118 C 112 96, 136 124, 164 96 S 210 78, 220 72" />
        <path class="visual-path visual-path--soft" d="M 92 144 H 154" />
        <rect class="visual-panel visual-panel--small" x="214" y="84" width="64" height="104" rx="20" />
        <path class="visual-path visual-path--soft" d="M 234 116 H 260" />
        <path class="visual-path visual-path--accent" pathLength="1" d="M 234 140 H 254" />
        <circle class="visual-node visual-node--accent" cx="246" cy="170" r="5" />
      </g>
    )}

    {variant === 'behavior' && (
      <g>
        <path class="visual-path visual-path--soft" d="M 94 150 L 156 106 L 116 58 M 156 106 L 232 76 L 270 142 L 156 106 M 94 150 L 232 166" />
        <circle class="visual-node" cx="116" cy="58" r="13" />
        <circle class="visual-node" cx="94" cy="150" r="13" />
        <circle class="visual-node visual-node--accent" cx="156" cy="106" r="19" />
        <circle class="visual-node" cx="232" cy="76" r="13" />
        <circle class="visual-node" cx="270" cy="142" r="13" />
        <circle class="visual-node" cx="232" cy="166" r="13" />
      </g>
    )}

    {variant === 'data' && (
      <g>
        <rect class="visual-panel visual-panel--large" x="62" y="48" width="236" height="136" rx="24" />
        <rect class="visual-tile" x="86" y="74" width="72" height="34" rx="10" />
        <rect class="visual-tile" x="176" y="74" width="78" height="34" rx="10" />
        <rect class="visual-bar" x="88" y="132" width="24" height="36" rx="6" />
        <rect class="visual-bar" x="122" y="144" width="24" height="24" rx="6" />
        <rect class="visual-bar" x="156" y="118" width="24" height="50" rx="6" />
        <path class="visual-path visual-path--accent" pathLength="1" d="M 92 162 C 124 146, 144 162, 166 134 S 214 122, 256 96" />
        <circle class="visual-node visual-node--accent" cx="256" cy="96" r="7" />
      </g>
    )}

    {variant === 'market' && (
      <g>
        <circle class="visual-ring" cx="178" cy="112" r="72" />
        <circle class="visual-ring visual-ring--soft" cx="178" cy="112" r="42" />
        <path class="visual-path visual-path--soft" d="M 178 40 V 184 M 106 112 H 250" />
        <path class="visual-path visual-path--accent visual-path--sweep" pathLength="1" d="M 178 112 L 238 74" />
        <circle class="visual-node visual-node--accent" cx="238" cy="74" r="9" />
        <circle class="visual-node" cx="126" cy="146" r="8" />
        <circle class="visual-node" cx="206" cy="164" r="7" />
        <rect class="visual-chip" x="66" y="62" width="68" height="30" rx="12" />
        <rect class="visual-chip visual-chip--dark" x="222" y="138" width="72" height="30" rx="12" />
      </g>
    )}

    {variant === 'advisory' && (
      <g>
        <rect class="visual-panel visual-panel--decision visual-panel--artifact" x="126" y="46" width="112" height="128" rx="24" />
        <path class="visual-path visual-path--soft visual-path--decision" d="M 148 82 H 216" />
        <path class="visual-path visual-path--soft visual-path--decision" d="M 148 106 H 202" />
        <path class="visual-path visual-path--accent" pathLength="1" d="M 148 134 H 194" />
        <path class="visual-path visual-path--soft visual-path--decision visual-path--decision-in" d="M 76 76 C 106 76, 106 110, 126 110" />
        <path class="visual-path visual-path--soft visual-path--decision visual-path--decision-in" d="M 76 144 C 108 144, 106 110, 126 110" />
        <path class="visual-path visual-path--soft visual-path--decision visual-path--decision-out" d="M 238 110 C 262 110, 266 88, 292 88" />
        <path class="visual-path visual-path--soft visual-path--decision visual-path--decision-out" d="M 238 132 C 264 132, 268 154, 294 154" />
        <circle class="visual-node" cx="76" cy="76" r="9" />
        <circle class="visual-node" cx="76" cy="144" r="9" />
        <circle class="visual-node visual-node--accent" cx="238" cy="110" r="8" />
        <circle class="visual-node" cx="292" cy="88" r="8" />
        <circle class="visual-node" cx="294" cy="154" r="8" />
      </g>
    )}
  </svg>
</figure>

<style>
  .service-visual {
    position: relative;
    display: grid;
    place-items: center;
    inline-size: min(100%, var(--visual-shell, 360px));
    margin: 0;
    isolation: isolate;
  }

  .service-visual::before {
    content: '';
    position: absolute;
    inset: 10% 14%;
    z-index: -1;
    border-radius: 999px;
    background: color-mix(in srgb, var(--signal) 16%, transparent);
    filter: blur(26px);
    opacity: 0.58;
    transition:
      opacity var(--dur-hover) var(--ease-luxe),
      transform var(--dur-hover) var(--ease-luxe);
  }

  .service-visual__plane {
    position: absolute;
    z-index: 0;
    display: block;
    border: 1px solid color-mix(in srgb, var(--signal) 14%, var(--hairline));
    border-radius: 18px;
    background:
      linear-gradient(
        145deg,
        color-mix(in srgb, var(--surface) 70%, transparent),
        color-mix(in srgb, var(--glass-hi) 46%, transparent)
      );
    -webkit-backdrop-filter: blur(12px) saturate(135%);
    backdrop-filter: blur(12px) saturate(135%);
    box-shadow:
      0 18px 46px color-mix(in srgb, var(--ink) 8%, transparent),
      inset 0 1px 0 color-mix(in srgb, white 48%, transparent);
    opacity: 0.72;
  }

  .service-visual__plane--one {
    inline-size: 36%;
    block-size: 32%;
    inset-inline-start: 10%;
    inset-block-start: 18%;
    transform: rotate(-8deg);
  }

  .service-visual__plane--two {
    inline-size: 25%;
    block-size: 45%;
    inset-inline-end: 14%;
    inset-block-start: 14%;
    transform: rotate(6deg);
  }

  .service-visual__plane--three {
    inline-size: 33%;
    block-size: 28%;
    inset-inline-start: 38%;
    inset-block-end: 14%;
    transform: rotate(4deg);
    opacity: 0.58;
  }

  .service-visual--advisory .service-visual__plane {
    display: none;
  }

  .service-visual__svg {
    position: relative;
    z-index: 1;
    inline-size: 100%;
    max-inline-size: var(--visual-max, 260px);
    block-size: auto;
    overflow: visible;
  }

  .service-visual--card {
    --visual-max: 210px;
    --visual-shell: 240px;
  }

  .service-visual--feature {
    --visual-max: 360px;
    --visual-shell: 380px;
  }

  .visual-panel,
  .visual-tile,
  .visual-chip,
  .visual-ring {
    fill: color-mix(in srgb, var(--glass-hi) 80%, var(--surface));
    stroke: color-mix(in srgb, var(--glass-lo) 72%, var(--surface));
    stroke-width: 3;
  }

  .visual-ring {
    fill: none;
    opacity: 0.72;
  }

  .visual-ring--soft {
    stroke: color-mix(in srgb, var(--signal) 34%, var(--glass-lo));
    opacity: 0.5;
  }

  .visual-chip--dark {
    fill: color-mix(in srgb, var(--signal) 16%, var(--ink-surface));
  }

  .visual-panel--decision {
    fill: color-mix(in srgb, var(--ink-surface) 88%, var(--signal));
    stroke: color-mix(in srgb, var(--speed-from) 26%, transparent);
  }

  .visual-panel--artifact {
    filter: drop-shadow(0 18px 24px color-mix(in srgb, var(--ink) 18%, transparent));
  }

  .visual-path {
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .visual-path--soft {
    stroke: color-mix(in srgb, var(--glass-lo) 76%, var(--graphite));
    stroke-width: 4;
    opacity: 0.82;
  }

  .visual-path--accent {
    stroke: var(--signal);
    stroke-width: 4.5;
  }

  .visual-path--decision {
    stroke: var(--speed-from);
    stroke-width: 3;
    opacity: 0.9;
  }

  .visual-node,
  .visual-bar {
    fill: color-mix(in srgb, var(--glass-lo) 78%, var(--surface));
  }

  .visual-node--accent {
    fill: var(--signal);
  }

  .visual-bar {
    opacity: 0.95;
  }

  @media (prefers-reduced-motion: no-preference) {
    .service-visual__plane--one {
      animation: visual-plane-one 8s ease-in-out infinite;
    }

    .service-visual__plane--two {
      animation: visual-plane-two 9s ease-in-out infinite;
    }

    .service-visual__plane--three {
      animation: visual-plane-three 10s ease-in-out infinite;
    }

    .service-visual * {
      transform-box: fill-box;
      transform-origin: center;
      transition:
        transform var(--dur-hover) var(--ease-luxe),
        opacity var(--dur-hover) var(--ease-luxe);
    }

    .visual-path--accent {
      transition:
        stroke-dashoffset 1100ms var(--ease-luxe),
        transform var(--dur-hover) var(--ease-luxe),
        opacity var(--dur-hover) var(--ease-luxe);
    }

    :global(.js [data-reveal]:not(.in)) .visual-path--accent {
      stroke-dasharray: 1;
      stroke-dashoffset: 1;
      opacity: 0.7;
    }

    :global(.js [data-reveal].in) .visual-path--accent {
      stroke-dasharray: 1;
      stroke-dashoffset: 0;
    }

    :global(.js [data-reveal]:not(.in)) .service-visual--product .visual-panel--small,
    :global(.js [data-reveal]:not(.in)) .service-visual--market .visual-chip,
    :global(.js [data-reveal]:not(.in)) .service-visual--advisory .visual-panel--decision {
      opacity: 0;
      transform: translate3d(-10px, 6px, 0);
    }

    :global(.js [data-reveal]:not(.in)) .service-visual--behavior .visual-node,
    :global(.js [data-reveal]:not(.in)) .service-visual--market .visual-node {
      opacity: 0.2;
      transform: scale(0.72);
    }

    :global(.js [data-reveal]:not(.in)) .service-visual--data .visual-bar {
      opacity: 0.45;
      transform: translate3d(0, 14px, 0) scaleY(0.72);
    }

    :global(.card:hover) .service-visual::before,
    :global(.pillar__visual:hover) .service-visual::before {
      opacity: 0.82;
      transform: scale(1.08);
    }

    :global(.card:hover) .service-visual--product .visual-panel--small,
    :global(.pillar:hover) .service-visual--product .visual-panel--small {
      transform: translate3d(7px, 4px, 0);
    }

    :global(.card:hover) .service-visual--behavior .visual-node--accent,
    :global(.pillar:hover) .service-visual--behavior .visual-node--accent,
    :global(.card:hover) .service-visual--market .visual-node--accent,
    :global(.pillar:hover) .service-visual--market .visual-node--accent,
    :global(.card:hover) .service-visual--data .visual-node--accent,
    :global(.pillar:hover) .service-visual--data .visual-node--accent {
      transform: scale(1.12);
    }

    :global(.card:hover) .service-visual--advisory .visual-panel--decision,
    :global(.pillar:hover) .service-visual--advisory .visual-panel--decision {
      transform: translate3d(6px, 0, 0);
    }

    .service-visual--behavior .visual-node {
      animation: visual-node-breathe 5.8s ease-in-out infinite;
    }

    .service-visual--behavior .visual-node:nth-of-type(3n),
    .service-visual--market .visual-node:nth-of-type(2n) {
      animation-delay: -1.4s;
    }

    .service-visual--market .visual-node {
      animation: visual-node-breathe 6.4s ease-in-out infinite;
    }

    .service-visual--data .visual-bar {
      animation: visual-bar-float 5.8s ease-in-out infinite;
    }

    .service-visual--data .visual-bar:nth-of-type(2n) {
      animation-delay: -1.1s;
    }

    .service-visual--advisory .visual-panel--decision {
      animation: visual-decision-float 6.6s ease-in-out infinite;
    }

    .service-visual--advisory .visual-path--accent {
      animation: visual-line-pulse 4.8s ease-in-out infinite;
    }

    .service-visual--market .visual-ring,
    .service-visual--market .visual-path--sweep {
      animation: visual-market-scan 7s ease-in-out infinite;
    }
  }

  @keyframes visual-plane-one {
    0%,
    100% {
      transform: translate3d(0, 0, 0) rotate(-8deg);
    }

    50% {
      transform: translate3d(8px, -7px, 0) rotate(-4deg);
    }
  }

  @keyframes visual-plane-two {
    0%,
    100% {
      transform: translate3d(0, 0, 0) rotate(6deg);
    }

    50% {
      transform: translate3d(-7px, 8px, 0) rotate(3deg);
    }
  }

  @keyframes visual-plane-three {
    0%,
    100% {
      transform: translate3d(0, 0, 0) rotate(4deg);
    }

    50% {
      transform: translate3d(-8px, -6px, 0) rotate(7deg);
    }
  }

  @keyframes visual-node-breathe {
    0%,
    100% {
      transform: scale(1);
      opacity: 0.92;
    }

    50% {
      transform: scale(1.12);
      opacity: 1;
    }
  }

  @keyframes visual-bar-float {
    0%,
    100% {
      transform: translate3d(0, 0, 0) scaleY(1);
    }

    50% {
      transform: translate3d(0, -5px, 0) scaleY(1.08);
    }
  }

  @keyframes visual-decision-float {
    0%,
    100% {
      transform: translate3d(0, 0, 0);
    }

    50% {
      transform: translate3d(7px, -5px, 0);
    }
  }

  @keyframes visual-line-pulse {
    0%,
    100% {
      opacity: 0.72;
    }

    50% {
      opacity: 1;
    }
  }

  @keyframes visual-market-scan {
    0%,
    100% {
      transform: rotate(-4deg);
      opacity: 0.72;
    }

    50% {
      transform: rotate(9deg);
      opacity: 1;
    }
  }
</style>
