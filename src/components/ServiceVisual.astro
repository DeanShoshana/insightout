---
export type ServiceVisualVariant = 'product' | 'behavior' | 'data' | 'market' | 'advisory';

interface Props {
  variant: ServiceVisualVariant;
  size?: 'card' | 'feature';
}

const { variant, size = 'card' } = Astro.props;
---

<figure class:list={['service-visual', `service-visual--${variant}`, `service-visual--${size}`]} aria-hidden="true">
  <span class="service-visual__glow service-visual__glow--one"></span>
  <span class="service-visual__glow service-visual__glow--two"></span>
  <svg class="service-visual__svg" viewBox="0 0 360 220" focusable="false">
    {variant === 'product' && (
      <g class="visual-scene visual-scene--product">
        <rect class="visual-board" x="46" y="34" width="268" height="154" rx="24" />
        <path class="visual-board-line" d="M 72 70 H 166" />
        <path class="visual-board-line visual-board-line--short" d="M 72 88 H 130" />
        <g class="prototype-card prototype-card--one">
          <rect x="74" y="112" width="66" height="42" rx="12" />
          <path d="M 88 127 H 124 M 88 140 H 112" />
        </g>
        <g class="prototype-card prototype-card--two">
          <rect x="154" y="96" width="64" height="58" rx="14" />
          <path d="M 169 114 H 202 M 169 128 H 194 M 169 142 H 184" />
        </g>
        <g class="prototype-card prototype-card--three">
          <rect x="232" y="72" width="44" height="82" rx="15" />
          <path d="M 244 98 H 264 M 244 119 H 260" />
          <circle cx="254" cy="140" r="4" />
        </g>
        <path class="visual-path visual-path--accent prototype-wire" pathLength="1" d="M 141 132 C 156 132, 154 124, 154 124" />
        <path class="visual-path visual-path--accent prototype-wire prototype-wire--two" pathLength="1" d="M 218 125 C 232 125, 228 113, 232 113" />
        <g class="prototype-cursor">
          <path d="M 286 148 L 305 161 L 294 166 L 289 182 L 281 179 L 286 164 Z" />
        </g>
      </g>
    )}

    {variant === 'behavior' && (
      <g class="visual-scene visual-scene--behavior">
        <path class="funnel-shell" d="M 72 54 H 288 L 248 96 H 112 Z" />
        <path class="funnel-shell funnel-shell--mid" d="M 112 104 H 248 L 218 142 H 142 Z" />
        <path class="funnel-shell funnel-shell--low" d="M 142 150 H 218 L 198 178 H 162 Z" />
        <path class="visual-path visual-path--accent funnel-flow" pathLength="1" d="M 92 74 C 126 88, 156 90, 188 80 S 248 76, 270 64" />
        <path class="visual-path visual-path--accent funnel-flow funnel-flow--two" pathLength="1" d="M 126 122 C 154 134, 178 132, 206 116 S 236 112, 248 110" />
        <circle class="visual-node funnel-node funnel-node--one" cx="104" cy="74" r="7" />
        <circle class="visual-node funnel-node funnel-node--two" cx="182" cy="82" r="9" />
        <circle class="visual-node funnel-node funnel-node--three" cx="250" cy="66" r="7" />
        <circle class="visual-node funnel-node funnel-node--four" cx="164" cy="124" r="7" />
        <circle class="visual-node visual-node--accent funnel-node funnel-node--five" cx="190" cy="162" r="9" />
      </g>
    )}

    {variant === 'data' && (
      <g class="visual-scene visual-scene--data">
        <rect class="dashboard-frame" x="50" y="40" width="260" height="148" rx="24" />
        <rect class="dashboard-kpi dashboard-kpi--one" x="74" y="66" width="70" height="38" rx="12" />
        <rect class="dashboard-kpi dashboard-kpi--two" x="158" y="66" width="70" height="38" rx="12" />
        <rect class="dashboard-kpi dashboard-kpi--three" x="242" y="66" width="44" height="38" rx="12" />
        <path class="dashboard-line dashboard-line--one" d="M 88 84 H 126" />
        <path class="dashboard-line dashboard-line--two" d="M 172 84 H 211" />
        <path class="dashboard-line dashboard-line--three" d="M 254 84 H 274" />
        <rect class="dashboard-bar dashboard-bar--one" x="82" y="136" width="20" height="30" rx="6" />
        <rect class="dashboard-bar dashboard-bar--two" x="113" y="124" width="20" height="42" rx="6" />
        <rect class="dashboard-bar dashboard-bar--three" x="144" y="108" width="20" height="58" rx="6" />
        <rect class="dashboard-bar dashboard-bar--four" x="175" y="130" width="20" height="36" rx="6" />
        <path class="visual-path visual-path--accent dashboard-trend" pathLength="1" d="M 212 158 C 232 142, 242 152, 254 132 S 272 108, 288 104" />
        <circle class="visual-node visual-node--accent dashboard-node" cx="288" cy="104" r="7" />
      </g>
    )}

    {variant === 'market' && (
      <g class="visual-scene visual-scene--market">
        <circle class="market-orbit market-orbit--outer" cx="180" cy="110" r="76" />
        <circle class="market-orbit market-orbit--inner" cx="180" cy="110" r="42" />
        <g class="market-ripples">
          <circle class="market-ripple market-ripple--one" cx="180" cy="110" r="22" />
          <circle class="market-ripple market-ripple--two" cx="180" cy="110" r="44" />
          <circle class="market-ripple market-ripple--three" cx="180" cy="110" r="66" />
        </g>
        <circle class="market-hub" cx="180" cy="110" r="12" />
        <g class="market-signal market-signal--one">
          <rect x="58" y="68" width="58" height="24" rx="12" />
          <path d="M 70 80 H 102" />
        </g>
        <g class="market-signal market-signal--two">
          <rect x="228" y="52" width="72" height="24" rx="12" />
          <path d="M 240 64 H 286" />
        </g>
        <g class="market-signal market-signal--three">
          <rect x="222" y="150" width="66" height="24" rx="12" />
          <path d="M 235 162 H 275" />
        </g>
        <path class="visual-path visual-path--accent market-sweep" pathLength="1" d="M 180 110 L 266 74" />
        <circle class="visual-node visual-node--accent market-node" cx="266" cy="74" r="8" />
      </g>
    )}

    {variant === 'advisory' && (
      <g class="visual-scene visual-scene--advisory">
        <rect class="presentation-screen" x="76" y="42" width="208" height="116" rx="22" />
        <rect class="slide-card slide-card--one" x="96" y="64" width="62" height="40" rx="10" />
        <rect class="slide-card slide-card--two" x="172" y="64" width="84" height="40" rx="10" />
        <path class="slide-line slide-line--one" d="M 108 82 H 146 M 108 94 H 132" />
        <path class="slide-line slide-line--two" d="M 185 82 H 240 M 185 94 H 220" />
        <path class="visual-path visual-path--accent presentation-build" pathLength="1" d="M 102 132 C 132 118, 158 136, 184 110 S 234 104, 254 84" />
        <circle class="visual-node visual-node--accent presentation-node" cx="254" cy="84" r="7" />
        <path class="table-line" d="M 86 178 H 274" />
        <g class="meeting-seat meeting-seat--one">
          <circle cx="120" cy="176" r="13" />
          <path d="M 102 198 C 110 186, 130 186, 138 198" />
        </g>
        <g class="meeting-seat meeting-seat--two">
          <circle cx="180" cy="176" r="13" />
          <path d="M 162 198 C 170 186, 190 186, 198 198" />
        </g>
        <g class="meeting-seat meeting-seat--three">
          <circle cx="240" cy="176" r="13" />
          <path d="M 222 198 C 230 186, 250 186, 258 198" />
        </g>
      </g>
    )}
  </svg>
</figure>

<style>
  .service-visual {
    position: relative;
    display: grid;
    place-items: center;
    inline-size: min(100%, var(--visual-shell, 360px));
    margin: 0;
    isolation: isolate;
  }

  .service-visual::before {
    content: '';
    position: absolute;
    inset: 9% 12%;
    z-index: -1;
    border-radius: 999px;
    background:
      radial-gradient(circle at 34% 42%, color-mix(in srgb, var(--glass-lo) 24%, transparent), transparent 58%),
      radial-gradient(circle at 68% 58%, color-mix(in srgb, var(--signal) 18%, transparent), transparent 64%);
    filter: blur(28px);
    opacity: 0.64;
    transition:
      opacity var(--dur-hover) var(--ease-luxe),
      transform var(--dur-hover) var(--ease-luxe);
  }

  .service-visual__glow {
    position: absolute;
    display: block;
    border-radius: 999px;
    pointer-events: none;
    will-change: transform;
  }

  .service-visual__glow--one {
    inline-size: 48%;
    block-size: 36%;
    inset-inline-start: 8%;
    inset-block-start: 14%;
    background: color-mix(in srgb, var(--glass-hi) 62%, transparent);
    filter: blur(18px);
    opacity: 0.74;
  }

  .service-visual__glow--two {
    inline-size: 38%;
    block-size: 46%;
    inset-inline-end: 10%;
    inset-block-end: 9%;
    background: color-mix(in srgb, var(--signal) 14%, transparent);
    filter: blur(22px);
    opacity: 0.56;
  }

  .service-visual--behavior .service-visual__glow--one,
  .service-visual--market .service-visual__glow--one {
    border-radius: 44% 56% 58% 42% / 46% 42% 58% 54%;
  }

  .service-visual--advisory .service-visual__glow--one,
  .service-visual--advisory .service-visual__glow--two {
    background: color-mix(in srgb, var(--speed-from) 18%, transparent);
  }

  .service-visual__svg {
    position: relative;
    z-index: 1;
    inline-size: 100%;
    max-inline-size: var(--visual-max, 260px);
    block-size: auto;
    overflow: visible;
  }

  .service-visual--card {
    --visual-max: 210px;
    --visual-shell: 240px;
  }

  .service-visual--feature {
    --visual-max: 360px;
    --visual-shell: 380px;
  }

  .visual-board,
  .dashboard-frame,
  .presentation-screen,
  .funnel-shell {
    fill: color-mix(in srgb, var(--surface) 88%, transparent);
    stroke: color-mix(in srgb, var(--glass-lo) 72%, var(--surface));
    stroke-width: 3;
    filter: drop-shadow(0 18px 28px color-mix(in srgb, var(--ink) 10%, transparent));
  }

  .prototype-card rect,
  .dashboard-kpi,
  .slide-card,
  .market-signal rect {
    fill: color-mix(in srgb, var(--glass-hi) 72%, var(--surface));
    stroke: color-mix(in srgb, var(--glass-lo) 70%, var(--surface));
    stroke-width: 2.5;
  }

  .prototype-card path,
  .dashboard-line,
  .slide-line,
  .market-signal path,
  .visual-board-line {
    fill: none;
    stroke: color-mix(in srgb, var(--glass-lo) 74%, var(--graphite));
    stroke-width: 4;
    stroke-linecap: round;
  }

  .visual-board-line--short {
    opacity: 0.64;
  }

  .prototype-card circle,
  .visual-node {
    fill: color-mix(in srgb, var(--glass-lo) 78%, var(--surface));
  }

  .visual-node--accent,
  .dashboard-node,
  .market-node,
  .presentation-node {
    fill: var(--signal);
  }

  .visual-path,
  .table-line {
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .visual-path--accent {
    stroke: var(--signal);
    stroke-width: 4.5;
  }

  .market-orbit {
    fill: none;
    stroke: color-mix(in srgb, var(--glass-lo) 62%, transparent);
    stroke-width: 2.5;
  }

  .market-orbit--inner {
    stroke: color-mix(in srgb, var(--signal) 34%, transparent);
  }

  .market-ripple {
    fill: none;
    stroke: color-mix(in srgb, var(--signal) 36%, transparent);
    stroke-width: 2.5;
    opacity: 0.48;
  }

  .market-ripple--two {
    stroke: color-mix(in srgb, var(--glass-lo) 54%, transparent);
    opacity: 0.36;
  }

  .market-ripple--three {
    stroke: color-mix(in srgb, var(--speed-from) 42%, transparent);
    opacity: 0.26;
  }

  .market-hub {
    fill: var(--signal);
    filter: drop-shadow(0 0 16px color-mix(in srgb, var(--signal) 42%, transparent));
  }

  .dashboard-bar {
    fill: color-mix(in srgb, var(--signal) 40%, var(--glass-hi));
  }

  .presentation-screen {
    fill: color-mix(in srgb, var(--ink-surface) 84%, var(--signal));
    stroke: color-mix(in srgb, var(--speed-from) 28%, transparent);
  }

  .slide-card {
    fill: color-mix(in srgb, var(--surface) 18%, var(--speed-from));
    stroke: color-mix(in srgb, var(--speed-from) 44%, transparent);
  }

  .slide-line {
    stroke: color-mix(in srgb, white 72%, var(--speed-from));
  }

  .table-line {
    stroke: color-mix(in srgb, var(--speed-from) 48%, transparent);
    stroke-width: 3;
  }

  .meeting-seat circle {
    fill: color-mix(in srgb, var(--speed-from) 76%, var(--surface));
  }

  .meeting-seat path {
    fill: none;
    stroke: color-mix(in srgb, var(--speed-from) 58%, transparent);
    stroke-width: 4;
    stroke-linecap: round;
  }

  .funnel-shell {
    opacity: 0.88;
  }

  .funnel-shell--mid {
    fill: color-mix(in srgb, var(--glass-hi) 82%, var(--surface));
  }

  .funnel-shell--low {
    fill: color-mix(in srgb, var(--signal) 12%, var(--glass-hi));
  }

  .prototype-cursor path {
    fill: color-mix(in srgb, var(--ink-surface) 88%, var(--signal));
    stroke: color-mix(in srgb, white 24%, transparent);
    stroke-width: 1;
  }

  @media (max-width: 720px) {
    .service-visual--feature {
      --visual-max: 292px;
      --visual-shell: 320px;
    }

    .service-visual--card {
      --visual-max: 190px;
      --visual-shell: 220px;
    }

    .service-visual::before {
      inset: 13% 16%;
      filter: blur(22px);
      opacity: 0.54;
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .service-visual__glow--one {
      animation: visual-glow-one 8s var(--ease-luxe) infinite;
    }

    .service-visual__glow--two {
      animation: visual-glow-two 9s var(--ease-luxe) infinite;
    }

    .service-visual * {
      transform-box: fill-box;
      transform-origin: center;
      transition:
        transform var(--dur-hover) var(--ease-luxe),
        opacity var(--dur-hover) var(--ease-luxe);
    }

    .visual-path--accent {
      stroke-dasharray: 1;
      stroke-dashoffset: 0;
    }

    :global(.js [data-reveal]:not(.in)) .visual-path--accent {
      stroke-dashoffset: 1;
      opacity: 0.72;
    }

    .prototype-card--one {
      animation: prototype-build-card 7.2s var(--ease-luxe) infinite;
    }

    .prototype-card--two {
      animation: prototype-build-card 7.2s var(--ease-luxe) infinite 0.45s;
    }

    .prototype-card--three {
      animation: prototype-build-card 7.2s var(--ease-luxe) infinite 0.9s;
    }

    .prototype-wire {
      animation: prototype-draw 7.2s var(--ease-luxe) infinite 1.1s;
    }

    .prototype-wire--two {
      animation-delay: 1.55s;
    }

    .prototype-cursor {
      animation: prototype-cursor 7.2s var(--ease-luxe) infinite;
    }

    .funnel-node {
      animation: funnel-node 6.8s var(--ease-luxe) infinite;
    }

    .funnel-node--two,
    .funnel-node--four {
      animation-delay: -1.2s;
    }

    .funnel-node--five {
      animation-delay: -2.2s;
    }

    .funnel-flow {
      animation: flow-draw 6.8s var(--ease-luxe) infinite;
    }

    .funnel-flow--two {
      animation-delay: -1.1s;
    }

    .dashboard-kpi,
    .dashboard-bar,
    .dashboard-line {
      animation: dashboard-build 7s var(--ease-luxe) infinite;
    }

    .dashboard-kpi--two,
    .dashboard-line--two,
    .dashboard-bar--two {
      animation-delay: -0.45s;
    }

    .dashboard-kpi--three,
    .dashboard-line--three,
    .dashboard-bar--three {
      animation-delay: -0.9s;
    }

    .dashboard-bar--four {
      animation-delay: -1.2s;
    }

    .dashboard-trend {
      animation: dashboard-trend 7s var(--ease-luxe) infinite;
    }

    .dashboard-node {
      animation: visual-node-breathe 7s var(--ease-luxe) infinite;
    }

    .market-orbit--outer,
    .market-sweep {
      animation: market-rotate 8s ease-in-out infinite;
    }

    .market-orbit--inner {
      animation: market-rotate 8s ease-in-out infinite reverse;
    }

    .market-ripple {
      animation: market-ripple 6.8s var(--ease-luxe) infinite;
    }

    .market-ripple--two {
      animation-delay: -1.2s;
    }

    .market-ripple--three {
      animation-delay: -2.4s;
    }

    .market-hub {
      animation: visual-node-breathe 5.8s ease-in-out infinite;
    }

    .market-signal {
      animation: market-signal 7.4s var(--ease-luxe) infinite;
    }

    .market-signal--two {
      animation-delay: -1s;
    }

    .market-signal--three {
      animation-delay: -2s;
    }

    .market-node {
      animation: visual-node-breathe 5.8s ease-in-out infinite;
    }

    .slide-card,
    .slide-line {
      animation: slide-build 7.4s var(--ease-luxe) infinite;
    }

    .slide-card--two,
    .slide-line--two {
      animation-delay: -0.75s;
    }

    .presentation-build {
      animation: presentation-draw 7.4s var(--ease-luxe) infinite;
    }

    .presentation-node {
      animation: visual-node-breathe 5.8s ease-in-out infinite;
    }

    .meeting-seat {
      animation: meeting-settle 7.4s var(--ease-luxe) infinite;
    }

    .meeting-seat--two {
      animation-delay: -0.35s;
    }

    .meeting-seat--three {
      animation-delay: -0.7s;
    }

    :global(.card:hover) .service-visual::before,
    :global(.pillar__visual:hover) .service-visual::before {
      opacity: 0.84;
      transform: scale(1.08);
    }
  }

  @keyframes visual-glow-one {
    0%,
    100% {
      transform: translate3d(0, 0, 0) scale(1);
    }

    50% {
      transform: translate3d(7%, -8%, 0) scale(1.08);
    }
  }

  @keyframes visual-glow-two {
    0%,
    100% {
      transform: translate3d(0, 0, 0) scale(1);
    }

    50% {
      transform: translate3d(-8%, 6%, 0) scale(1.12);
    }
  }

  @keyframes prototype-build-card {
    0%,
    8% {
      opacity: 0.34;
      transform: translate3d(0, 10px, 0) scale(0.96);
    }

    22%,
    100% {
      opacity: 1;
      transform: translate3d(0, 0, 0) scale(1);
    }
  }

  @keyframes prototype-draw {
    0%,
    18% {
      stroke-dashoffset: 1;
      opacity: 0.4;
    }

    34%,
    100% {
      stroke-dashoffset: 0;
      opacity: 1;
    }
  }

  @keyframes prototype-cursor {
    0%,
    100% {
      transform: translate3d(-88px, -54px, 0);
      opacity: 0.72;
    }

    28% {
      transform: translate3d(-58px, -26px, 0);
      opacity: 1;
    }

    58% {
      transform: translate3d(-18px, -42px, 0);
      opacity: 1;
    }

    80% {
      transform: translate3d(0, 0, 0);
      opacity: 0.82;
    }
  }

  @keyframes funnel-node {
    0%,
    100% {
      transform: scale(0.9);
      opacity: 0.64;
    }

    45% {
      transform: scale(1.16);
      opacity: 1;
    }
  }

  @keyframes flow-draw {
    0%,
    18% {
      stroke-dashoffset: 1;
      opacity: 0.45;
    }

    48%,
    100% {
      stroke-dashoffset: 0;
      opacity: 1;
    }
  }

  @keyframes dashboard-build {
    0%,
    14% {
      opacity: 0.46;
      transform: translate3d(0, 12px, 0) scaleY(0.72);
    }

    34%,
    100% {
      opacity: 1;
      transform: translate3d(0, 0, 0) scaleY(1);
    }
  }

  @keyframes dashboard-trend {
    0%,
    28% {
      stroke-dashoffset: 1;
      opacity: 0.4;
    }

    58%,
    100% {
      stroke-dashoffset: 0;
      opacity: 1;
    }
  }

  @keyframes market-rotate {
    0%,
    100% {
      transform: rotate(-6deg);
    }

    50% {
      transform: rotate(10deg);
    }
  }

  @keyframes market-ripple {
    0%,
    100% {
      transform: scale(0.92);
      opacity: 0.2;
    }

    50% {
      transform: scale(1.08);
      opacity: 0.58;
    }
  }

  @keyframes market-signal {
    0%,
    100% {
      transform: translate3d(0, 0, 0);
      opacity: 0.68;
    }

    50% {
      transform: translate3d(9px, -7px, 0);
      opacity: 1;
    }
  }

  @keyframes slide-build {
    0%,
    16% {
      opacity: 0.42;
      transform: translate3d(0, 9px, 0) scale(0.97);
    }

    34%,
    100% {
      opacity: 1;
      transform: translate3d(0, 0, 0) scale(1);
    }
  }

  @keyframes presentation-draw {
    0%,
    28% {
      stroke-dashoffset: 1;
      opacity: 0.36;
    }

    60%,
    100% {
      stroke-dashoffset: 0;
      opacity: 1;
    }
  }

  @keyframes meeting-settle {
    0%,
    100% {
      transform: translate3d(0, 0, 0);
      opacity: 0.78;
    }

    52% {
      transform: translate3d(0, -5px, 0);
      opacity: 1;
    }
  }

  @keyframes visual-node-breathe {
    0%,
    100% {
      transform: scale(1);
      opacity: 0.88;
    }

    50% {
      transform: scale(1.13);
      opacity: 1;
    }
  }
</style>
