---
import { navItems, ui } from '../content/ui';
import { siteConfig } from '../../site.config';
import { withBase } from '../lib/url';

const logoSrc = withBase('/brand/insightout-logo-light.svg');
const year = new Date().getFullYear();
---

<!-- The #contact anchor now lives on the home ContactCTA section (nav CTA
     targets {base}/#contact); the footer must not duplicate the id. --><footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <img class="footer__logo" src={logoSrc} alt={ui.logoAlt} width="220" height="66" />
      <p class="footer__tagline">{ui.footerTagline}</p>
    </div>

    <nav class="footer__nav" aria-label="Footer">
      <ul>
        {
          navItems.map((item) => (
            <li>
              <a href={withBase(item.href)}>{item.label}</a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>

  <div class="container footer__base">
    <p class="footer__copy">© {year} {siteConfig.name}. {ui.footerRights}</p>
  </div>
</footer>

<style>
  .footer {
    background: var(--surface-2);
    border-block-start: 1px solid var(--hairline);
    margin-block-start: auto;
  }

  .footer__inner {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 2.5rem;
    padding-block: clamp(2.5rem, 6vw, 4rem) 2rem;
  }

  .footer__brand {
    max-inline-size: 360px;
  }

  .footer__logo {
    inline-size: auto;
    block-size: 44px;
    margin-block-end: 1rem;
  }

  .footer__tagline {
    color: var(--graphite);
    margin: 0;
  }

  .footer__nav ul {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.75rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer__nav a {
    color: var(--graphite);
    font-weight: 500;
    transition: color var(--dur-fast) var(--ease-out);
  }

  .footer__nav a:hover {
    color: var(--ink);
  }

  .footer__base {
    border-block-start: 1px solid var(--hairline);
    padding-block: 1.25rem 1.5rem;
  }

  .footer__copy {
    color: var(--graphite);
    font-size: 0.875rem;
    margin: 0;
  }
</style>
