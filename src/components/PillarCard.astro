---
import { withBase } from '../lib/url';
import ServiceVisual, { type ServiceVisualVariant } from './ServiceVisual.astro';

interface Props {
  /** Pillar name (SPEC §2), shown as the card kicker. */
  pillar: string;
  /** Outcome headline - leads the card (SPEC §5.1 #3). */
  headline: string;
  offerings: readonly string[];
  /** Services-page anchor (slugs stable since M2). */
  href: string;
  /** Sourced from the page's content file alongside the rest of the copy. */
  linkLabel: string;
  /** 'engine' = Material card; 'seat' = inverted Pillar 4 card (§6). */
  variant?: 'engine' | 'seat';
  /** Stagger offset for the rise-on-enter reveal (§6: 60–80ms steps). */
  revealDelay?: number;
  body?: string;
  /** Brand-native data-motif for the gradient hero zone. */
  motif?: 'devices' | 'funnel' | 'trend' | 'network' | 'streams';
}

const {
  pillar,
  headline,
  offerings,
  href,
  linkLabel,
  variant = 'engine',
  revealDelay = 0,
  body,
  motif,
} = Astro.props;

const motifMap: Record<NonNullable<typeof motif>, ServiceVisualVariant> = {
  devices: 'product',
  funnel: 'behavior',
  trend: 'data',
  network: 'market',
  streams: 'advisory',
};
---

<article
  class:list={['card', `card--${variant}`]}
  data-reveal
  data-spotlight
  style={`--reveal-delay: ${revealDelay}ms`}
>
  {
    motif && (
      <div class="card__viz" aria-hidden="true">
        <ServiceVisual variant={motifMap[motif]} size="card" />
      </div>
    )
  }

  <div class="card__content">
    <p class="card__kicker">{pillar}</p>
    <h3 class="card__headline">{headline}</h3>
    {body && <p class="card__body">{body}</p>}
    <ul class="card__offerings">
      {offerings.map((o) => <li>{o}</li>)}
    </ul>
    <a class="card__link" href={withBase(href)} data-magnetic={variant === 'seat' ? true : undefined}>
      {linkLabel}
      <span aria-hidden="true" class="card__arrow">→</span>
    </a>
  </div>
</article>

<style>
  .card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
    overflow: hidden;
    transition:
      transform var(--dur-hover) var(--ease-luxe),
      box-shadow var(--dur-hover) var(--ease-luxe);
  }

  /* Micro motion (§6): hover lift, transform + shadow only - slow register. */
  .card:hover {
    box-shadow: var(--shadow-card-hover);
  }

  /* Cursor-tracking spotlight (M4): a soft derived violet/indigo radial glow that the
     Base script eases across the surface. Opacity 0 until JS + fine pointer +
     motion-ok all hold, so it simply never appears otherwise. */
  .card::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    background: radial-gradient(
      300px circle at var(--spot-x, 50%) var(--spot-y, 50%),
      color-mix(in srgb, var(--spotlight) 18%, transparent),
      transparent 70%
    );
    filter: hue-rotate(30deg) saturate(1.22);
    opacity: var(--spot-o, 0);
    transition: opacity 0.6s var(--ease-luxe);
  }

  /* ---- Gradient hero zone (BACKLOG Entry A): blue-on-warm, tokens only ---- */
  .card__viz {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    block-size: 136px;
    flex: none;
    background: linear-gradient(
      168deg,
      var(--surface) 0%,
      var(--glass-hi) 52%,
      color-mix(in srgb, var(--glass-lo) 38%, var(--glass-hi)) 100%
    );
    border-block-end: 1px solid var(--hairline);
    isolation: isolate;
    overflow: hidden;
  }

  .card__viz::before,
  .card__viz::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .card__viz::before {
    z-index: 0;
    background:
      radial-gradient(
        180px circle at 22% 26%,
        color-mix(in srgb, var(--surface) 92%, transparent),
        transparent 66%
      ),
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--surface) 38%, transparent),
        transparent 62%
      );
    opacity: 0.72;
  }

  .card__viz::after {
    z-index: 2;
    background: linear-gradient(
      105deg,
      transparent 18%,
      color-mix(in srgb, var(--surface) 34%, transparent) 46%,
      transparent 72%
    );
    opacity: 0;
    transform: translate3d(-36%, 0, 0);
    transition:
      opacity var(--dur-hover) var(--ease-luxe),
      transform 900ms var(--ease-luxe);
  }

  .card__viz :global(.service-visual) {
    position: relative;
    z-index: 1;
    transition: transform var(--dur-hover) var(--ease-luxe);
  }

  .card__content {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: clamp(1.6rem, 3vw, 2.1rem);
  }

  .card__kicker {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--signal-text);
    margin-block-end: 0.75rem;
  }

  .card__headline {
    font-size: clamp(1.25rem, 2vw, 1.5rem);
    margin-block-end: 0.5rem;
  }

  .card__body {
    color: var(--graphite);
    margin-block-end: 0.5rem;
  }

  .card__offerings {
    list-style: none;
    margin: 0.5rem 0 1.25rem;
    padding: 0;
    color: var(--graphite);
  }

  .card__offerings li {
    padding-block: 0.4rem;
    padding-inline-start: 1.1rem;
    position: relative;
  }

  .card__offerings li::before {
    content: '';
    position: absolute;
    inset-inline-start: 0;
    inset-block-start: 0.95em;
    inline-size: 0.4rem;
    block-size: 2px;
    border-radius: 1px;
    background: var(--signal);
  }

  .card__link {
    margin-block-start: auto;
    font-weight: 600;
    font-size: 0.95rem;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .card__arrow {
    transition: transform var(--dur-hover) var(--ease-luxe);
  }

  .card__link:hover .card__arrow {
    transform: translateX(3px);
  }

  /* ---- Pillar 4: the seat. Inverted ink, equal hero-zone polish (§6). ---- */
  .card--seat {
    background: var(--ink-surface);
    color: var(--on-ink);
  }

  .card--seat::after {
    background: radial-gradient(
      320px circle at var(--spot-x, 50%) var(--spot-y, 50%),
      color-mix(in srgb, var(--spotlight) 22%, transparent),
      transparent 70%
    );
    filter: hue-rotate(30deg) saturate(1.22);
  }

  .card--seat .card__viz {
    block-size: 150px;
    background: linear-gradient(
      168deg,
      var(--ink-surface) 0%,
      color-mix(in srgb, var(--signal) 16%, var(--ink-surface)) 62%,
      color-mix(in srgb, var(--signal) 30%, var(--ink-surface)) 100%
    );
    border-block-end: 1px solid rgba(255, 255, 255, 0.08);
  }

  .card--seat .card__viz::before {
    background:
      radial-gradient(
        190px circle at 24% 28%,
        color-mix(in srgb, var(--speed-from) 16%, transparent),
        transparent 68%
      ),
      linear-gradient(180deg, rgba(255, 255, 255, 0.08), transparent 58%);
  }

  .card--seat .card__kicker {
    color: var(--speed-from);
  }

  .card--seat .card__headline {
    font-size: clamp(1.5rem, 2.6vw, 2rem);
  }

  .card--seat .card__body,
  .card--seat .card__offerings {
    color: rgba(255, 255, 255, 0.78);
  }

  .card--seat .card__link {
    align-self: flex-start;
    background: var(--signal);
    color: var(--on-ink);
    padding: 0.6rem 1.2rem;
    border-radius: var(--radius-sm);
    transition:
      background var(--dur-fast) var(--ease-out),
      transform var(--dur-fast) var(--ease-out);
  }

  .card--seat .card__link:hover {
    background: var(--signal-hover);
    transform: translateY(-2px);
  }

  @media (prefers-reduced-motion: no-preference) {
    .card:hover {
      transform: translateY(-6px);
    }

    .card:hover .card__viz::after {
      opacity: 1;
      transform: translate3d(36%, 0, 0);
    }

    .card:hover .card__viz :global(.service-visual) {
      transform: translate3d(0, -2px, 0) scale(1.018);
    }
  }

  /* Full-width seat panel: two-column internal layout on desktop. */
  @media (min-width: 860px) {
    .card--seat .card__content {
      display: grid;
      grid-template-areas:
        'kicker offerings'
        'headline offerings'
        'body offerings'
        'link offerings';
      grid-template-columns: 1.15fr 1fr;
      grid-template-rows: auto auto auto 1fr;
      column-gap: clamp(2rem, 5vw, 4rem);
      padding: clamp(2rem, 4vw, 3rem);
    }

    .card--seat .card__kicker {
      grid-area: kicker;
    }
    .card--seat .card__headline {
      grid-area: headline;
    }
    .card--seat .card__body {
      grid-area: body;
    }
    .card--seat .card__offerings {
      grid-area: offerings;
      margin-block: 0.25rem 0;
    }
    .card--seat .card__link {
      grid-area: link;
      align-self: end;
      justify-self: start;
      margin-block-start: 1.5rem;
    }
  }
</style>
