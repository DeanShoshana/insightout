---
import { withBase } from '../lib/url';

interface Props {
  /** Pillar name (SPEC §2), shown as the card kicker. */
  pillar: string;
  /** Outcome headline - leads the card (SPEC §5.1 #3). */
  headline: string;
  offerings: readonly string[];
  /** Services-page anchor (slugs stable since M2). */
  href: string;
  /** Sourced from the page's content file alongside the rest of the copy. */
  linkLabel: string;
  /** 'engine' = Material card; 'seat' = inverted Pillar 4 card (§6). */
  variant?: 'engine' | 'seat';
  /** Stagger offset for the rise-on-enter reveal (§6: 60–80ms steps). */
  revealDelay?: number;
  body?: string;
  /** Brand-native data-motif for the gradient hero zone (BACKLOG Entry A).
      One per pillar: funnel | trend | network | streams. */
  motif?: 'funnel' | 'trend' | 'network' | 'streams';
}

const {
  pillar,
  headline,
  offerings,
  href,
  linkLabel,
  variant = 'engine',
  revealDelay = 0,
  body,
  motif,
} = Astro.props;
---

<article
  class:list={['card', `card--${variant}`]}
  data-reveal
  data-spotlight
  style={`--reveal-delay: ${revealDelay}ms`}
>
  {
    motif && (
      <div class="card__viz" aria-hidden="true">
        {motif === 'funnel' && (
          <svg viewBox="0 0 220 120" class="card__motif">
            <g fill="var(--glass-lo)">
              <rect x="35" y="14" width="150" height="13" rx="6.5" opacity="0.55" />
              <rect x="57" y="40" width="106" height="13" rx="6.5" opacity="0.75" />
              <rect x="76" y="66" width="68" height="13" rx="6.5" opacity="0.9" />
            </g>
            <rect x="92" y="92" width="36" height="13" rx="6.5" fill="var(--signal)" />
          </svg>
        )}
        {motif === 'trend' && (
          <svg viewBox="0 0 220 120" class="card__motif">
            <defs>
              <linearGradient id="pm-trend" gradientUnits="userSpaceOnUse" x1="20" y1="100" x2="200" y2="24">
                <stop offset="0" stop-color="#7FAFF8" />
                <stop offset="1" stop-color="#2470E5" />
              </linearGradient>
            </defs>
            <path d="M 16 104 H 204" stroke="var(--glass-lo)" stroke-width="2" stroke-linecap="round" opacity="0.5" fill="none" />
            <path
              d="M 20 96 C 60 92, 76 70, 104 66 S 150 58, 166 40 S 192 26, 200 24"
              fill="none"
              stroke="url(#pm-trend)"
              stroke-width="3.5"
              stroke-linecap="round"
            />
            <circle cx="124" cy="62" r="6" fill="var(--signal)" />
          </svg>
        )}
        {motif === 'network' && (
          <svg viewBox="0 0 220 120" class="card__motif">
            <g stroke="var(--glass-lo)" stroke-width="2" opacity="0.8">
              <path d="M 52 88 L 104 60 L 62 28 M 104 60 L 162 80 L 186 36 L 104 60 M 52 88 L 162 80" fill="none" />
            </g>
            <g fill="var(--glass-lo)">
              <circle cx="62" cy="28" r="8" />
              <circle cx="52" cy="88" r="7" />
              <circle cx="186" cy="36" r="7" />
            </g>
            <circle cx="104" cy="60" r="10" fill="var(--signal)" />
            <circle cx="162" cy="80" r="8" fill="var(--speed-from)" />
          </svg>
        )}
        {motif === 'streams' && (
          <svg viewBox="0 0 220 120" class="card__motif">
            <defs>
              <linearGradient id="pm-seat" gradientUnits="userSpaceOnUse" x1="148" y1="60" x2="64" y2="60">
                <stop offset="0" stop-color="#7FAFF8" />
                <stop offset="1" stop-color="#2470E5" />
              </linearGradient>
            </defs>
            <g stroke="var(--glass-lo)" stroke-width="2.5" stroke-linecap="round" fill="none" opacity="0.85">
              <path d="M 204 24 C 176 24, 168 56, 148 58" />
              <path d="M 208 60 L 148 60" />
              <path d="M 204 96 C 176 96, 168 64, 148 62" />
            </g>
            <circle cx="144" cy="60" r="6.5" fill="var(--speed-from)" />
            <path d="M 137 60 L 64 60" stroke="url(#pm-seat)" stroke-width="3.5" stroke-linecap="round" fill="none" />
            <rect x="18" y="46" width="46" height="28" rx="9" fill="var(--speed-from)" opacity="0.92" />
          </svg>
        )}
      </div>
    )
  }

  <div class="card__content">
    <p class="card__kicker">{pillar}</p>
    <h3 class="card__headline">{headline}</h3>
    {body && <p class="card__body">{body}</p>}
    <ul class="card__offerings">
      {offerings.map((o) => <li>{o}</li>)}
    </ul>
    <a class="card__link" href={withBase(href)} data-magnetic={variant === 'seat' ? true : undefined}>
      {linkLabel}
      <span aria-hidden="true" class="card__arrow">→</span>
    </a>
  </div>
</article>

<style>
  .card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
    overflow: hidden;
    transition:
      transform var(--dur-hover) var(--ease-luxe),
      box-shadow var(--dur-hover) var(--ease-luxe);
  }

  /* Micro motion (§6): hover lift, transform + shadow only - slow register. */
  .card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-card-hover);
  }

  /* Cursor-tracking spotlight (M4): a soft signal-blue radial glow that the
     Base script eases across the surface. Opacity 0 until JS + fine pointer +
     motion-ok all hold, so it simply never appears otherwise. */
  .card::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    background: radial-gradient(
      300px circle at var(--spot-x, 50%) var(--spot-y, 50%),
      color-mix(in srgb, var(--signal) 9%, transparent),
      transparent 70%
    );
    opacity: var(--spot-o, 0);
    transition: opacity 0.6s var(--ease-luxe);
  }

  /* ---- Gradient hero zone (BACKLOG Entry A): blue-on-warm, tokens only ---- */
  .card__viz {
    display: flex;
    align-items: center;
    justify-content: center;
    block-size: 136px;
    flex: none;
    background: linear-gradient(
      168deg,
      var(--surface) 0%,
      var(--glass-hi) 52%,
      color-mix(in srgb, var(--glass-lo) 38%, var(--glass-hi)) 100%
    );
    border-block-end: 1px solid var(--hairline);
  }

  .card__motif {
    inline-size: min(62%, 200px);
    block-size: auto;
  }

  .card__content {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: clamp(1.6rem, 3vw, 2.1rem);
  }

  .card__kicker {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--signal-text);
    margin-block-end: 0.75rem;
  }

  .card__headline {
    font-size: clamp(1.25rem, 2vw, 1.5rem);
    margin-block-end: 0.5rem;
  }

  .card__body {
    color: var(--graphite);
    margin-block-end: 0.5rem;
  }

  .card__offerings {
    list-style: none;
    margin: 0.5rem 0 1.25rem;
    padding: 0;
    color: var(--graphite);
  }

  .card__offerings li {
    padding-block: 0.4rem;
    padding-inline-start: 1.1rem;
    position: relative;
  }

  .card__offerings li::before {
    content: '';
    position: absolute;
    inset-inline-start: 0;
    inset-block-start: 0.95em;
    inline-size: 0.4rem;
    block-size: 2px;
    border-radius: 1px;
    background: var(--signal);
  }

  .card__link {
    margin-block-start: auto;
    font-weight: 600;
    font-size: 0.95rem;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .card__arrow {
    transition: transform var(--dur-hover) var(--ease-luxe);
  }

  .card__link:hover .card__arrow {
    transform: translateX(3px);
  }

  /* ---- Pillar 4: the seat. Inverted ink, equal hero-zone polish (§6). ---- */
  .card--seat {
    background: var(--ink-surface);
    color: var(--on-ink);
  }

  .card--seat::after {
    background: radial-gradient(
      320px circle at var(--spot-x, 50%) var(--spot-y, 50%),
      color-mix(in srgb, var(--speed-from) 13%, transparent),
      transparent 70%
    );
  }

  .card--seat .card__viz {
    block-size: 150px;
    background: linear-gradient(
      168deg,
      var(--ink-surface) 0%,
      color-mix(in srgb, var(--signal) 16%, var(--ink-surface)) 62%,
      color-mix(in srgb, var(--signal) 30%, var(--ink-surface)) 100%
    );
    border-block-end: 1px solid rgba(255, 255, 255, 0.08);
  }

  .card--seat .card__kicker {
    color: var(--speed-from);
  }

  .card--seat .card__headline {
    font-size: clamp(1.5rem, 2.6vw, 2rem);
  }

  .card--seat .card__body,
  .card--seat .card__offerings {
    color: rgba(255, 255, 255, 0.78);
  }

  .card--seat .card__link {
    align-self: flex-start;
    background: var(--signal);
    color: var(--on-ink);
    padding: 0.6rem 1.2rem;
    border-radius: var(--radius-sm);
    transition:
      background var(--dur-fast) var(--ease-out),
      transform var(--dur-fast) var(--ease-out);
  }

  .card--seat .card__link:hover {
    background: var(--signal-hover);
    transform: translateY(-2px);
  }

  /* Full-width seat panel: two-column internal layout on desktop. */
  @media (min-width: 860px) {
    .card--seat .card__content {
      display: grid;
      grid-template-areas:
        'kicker offerings'
        'headline offerings'
        'body offerings'
        'link offerings';
      grid-template-columns: 1.15fr 1fr;
      grid-template-rows: auto auto auto 1fr;
      column-gap: clamp(2rem, 5vw, 4rem);
      padding: clamp(2rem, 4vw, 3rem);
    }

    .card--seat .card__kicker {
      grid-area: kicker;
    }
    .card--seat .card__headline {
      grid-area: headline;
    }
    .card--seat .card__body {
      grid-area: body;
    }
    .card--seat .card__offerings {
      grid-area: offerings;
      margin-block: 0.25rem 0;
    }
    .card--seat .card__link {
      grid-area: link;
      align-self: end;
      justify-self: start;
      margin-block-start: 1.5rem;
    }
  }
</style>
