---
// Closing CTA (SPEC §5.1 #6 / §5.6): "Work with Claritix" - name, email,
// one-line message. No dropdowns, no budget selectors.
// M5b: wired to Formspree. The endpoint is public by design; the destination
// address stays server-side - no email is ever rendered into the markup.
import { home } from '../content/home';
import { siteConfig } from '../../site.config';

const { contact } = home;
const { mode, target } = siteConfig.contact;
const action = mode === 'endpoint' ? target : target ? `mailto:${target}` : undefined;
// Only endpoint submissions are AJAX-enhanced; mailto (if ever used) falls back.
const ajax = mode === 'endpoint' && !!action;
---

<section class="contact" id="contact">
  <div class="container contact__inner">
    <div class="contact__copy" data-reveal>
      <!-- DRAFT COPY -->
      <p class="contact__kicker">{contact.kicker}</p>
      <h2 class="contact__headline">{contact.headline}</h2>
      <p class="contact__body">{contact.body}</p>
      <div class="contact__constellation" aria-hidden="true">
        <span>Product question</span>
        <span>Evidence base</span>
        <span>Decision frame</span>
      </div>
    </div>

    <div class="contact__workspace" data-reveal data-spotlight style="--reveal-delay: 80ms">
      <div class="contact__motion" aria-hidden="true">
        <span class="contact__motion-card contact__motion-card--one"></span>
        <span class="contact__motion-card contact__motion-card--two"></span>
        <span class="contact__motion-card contact__motion-card--three"></span>
        <span class="contact__motion-line contact__motion-line--one"></span>
        <span class="contact__motion-line contact__motion-line--two"></span>
        <span class="contact__motion-node contact__motion-node--one"></span>
        <span class="contact__motion-node contact__motion-node--two"></span>
      </div>

      <form
        class="contact__form"
        method="POST"
        action={action}
        data-ajax={ajax ? 'true' : 'false'}
        data-sending={contact.sending}
        data-submit={contact.submit}
        data-success={contact.successNote}
        data-error={contact.errorNote}
      >
        <div class="contact__row">
          <div class="contact__field">
            <label for="contact-name">{contact.fields.name}</label>
            <input id="contact-name" name="name" type="text" autocomplete="name" required />
          </div>

          <div class="contact__field">
            <label for="contact-email">{contact.fields.email}</label>
            <input id="contact-email" name="email" type="email" autocomplete="email" required />
          </div>
        </div>

        <div class="contact__field">
          <label for="contact-message">{contact.fields.message}</label>
          <textarea
            id="contact-message"
            name="message"
            rows="3"
            placeholder={contact.messagePlaceholder}
            required></textarea>
        </div>

        <!-- Formspree honeypot: bots fill it, humans never see it; if set,
             Formspree silently drops the submission. -->
        <input
          class="contact__gotcha"
          type="text"
          name="_gotcha"
          tabindex="-1"
          autocomplete="off"
          aria-hidden="true"
        />

        <button class="contact__submit" type="submit" data-magnetic>{contact.submit}</button>

        <!-- DRAFT COPY - post-submit states, announced politely. -->
        <p class="contact__status" role="status" aria-live="polite" hidden></p>
      </form>
    </div>
  </div>
</section>

<script>
  const form = document.querySelector<HTMLFormElement>('.contact__form');
  if (form && form.dataset.ajax === 'true') {
    const status = form.querySelector<HTMLElement>('.contact__status')!;
    const submit = form.querySelector<HTMLButtonElement>('.contact__submit')!;
    const successNote = form.dataset.success!;
    const errorNote = form.dataset.error!;
    const sending = form.dataset.sending!;
    const submitLabel = form.dataset.submit!;

    const setStatus = (msg: string, kind: 'error' | '') => {
      status.textContent = msg;
      status.hidden = false;
      status.classList.toggle('is-error', kind === 'error');
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      // Let native required/email validation gate the submit.
      if (!form.reportValidity()) return;

      submit.disabled = true;
      submit.textContent = sending;
      status.hidden = true;
      status.classList.remove('is-error');

      try {
        const res = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { Accept: 'application/json' },
        });
        if (res.ok) {
          // Replace the form with the success message (no reload jank). A state
          // class hides every field/control - the `hidden` attribute alone is
          // overridden by the fields' own display rules (equal specificity).
          form.reset();
          form.classList.add('is-sent');
          setStatus(successNote, '');
          status.setAttribute('tabindex', '-1');
          status.focus();
        } else {
          setStatus(errorNote, 'error');
          submit.disabled = false;
          submit.textContent = submitLabel;
        }
      } catch {
        setStatus(errorNote, 'error');
        submit.disabled = false;
        submit.textContent = submitLabel;
      }
    });
  }
</script>

<style>
  .contact {
    position: relative;
    overflow: hidden;
    padding-block: var(--section-pad);
    background:
      radial-gradient(
        760px circle at 14% 18%,
        color-mix(in srgb, var(--signal) 13%, transparent),
        transparent 58%
      ),
      linear-gradient(
        180deg,
        var(--surface) 0%,
        color-mix(in srgb, var(--surface-2) 78%, var(--surface)) 100%
      );
  }

  .contact::before {
    content: '';
    position: absolute;
    inset-inline: var(--gutter);
    inset-block-start: 0;
    block-size: 1px;
    max-inline-size: var(--content-max);
    margin-inline: auto;
    background: linear-gradient(90deg, transparent, var(--hairline), transparent);
  }

  .contact__inner {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 0.88fr) minmax(0, 1.12fr);
    gap: clamp(2rem, 6vw, 5rem);
    align-items: center;
  }

  @media (max-width: 860px) {
    .contact__inner {
      grid-template-columns: 1fr;
    }
  }

  .contact__kicker {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--signal-text);
    margin-block-end: 0.75rem;
  }

  .contact__headline {
    font-size: clamp(2.25rem, 5vw, 4rem);
    max-inline-size: 11ch;
  }

  .contact__body {
    color: var(--graphite);
    font-size: clamp(1.1rem, 2vw, 1.25rem);
    max-inline-size: 34ch;
  }

  .contact__constellation {
    display: grid;
    gap: 0.65rem;
    max-inline-size: 22rem;
    margin-block-start: clamp(1.5rem, 4vw, 2.5rem);
  }

  .contact__constellation span {
    position: relative;
    min-block-size: 2.6rem;
    display: flex;
    align-items: center;
    padding-inline: 0.85rem 2.3rem;
    border: 1px solid color-mix(in srgb, var(--signal) 18%, var(--hairline));
    border-radius: var(--radius-sm);
    background: color-mix(in srgb, var(--surface) 58%, transparent);
    -webkit-backdrop-filter: blur(12px);
    backdrop-filter: blur(12px);
    color: var(--ink);
    font-weight: 650;
    box-shadow: 0 16px 40px color-mix(in srgb, var(--ink) 5%, transparent);
  }

  .contact__constellation span::after {
    content: '';
    position: absolute;
    inset-inline-end: 0.85rem;
    inset-block-start: 50%;
    inline-size: 0.55rem;
    block-size: 0.55rem;
    transform: translateY(-50%);
    border-radius: 999px;
    background: var(--signal);
    box-shadow: 0 0 0 7px color-mix(in srgb, var(--signal) 12%, transparent);
  }

  .contact__workspace {
    position: relative;
    min-block-size: clamp(520px, 44vw, 640px);
    display: grid;
    align-items: end;
    padding: clamp(1rem, 2vw, 1.4rem);
    border-radius: calc(var(--radius-card) + 8px);
    background:
      radial-gradient(
        520px circle at 74% 16%,
        color-mix(in srgb, var(--signal) 18%, transparent),
        transparent 64%
      ),
      linear-gradient(
        145deg,
        color-mix(in srgb, var(--surface) 92%, var(--glass-hi)) 0%,
        color-mix(in srgb, var(--surface-2) 82%, var(--surface)) 100%
      );
    box-shadow:
      0 28px 90px color-mix(in srgb, var(--ink) 10%, transparent),
      inset 0 1px 0 color-mix(in srgb, white 58%, transparent);
    overflow: hidden;
    isolation: isolate;
  }

  .contact__workspace::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(
      420px circle at var(--spot-x, 50%) var(--spot-y, 50%),
      color-mix(in srgb, var(--signal) 13%, transparent),
      transparent 70%
    );
    opacity: var(--spot-o, 0);
    transition: opacity 0.7s var(--ease-luxe);
  }

  .contact__motion {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .contact__motion-card {
    position: absolute;
    border: 1px solid color-mix(in srgb, var(--signal) 22%, var(--hairline));
    border-radius: 22px;
    background:
      linear-gradient(
        145deg,
        color-mix(in srgb, var(--surface) 74%, transparent),
        color-mix(in srgb, var(--glass-hi) 45%, transparent)
      );
    -webkit-backdrop-filter: blur(14px);
    backdrop-filter: blur(14px);
    box-shadow: 0 24px 70px color-mix(in srgb, var(--ink) 9%, transparent);
  }

  .contact__motion-card::before,
  .contact__motion-card::after {
    content: '';
    position: absolute;
    inset-inline-start: 16%;
    block-size: 3px;
    border-radius: 999px;
    background: color-mix(in srgb, var(--glass-lo) 70%, transparent);
  }

  .contact__motion-card::before {
    inset-block-start: 34%;
    inline-size: 54%;
  }

  .contact__motion-card::after {
    inset-block-start: 54%;
    inline-size: 34%;
    background: var(--signal);
  }

  .contact__motion-card--one {
    inline-size: 36%;
    aspect-ratio: 1.65;
    inset-inline-start: 8%;
    inset-block-start: 9%;
    transform: rotate(-6deg);
  }

  .contact__motion-card--two {
    inline-size: 24%;
    aspect-ratio: 0.72;
    inset-inline-end: 11%;
    inset-block-start: 14%;
    transform: rotate(5deg);
  }

  .contact__motion-card--three {
    inline-size: 30%;
    aspect-ratio: 1.45;
    inset-inline-start: 32%;
    inset-block-start: 34%;
    transform: rotate(2deg);
  }

  .contact__motion-line {
    position: absolute;
    block-size: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      color-mix(in srgb, var(--signal) 64%, transparent),
      transparent
    );
    opacity: 0.72;
  }

  .contact__motion-line--one {
    inline-size: 62%;
    inset-inline-start: 17%;
    inset-block-start: 32%;
    transform: rotate(8deg);
  }

  .contact__motion-line--two {
    inline-size: 56%;
    inset-inline-start: 22%;
    inset-block-start: 48%;
    transform: rotate(-7deg);
  }

  .contact__motion-node {
    position: absolute;
    inline-size: 10px;
    block-size: 10px;
    border-radius: 999px;
    background: var(--signal);
    box-shadow: 0 0 0 8px color-mix(in srgb, var(--signal) 12%, transparent);
  }

  .contact__motion-node--one {
    inset-inline-start: 28%;
    inset-block-start: 31%;
  }

  .contact__motion-node--two {
    inset-inline-end: 25%;
    inset-block-start: 47%;
  }

  .contact__form {
    position: relative;
    z-index: 1;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--surface) 94%, var(--on-ink)) 0%, var(--surface) 100%);
    border: 1px solid color-mix(in srgb, var(--hairline) 78%, transparent);
    border-radius: var(--radius-card);
    box-shadow:
      var(--shadow-card-hover),
      0 18px 60px color-mix(in srgb, var(--signal) 9%, transparent);
    padding: clamp(1.5rem, 3vw, 2rem);
    transition:
      border-color var(--dur-med) var(--ease-out),
      box-shadow var(--dur-med) var(--ease-out),
      transform var(--dur-med) var(--ease-out);
  }

  .contact__form:focus-within {
    border-color: color-mix(in srgb, var(--signal) 42%, var(--hairline));
    box-shadow:
      var(--shadow-card-hover),
      0 0 0 1px color-mix(in srgb, var(--signal) 12%, transparent);
    transform: translateY(-2px);
  }

  /* Speed-line accent (§6: the one accent spikes at insight/CTA moments) -
     lifts the card out of default-contact-box territory. */
  .contact__form::before {
    content: '';
    position: absolute;
    inset-block-start: 0;
    inset-inline: 0;
    block-size: 3px;
    background: linear-gradient(90deg, var(--speed-from), var(--speed-to));
  }

  @media (prefers-reduced-motion: no-preference) {
    .contact__motion-card--one {
      animation: contact-float-a 11s var(--ease-luxe) infinite;
    }

    .contact__motion-card--two {
      animation: contact-float-b 10s var(--ease-luxe) infinite;
    }

    .contact__motion-card--three {
      animation: contact-float-c 12s var(--ease-luxe) infinite;
    }

    .contact__motion-node {
      animation: contact-node 4.2s var(--ease-luxe) infinite;
    }

    .contact__motion-node--two {
      animation-delay: -1.7s;
    }

    .contact__constellation span {
      animation: contact-chip 8s var(--ease-luxe) infinite;
    }

    .contact__constellation span:nth-child(2) {
      animation-delay: -1.6s;
    }

    .contact__constellation span:nth-child(3) {
      animation-delay: -3.1s;
    }
  }

  @keyframes contact-float-a {
    0%,
    100% {
      transform: translate3d(0, 0, 0) rotate(-6deg);
    }

    50% {
      transform: translate3d(18px, -14px, 0) rotate(-3deg);
    }
  }

  @keyframes contact-float-b {
    0%,
    100% {
      transform: translate3d(0, 0, 0) rotate(5deg);
    }

    50% {
      transform: translate3d(-14px, 18px, 0) rotate(2deg);
    }
  }

  @keyframes contact-float-c {
    0%,
    100% {
      transform: translate3d(0, 0, 0) rotate(2deg);
    }

    50% {
      transform: translate3d(-12px, -10px, 0) rotate(5deg);
    }
  }

  @keyframes contact-node {
    0%,
    54%,
    100% {
      opacity: 0.5;
      transform: scale(0.92);
    }

    20% {
      opacity: 1;
      transform: scale(1.14);
    }
  }

  @keyframes contact-chip {
    0%,
    100% {
      transform: translate3d(0, 0, 0);
    }

    50% {
      transform: translate3d(8px, -8px, 0);
    }
  }

  .contact__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.1rem;
  }

  @media (max-width: 560px) {
    .contact__row {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 860px) {
    .contact__workspace {
      min-block-size: auto;
      padding: 0.9rem;
    }

    .contact__motion {
      opacity: 0.5;
    }
  }

  @media (max-width: 560px) {
    .contact__constellation {
      display: none;
    }

    .contact__motion-card--three,
    .contact__motion-line--two,
    .contact__motion-node--two {
      display: none;
    }

    .contact__form {
      padding: 1rem;
    }
  }

  .contact__field {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    transition: transform var(--dur-med) var(--ease-out);
  }

  .contact__field:focus-within {
    transform: translateY(-2px);
  }

  .contact__field label {
    font-weight: 600;
    font-size: 0.925rem;
  }

  .contact__field input,
  .contact__field textarea {
    font: inherit;
    color: var(--ink);
    background: color-mix(in srgb, var(--surface) 88%, var(--surface-2));
    border: 1px solid var(--hairline);
    border-radius: var(--radius-sm);
    padding: 0.78rem 0.9rem;
    box-shadow: inset 0 1px 0 color-mix(in srgb, var(--on-ink) 32%, transparent);
    transition:
      background var(--dur-med) var(--ease-out),
      border-color var(--dur-med) var(--ease-out),
      box-shadow var(--dur-med) var(--ease-out);
  }

  .contact__field input:focus-visible,
  .contact__field textarea:focus-visible {
    outline: 2px solid var(--signal);
    outline-offset: 1px;
    border-color: var(--signal);
    box-shadow:
      0 0 0 4px color-mix(in srgb, var(--signal) 14%, transparent),
      inset 0 1px 0 color-mix(in srgb, var(--on-ink) 34%, transparent);
  }

  .contact__field textarea {
    resize: vertical;
    min-block-size: 4.5rem;
  }

  .contact__field ::placeholder {
    color: var(--graphite);
    opacity: 0.7;
  }

  .contact__submit {
    position: relative;
    z-index: 1;
    inline-size: 100%;
    font: inherit;
    font-weight: 600;
    font-size: 1rem;
    background: var(--signal);
    color: var(--on-ink);
    border: 0;
    border-radius: var(--radius-sm);
    padding: 0.8rem 1.8rem;
    cursor: pointer;
    transition:
      background var(--dur-fast) var(--ease-out),
      transform var(--dur-fast) var(--ease-out),
      box-shadow var(--dur-fast) var(--ease-out);
  }

  .contact__submit:hover {
    background: var(--signal-hover);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(36, 112, 229, 0.28);
  }

  /* Honeypot: removed from layout and the a11y tree, off-screen for bots. */
  .contact__gotcha {
    position: absolute;
    inline-size: 1px;
    block-size: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    border: 0;
  }

  /* Sent state: hide every field/control, leave only the status message.
     Higher specificity than the fields' own display rules, so it wins. */
  .contact__form.is-sent > :not(.contact__status) {
    display: none;
  }

  .contact__status {
    position: relative;
    z-index: 1;
    margin: 0;
    font-size: 1rem;
    font-weight: 500;
    color: var(--ink);
  }

  .contact__form.is-sent .contact__status {
    font-size: clamp(1.1rem, 2vw, 1.3rem);
    padding-block: clamp(2rem, 5vw, 3.5rem);
  }

  /* Error keeps the form visible for retry (the success path hides it), so it
     reads as an error from context - no new color token introduced. */
  .contact__status.is-error {
    font-weight: 400;
    font-size: 0.9rem;
    color: var(--ink);
  }

  .contact__status:focus-visible {
    outline: 2px solid var(--signal);
    outline-offset: 4px;
  }
</style>
