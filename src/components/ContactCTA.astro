---
// Closing CTA (SPEC §5.1 #6 / §5.6): "Work with InsightOut" — name, email,
// one-line message. No dropdowns, no budget selectors. The backend choice is
// OPEN (§5.6); wiring happens at M5. Until siteConfig.contact.target is set,
// submit shows an honest "not live yet" note instead of pretending to send.
import { home } from '../content/home';
import { siteConfig } from '../../site.config';

const { contact } = home;
const { mode, target } = siteConfig.contact;

// Forward-compatible: when M5 sets a target, the form posts without code changes.
const action =
  target === '' ? undefined : mode === 'endpoint' ? target : `mailto:${target}`;
---

<section class="contact" id="contact">
  <div class="container contact__inner">
    <div class="contact__copy" data-reveal>
      <!-- DRAFT COPY -->
      <p class="contact__kicker">{contact.kicker}</p>
      <h2 class="contact__headline">{contact.headline}</h2>
      <p class="contact__body">{contact.body}</p>
    </div>

    <form
      class="contact__form"
      method={action ? 'POST' : 'GET'}
      action={action}
      data-reveal
      style="--reveal-delay: 80ms"
      data-wired={action ? 'true' : 'false'}
    >
      <div class="contact__row">
        <div class="contact__field">
          <label for="contact-name">{contact.fields.name}</label>
          <input id="contact-name" name="name" type="text" autocomplete="name" required />
        </div>

        <div class="contact__field">
          <label for="contact-email">{contact.fields.email}</label>
          <input id="contact-email" name="email" type="email" autocomplete="email" required />
        </div>
      </div>

      <div class="contact__field">
        <label for="contact-message">{contact.fields.message}</label>
        <textarea
          id="contact-message"
          name="message"
          rows="3"
          placeholder={contact.messagePlaceholder}
          required></textarea>
      </div>

      <button class="contact__submit" type="submit">{contact.submit}</button>

      <!-- DRAFT COPY -->
      <p class="contact__pending" role="status" hidden>{contact.pendingNote}</p>
    </form>
  </div>
</section>

<script>
  // Until the backend is wired (M5), block submission and show the honest note.
  const form = document.querySelector<HTMLFormElement>('.contact__form');
  if (form && form.dataset.wired === 'false') {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const note = form.querySelector<HTMLElement>('.contact__pending');
      if (note) note.hidden = false;
    });
  }
</script>

<style>
  .contact {
    /* M2b alternation: contact sits on --surface between industries (S2) and
       the footer (S2); the form card's layered shadow carries the separation. */
    padding-block: var(--section-pad);
  }

  .contact__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 6vw, 5rem);
    align-items: start;
  }

  @media (max-width: 860px) {
    .contact__inner {
      grid-template-columns: 1fr;
    }
  }

  .contact__kicker {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--signal-text);
    margin-block-end: 0.75rem;
  }

  .contact__headline {
    font-size: clamp(1.9rem, 4vw, 2.75rem);
  }

  .contact__body {
    color: var(--graphite);
    font-size: 1.1rem;
    max-inline-size: 38ch;
  }

  .contact__form {
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    background: var(--surface);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
    padding: clamp(1.5rem, 3vw, 2rem);
  }

  /* Speed-line accent (§6: the one accent spikes at insight/CTA moments) —
     lifts the card out of default-contact-box territory. */
  .contact__form::before {
    content: '';
    position: absolute;
    inset-block-start: 0;
    inset-inline: 0;
    block-size: 3px;
    background: linear-gradient(90deg, var(--speed-from), var(--speed-to));
  }

  .contact__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.1rem;
  }

  @media (max-width: 560px) {
    .contact__row {
      grid-template-columns: 1fr;
    }
  }

  .contact__field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .contact__field label {
    font-weight: 600;
    font-size: 0.925rem;
  }

  .contact__field input,
  .contact__field textarea {
    font: inherit;
    color: var(--ink);
    background: var(--surface);
    border: 1px solid var(--hairline);
    border-radius: var(--radius-sm);
    padding: 0.65rem 0.85rem;
    transition: border-color var(--dur-fast) var(--ease-out);
  }

  .contact__field input:focus-visible,
  .contact__field textarea:focus-visible {
    outline: 2px solid var(--signal);
    outline-offset: 1px;
    border-color: var(--signal);
  }

  .contact__field textarea {
    resize: vertical;
    min-block-size: 4.5rem;
  }

  .contact__field ::placeholder {
    color: var(--graphite);
    opacity: 0.7;
  }

  .contact__submit {
    inline-size: 100%;
    font: inherit;
    font-weight: 600;
    font-size: 1rem;
    background: var(--signal);
    color: var(--on-ink);
    border: 0;
    border-radius: var(--radius-sm);
    padding: 0.8rem 1.8rem;
    cursor: pointer;
    transition:
      background var(--dur-fast) var(--ease-out),
      transform var(--dur-fast) var(--ease-out),
      box-shadow var(--dur-fast) var(--ease-out);
  }

  .contact__submit:hover {
    background: var(--signal-hover);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(36, 112, 229, 0.28);
  }

  .contact__pending {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--graphite);
  }
</style>
