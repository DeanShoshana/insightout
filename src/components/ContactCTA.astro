---
// Closing CTA (SPEC §5.1 #6 / §5.6): "Work with Claritix" — name, email,
// one-line message. No dropdowns, no budget selectors.
// M5b: wired to Formspree. The endpoint is public by design; the destination
// address stays server-side — no email is ever rendered into the markup.
import { home } from '../content/home';
import { siteConfig } from '../../site.config';

const { contact } = home;
const { mode, target } = siteConfig.contact;
const action = mode === 'endpoint' ? target : target ? `mailto:${target}` : undefined;
// Only endpoint submissions are AJAX-enhanced; mailto (if ever used) falls back.
const ajax = mode === 'endpoint' && !!action;
---

<section class="contact" id="contact">
  <div class="container contact__inner">
    <div class="contact__copy" data-reveal>
      <!-- DRAFT COPY -->
      <p class="contact__kicker">{contact.kicker}</p>
      <h2 class="contact__headline">{contact.headline}</h2>
      <p class="contact__body">{contact.body}</p>
    </div>

    <form
      class="contact__form"
      method="POST"
      action={action}
      data-reveal
      data-ajax={ajax ? 'true' : 'false'}
      data-sending={contact.sending}
      data-submit={contact.submit}
      data-success={contact.successNote}
      data-error={contact.errorNote}
      style="--reveal-delay: 80ms"
    >
      <div class="contact__row">
        <div class="contact__field">
          <label for="contact-name">{contact.fields.name}</label>
          <input id="contact-name" name="name" type="text" autocomplete="name" required />
        </div>

        <div class="contact__field">
          <label for="contact-email">{contact.fields.email}</label>
          <input id="contact-email" name="email" type="email" autocomplete="email" required />
        </div>
      </div>

      <div class="contact__field">
        <label for="contact-message">{contact.fields.message}</label>
        <textarea
          id="contact-message"
          name="message"
          rows="3"
          placeholder={contact.messagePlaceholder}
          required></textarea>
      </div>

      <!-- Formspree honeypot: bots fill it, humans never see it; if set,
           Formspree silently drops the submission. -->
      <input
        class="contact__gotcha"
        type="text"
        name="_gotcha"
        tabindex="-1"
        autocomplete="off"
        aria-hidden="true"
      />

      <button class="contact__submit" type="submit" data-magnetic>{contact.submit}</button>

      <!-- DRAFT COPY — post-submit states, announced politely. -->
      <p class="contact__status" role="status" aria-live="polite" hidden></p>
    </form>
  </div>
</section>

<script>
  const form = document.querySelector<HTMLFormElement>('.contact__form');
  if (form && form.dataset.ajax === 'true') {
    const status = form.querySelector<HTMLElement>('.contact__status')!;
    const submit = form.querySelector<HTMLButtonElement>('.contact__submit')!;
    const successNote = form.dataset.success!;
    const errorNote = form.dataset.error!;
    const sending = form.dataset.sending!;
    const submitLabel = form.dataset.submit!;

    const setStatus = (msg: string, kind: 'error' | '') => {
      status.textContent = msg;
      status.hidden = false;
      status.classList.toggle('is-error', kind === 'error');
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      // Let native required/email validation gate the submit.
      if (!form.reportValidity()) return;

      submit.disabled = true;
      submit.textContent = sending;
      status.hidden = true;
      status.classList.remove('is-error');

      try {
        const res = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { Accept: 'application/json' },
        });
        if (res.ok) {
          // Replace the form with the success message (no reload jank). A state
          // class hides every field/control — the `hidden` attribute alone is
          // overridden by the fields' own display rules (equal specificity).
          form.reset();
          form.classList.add('is-sent');
          setStatus(successNote, '');
          status.setAttribute('tabindex', '-1');
          status.focus();
        } else {
          setStatus(errorNote, 'error');
          submit.disabled = false;
          submit.textContent = submitLabel;
        }
      } catch {
        setStatus(errorNote, 'error');
        submit.disabled = false;
        submit.textContent = submitLabel;
      }
    });
  }
</script>

<style>
  .contact {
    /* M2b alternation: contact sits on --surface between industries (S2) and
       the footer (S2); the form card's layered shadow carries the separation. */
    padding-block: var(--section-pad);
  }

  .contact__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 6vw, 5rem);
    align-items: start;
  }

  @media (max-width: 860px) {
    .contact__inner {
      grid-template-columns: 1fr;
    }
  }

  .contact__kicker {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--signal-text);
    margin-block-end: 0.75rem;
  }

  .contact__headline {
    font-size: clamp(1.9rem, 4vw, 2.75rem);
  }

  .contact__body {
    color: var(--graphite);
    font-size: 1.1rem;
    max-inline-size: 38ch;
  }

  .contact__form {
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    background: var(--surface);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
    padding: clamp(1.5rem, 3vw, 2rem);
  }

  /* Speed-line accent (§6: the one accent spikes at insight/CTA moments) —
     lifts the card out of default-contact-box territory. */
  .contact__form::before {
    content: '';
    position: absolute;
    inset-block-start: 0;
    inset-inline: 0;
    block-size: 3px;
    background: linear-gradient(90deg, var(--speed-from), var(--speed-to));
  }

  .contact__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.1rem;
  }

  @media (max-width: 560px) {
    .contact__row {
      grid-template-columns: 1fr;
    }
  }

  .contact__field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .contact__field label {
    font-weight: 600;
    font-size: 0.925rem;
  }

  .contact__field input,
  .contact__field textarea {
    font: inherit;
    color: var(--ink);
    background: var(--surface);
    border: 1px solid var(--hairline);
    border-radius: var(--radius-sm);
    padding: 0.65rem 0.85rem;
    transition: border-color var(--dur-fast) var(--ease-out);
  }

  .contact__field input:focus-visible,
  .contact__field textarea:focus-visible {
    outline: 2px solid var(--signal);
    outline-offset: 1px;
    border-color: var(--signal);
  }

  .contact__field textarea {
    resize: vertical;
    min-block-size: 4.5rem;
  }

  .contact__field ::placeholder {
    color: var(--graphite);
    opacity: 0.7;
  }

  .contact__submit {
    inline-size: 100%;
    font: inherit;
    font-weight: 600;
    font-size: 1rem;
    background: var(--signal);
    color: var(--on-ink);
    border: 0;
    border-radius: var(--radius-sm);
    padding: 0.8rem 1.8rem;
    cursor: pointer;
    transition:
      background var(--dur-fast) var(--ease-out),
      transform var(--dur-fast) var(--ease-out),
      box-shadow var(--dur-fast) var(--ease-out);
  }

  .contact__submit:hover {
    background: var(--signal-hover);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(36, 112, 229, 0.28);
  }

  /* Honeypot: removed from layout and the a11y tree, off-screen for bots. */
  .contact__gotcha {
    position: absolute;
    inline-size: 1px;
    block-size: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    border: 0;
  }

  /* Sent state: hide every field/control, leave only the status message.
     Higher specificity than the fields' own display rules, so it wins. */
  .contact__form.is-sent > :not(.contact__status) {
    display: none;
  }

  .contact__status {
    margin: 0;
    font-size: 1rem;
    font-weight: 500;
    color: var(--ink);
  }

  .contact__form.is-sent .contact__status {
    font-size: clamp(1.1rem, 2vw, 1.3rem);
    padding-block: clamp(2rem, 5vw, 3.5rem);
  }

  /* Error keeps the form visible for retry (the success path hides it), so it
     reads as an error from context — no new color token introduced. */
  .contact__status.is-error {
    font-weight: 400;
    font-size: 0.9rem;
    color: var(--ink);
  }

  .contact__status:focus-visible {
    outline: 2px solid var(--signal);
    outline-offset: 4px;
  }
</style>
