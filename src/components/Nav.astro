---
import { navItems, ctaContact } from '../content/ui';
import { withBase } from '../lib/url';

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) => {
  const target = withBase(href).replace(/\/$/, '') || '/';
  return target === pathname;
};

const homeHref = withBase('/');
const contactHref = `${withBase('/')}#contact`;
const logoSrc = withBase('/brand/claritix/claritix-wordmark.webp');
---

<header class="nav">
  <div class="container nav__inner">
    <a class="nav__brand" href={homeHref} aria-label="Claritix - home">
      <img class="nav__logo" src={logoSrc} alt="Claritix" width="146" height="35" />
    </a>

    <!-- Zero-JS responsive menu: checkbox toggle drives the mobile dropdown.
         On desktop the links are always shown and the toggle is hidden. -->
    <input class="nav__checkbox" type="checkbox" id="nav-toggle" aria-label="Toggle menu" />
    <label class="nav__toggle" for="nav-toggle">
      <span class="nav__toggle-bars" aria-hidden="true"></span>
    </label>

    <nav class="nav__links" aria-label="Primary">
      <ul>
        {
          navItems.map((item) => (
            <li>
              <a
                href={withBase(item.href)}
                aria-current={isActive(item.href) ? 'page' : undefined}
                class:list={['nav__link', { 'is-active': isActive(item.href) }]}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
      <div class="nav__actions">
        <button
          class="nav__theme"
          type="button"
          aria-label="Switch theme"
          aria-pressed="false"
          data-theme-toggle
          data-magnetic
        >
          <span class="nav__theme-icon" aria-hidden="true"></span>
        </button>
        <a class="nav__cta" href={contactHref} data-magnetic>{ctaContact}</a>
      </div>
    </nav>
  </div>
</header>

<script>
  // §6 motion table: nav is transparent over the hero, frosted once scrolled
  // past it. Pages without a hero (and no-JS visitors) keep the frosted nav.
  const nav = document.querySelector('.nav');
  const hero = document.querySelector('[data-hero]');
  if (nav && hero) {
    nav.classList.add('nav--overhero');
    const io = new IntersectionObserver(
      ([entry]) => nav.classList.toggle('nav--overhero', entry.isIntersecting),
      // Shrink the root's top edge by the nav height: frost exactly when the
      // hero's bottom passes under the nav.
      { rootMargin: '-69px 0px 0px 0px', threshold: 0 }
    );
    io.observe(hero);
  }
</script>

<style>
  .nav {
    position: sticky;
    inset-block-start: 0;
    z-index: var(--z-nav);
    background: color-mix(in srgb, var(--surface) 80%, transparent);
    -webkit-backdrop-filter: saturate(180%) blur(12px);
    backdrop-filter: saturate(180%) blur(12px);
    border-block-end: 1px solid var(--hairline);
    transition:
      background var(--dur-med) var(--ease-out),
      border-color var(--dur-med) var(--ease-out);
  }

  /* Transparent state while the hero is under the nav. */
  .nav:global(.nav--overhero) {
    background: transparent;
    -webkit-backdrop-filter: none;
    backdrop-filter: none;
    border-block-end-color: transparent;
  }

  /* If the mobile menu opens while over the hero, re-solidify the bar so the
     dropdown doesn't float off a transparent strip. */
  .nav:global(.nav--overhero):has(.nav__checkbox:checked) {
    background: var(--surface);
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    block-size: 68px;
  }

  .nav__brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--ink);
    font-weight: 600;
    letter-spacing: var(--tracking-display);
  }

  .nav__brand:hover {
    color: var(--ink);
  }

  .nav__logo {
    /* Claritix wordmark (4.15:1) sized by height; width auto keeps aspect. */
    block-size: 32px;
    inline-size: auto;
    display: block;
  }

  /* Toggle is desktop-hidden; the checkbox that drives it is hidden but focusable. */
  .nav__checkbox,
  .nav__toggle {
    display: none;
  }

  .nav__links {
    display: flex;
    align-items: center;
    gap: clamp(1rem, 2.5vw, 2rem);
  }

  .nav__links ul {
    display: flex;
    align-items: center;
    gap: clamp(1rem, 2.5vw, 2rem);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav__link {
    color: var(--graphite);
    font-size: 0.975rem;
    font-weight: 500;
    padding-block: 0.25rem;
    transition: color var(--dur-fast) var(--ease-out);
  }

  .nav__link:hover,
  .nav__link.is-active {
    color: var(--ink);
  }

  .nav__link.is-active {
    box-shadow: inset 0 -2px 0 0 var(--signal);
  }

  .nav__actions {
    display: flex;
    align-items: center;
    gap: 0.65rem;
  }

  .nav__theme {
    display: inline-grid;
    place-items: center;
    inline-size: 40px;
    block-size: 40px;
    border: 1px solid var(--hairline);
    border-radius: var(--radius-sm);
    background: color-mix(in srgb, var(--surface) 72%, transparent);
    color: var(--ink);
    cursor: pointer;
    transition:
      background var(--dur-med) var(--ease-out),
      border-color var(--dur-med) var(--ease-out),
      box-shadow var(--dur-med) var(--ease-out);
  }

  .nav__theme:hover {
    border-color: color-mix(in srgb, var(--signal) 45%, var(--hairline));
    box-shadow: 0 10px 24px color-mix(in srgb, var(--signal) 12%, transparent);
  }

  .nav__theme-icon {
    position: relative;
    inline-size: 17px;
    block-size: 17px;
    border-radius: 50%;
    background: var(--signal);
    box-shadow:
      0 0 0 4px color-mix(in srgb, var(--signal) 13%, transparent),
      0 0 18px color-mix(in srgb, var(--signal) 28%, transparent);
    transition:
      background var(--dur-med) var(--ease-out),
      box-shadow var(--dur-med) var(--ease-out),
      transform var(--dur-med) var(--ease-out);
  }

  :global(html[data-theme='dark']) .nav__theme-icon {
    background: transparent;
    box-shadow: inset -5px -4px 0 0 var(--speed-from);
    transform: rotate(-18deg);
  }

  .nav__cta {
    display: inline-flex;
    align-items: center;
    background: var(--signal);
    color: var(--on-ink);
    font-weight: 600;
    font-size: 0.95rem;
    padding: 0.55rem 1.1rem;
    border-radius: var(--radius-sm);
    transition:
      background var(--dur-fast) var(--ease-out),
      transform var(--dur-fast) var(--ease-out);
  }

  .nav__cta:hover {
    background: var(--signal-hover);
    color: var(--on-ink);
    transform: translateY(-1px);
  }

  /* ---- Mobile: collapse links into a checkbox-toggled dropdown ---- */
  @media (max-width: 720px) {
    /* Visually hidden but kept in the tab order so the menu is keyboard-operable. */
    .nav__checkbox {
      display: block;
      position: absolute;
      inline-size: 1px;
      block-size: 1px;
      margin: -1px;
      padding: 0;
      border: 0;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
    }

    .nav__toggle {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      inline-size: 44px;
      block-size: 44px;
      border-radius: var(--radius-sm);
      cursor: pointer;
    }

    /* Visible focus ring on the label when the (hidden) checkbox is focused. */
    .nav__checkbox:focus-visible + .nav__toggle {
      outline: 2px solid var(--signal);
      outline-offset: 2px;
    }

    .nav__toggle-bars,
    .nav__toggle-bars::before,
    .nav__toggle-bars::after {
      content: '';
      display: block;
      inline-size: 22px;
      block-size: 2px;
      background: var(--ink);
      border-radius: 2px;
      transition: transform var(--dur-fast) var(--ease-out);
    }

    .nav__toggle-bars {
      position: relative;
    }

    .nav__toggle-bars::before {
      position: absolute;
      inset-block-start: -7px;
    }

    .nav__toggle-bars::after {
      position: absolute;
      inset-block-start: 7px;
    }

    /* Hamburger → X when open. */
    .nav__checkbox:checked + .nav__toggle .nav__toggle-bars {
      background: transparent;
    }
    .nav__checkbox:checked + .nav__toggle .nav__toggle-bars::before {
      transform: translateY(7px) rotate(45deg);
    }
    .nav__checkbox:checked + .nav__toggle .nav__toggle-bars::after {
      transform: translateY(-7px) rotate(-45deg);
    }

    .nav__links {
      display: none;
      position: absolute;
      inset-inline: 0;
      inset-block-start: 68px;
      flex-direction: column;
      align-items: stretch;
      gap: 0.5rem;
      padding: 1rem var(--gutter) 1.5rem;
      background: var(--surface);
      border-block-end: 1px solid var(--hairline);
      box-shadow: var(--shadow-card);
    }

    .nav__checkbox:checked ~ .nav__links {
      display: flex;
    }

    .nav__links ul {
      flex-direction: column;
      align-items: stretch;
      gap: 0.25rem;
    }

    .nav__link {
      display: block;
      padding-block: 0.7rem;
    }

    .nav__cta {
      justify-content: center;
      flex: 1;
    }

    .nav__actions {
      margin-block-start: 0.5rem;
      align-items: stretch;
    }

    .nav__theme {
      inline-size: 48px;
      block-size: 48px;
    }
  }
</style>
