---
// One industry slot in the strip (SPEC §5.1 #5, §3). Framed as a problem
// statement, not a bare label. No logos, no fake client grids (§5.3).

interface Props {
  label: string;
  blurb: string;
  revealDelay?: number;
}

const { label, blurb, revealDelay = 0 } = Astro.props;
---

<div class="industry" data-reveal data-spotlight style={`--reveal-delay: ${revealDelay}ms`}>
  <h3 class="industry__label">{label}</h3>
  <p class="industry__blurb">{blurb}</p>
</div>

<style>
  .industry {
    position: relative;
    min-block-size: 100%;
    padding: clamp(1.2rem, 3vw, 1.6rem);
    border-radius: var(--radius-card);
    background:
      radial-gradient(
        260px circle at 82% 12%,
        color-mix(in srgb, var(--signal) 9%, transparent),
        transparent 64%
      ),
      var(--surface);
    box-shadow: var(--shadow-card);
    overflow: hidden;
    transition:
      transform var(--dur-hover) var(--ease-luxe),
      box-shadow var(--dur-hover) var(--ease-luxe);
  }

  .industry::before {
    content: '';
    display: block;
    inline-size: 100%;
    block-size: 2px;
    margin-block-end: 1.1rem;
    background: linear-gradient(
      90deg,
      color-mix(in srgb, var(--signal) 70%, transparent),
      color-mix(in srgb, var(--glass-lo) 32%, transparent),
      transparent
    );
  }

  .industry::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    background: radial-gradient(
      300px circle at var(--spot-x, 50%) var(--spot-y, 50%),
      color-mix(in srgb, var(--spotlight) 18%, transparent),
      transparent 70%
    );
    filter: hue-rotate(30deg) saturate(1.22);
    opacity: var(--spot-o, 0);
    transition: opacity 0.6s var(--ease-luxe);
  }

  .industry__label {
    font-size: clamp(1.25rem, 2vw, 1.55rem);
    margin-block-end: 0.75rem;
  }

  .industry__blurb {
    color: var(--graphite);
    margin: 0;
  }

  @media (prefers-reduced-motion: no-preference) {
    .industry:hover {
      transform: translateY(-5px);
      box-shadow: var(--shadow-card-hover);
    }
  }
</style>
