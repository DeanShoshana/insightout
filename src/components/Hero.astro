---
import { home } from '../content/home';
import { withBase } from '../lib/url';

const { triad, subline, cta } = home.hero;
const logoSrc = withBase('/brand/claritix/claritix-wordmark.webp');
---

<!-- Hero (SPEC §5.1 #1). Load cascade per §6: logo settles first, triad words
  stagger in (~120ms offsets), sub-line and CTA follow. Pure CSS keyframes -
     content is never JS-gated, and the global reduced-motion rule collapses the
     cascade to an instant final state. -->
<section class="hero" data-hero>
  <div class="hero__field" aria-hidden="true">
    <span class="hero__aura hero__aura--one"></span>
    <span class="hero__aura hero__aura--two"></span>
    <span class="hero__aura hero__aura--three"></span>
    <span class="hero__glass"></span>
  </div>

  <div class="container hero__inner" data-hero-inner>
    <img class="hero__logo" src={logoSrc} alt="Claritix" width="900" height="217" />

    <h1 class="hero__triad">
      {
        triad.map((word, i) => (
          <>
            {i > 0 && (
              <span class="hero__dot" aria-hidden="true">
                •
              </span>
            )}
            <span class="hero__word" style={`--cascade: ${i}`}>
              {word}
            </span>
          </>
        ))
      }
    </h1>

    <p class="hero__sub">{subline}</p>
    <a class="hero__cta" href="#contact" data-magnetic>{cta}</a>
  </div>
</section>

<script>
  // Scroll-linked hero exit (SPEC §6): content eases up/out with slight
  // scale-down as the user scrolls toward problem framing. Scroll position
  // drives the animation - no pinning, no scroll-jacking. GSAP is allowed
  // here and for the Engine scene only (SPEC §7).
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    gsap.registerPlugin(ScrollTrigger);
    gsap.to('[data-hero-inner]', {
      yPercent: -10,
      scale: 0.96,
      opacity: 0.3,
      ease: 'none',
      scrollTrigger: {
        trigger: '[data-hero]',
        start: 'top top',
        end: 'bottom 25%',
        scrub: true,
      },
    });
  }
</script>

<style>
  .hero {
    /* Tall, airy stage; nav sits transparent on top of it. */
    position: relative;
    overflow: hidden;
    min-block-size: calc(88svh - 68px);
    display: flex;
    align-items: center;
    padding-block: clamp(4rem, 8vw, 7rem);
    isolation: isolate;
  }

  .hero__field {
    position: absolute;
    inset: 68px 0 0;
    z-index: -1;
    overflow: hidden;
    pointer-events: none;
  }

  .hero__field::before {
    content: '';
    position: absolute;
    inset: 9% max(6vw, calc((100vw - var(--content-max)) / 2 - 6rem)) 8%;
    border-radius: 42px;
    background: radial-gradient(
      closest-side at 50% 42%,
      color-mix(in srgb, var(--surface) 48%, transparent),
      color-mix(in srgb, var(--glass-hi) 24%, transparent) 42%,
      transparent 78%
    );
    -webkit-backdrop-filter: blur(18px) saturate(135%);
    backdrop-filter: blur(18px) saturate(135%);
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, white 48%, transparent),
      0 34px 110px color-mix(in srgb, var(--ink) 7%, transparent);
    opacity: 0.72;
  }

  .hero__field::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, transparent 0 48%, color-mix(in srgb, white 20%, transparent) 50%, transparent 54%),
      linear-gradient(180deg, color-mix(in srgb, var(--surface) 68%, transparent), transparent 34%, color-mix(in srgb, var(--surface) 76%, transparent));
    opacity: 0.58;
  }

  .hero__aura,
  .hero__glass {
    position: absolute;
    border-radius: 999px;
    display: block;
    will-change: transform;
  }

  .hero__aura {
    filter: blur(42px);
    opacity: 0.7;
    mix-blend-mode: multiply;
  }

  .hero__aura--one {
    inline-size: clamp(260px, 34vw, 560px);
    block-size: clamp(220px, 27vw, 420px);
    inset-inline-start: 13%;
    inset-block-start: 18%;
    background: color-mix(in srgb, var(--glass-lo) 48%, transparent);
    transform: translate3d(-5%, 0, 0) rotate(-10deg);
  }

  .hero__aura--two {
    inline-size: clamp(230px, 30vw, 500px);
    block-size: clamp(190px, 24vw, 390px);
    inset-inline-end: 12%;
    inset-block-start: 16%;
    background: color-mix(in srgb, var(--signal) 28%, transparent);
    transform: translate3d(7%, 0, 0) rotate(12deg);
  }

  .hero__aura--three {
    inline-size: clamp(240px, 30vw, 520px);
    block-size: clamp(160px, 20vw, 330px);
    inset-inline-start: 33%;
    inset-block-end: 14%;
    background: color-mix(in srgb, var(--speed-from) 30%, var(--surface));
    opacity: 0.42;
    transform: translate3d(0, 10%, 0) rotate(-4deg);
  }

  .hero__glass {
    inline-size: min(58vw, 760px);
    block-size: min(34vw, 430px);
    inset-inline-start: 50%;
    inset-block-start: 47%;
    transform: translate3d(-50%, -50%, 0);
    background:
      radial-gradient(circle at 28% 34%, color-mix(in srgb, white 38%, transparent), transparent 30%),
      radial-gradient(circle at 76% 22%, color-mix(in srgb, var(--glass-hi) 38%, transparent), transparent 34%),
      linear-gradient(135deg, color-mix(in srgb, white 14%, transparent), color-mix(in srgb, var(--surface) 3%, transparent));
    border: 1px solid color-mix(in srgb, var(--signal) 12%, transparent);
    -webkit-backdrop-filter: blur(24px) saturate(145%);
    backdrop-filter: blur(24px) saturate(145%);
    opacity: 0.56;
  }

  .hero__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    transform-origin: 50% 0;
    will-change: transform, opacity;
  }

  .hero__logo {
    /* Wide wordmark (4.15:1) - sized by width; min stays within 360px gutters. */
    inline-size: clamp(240px, 36vw, 400px);
    block-size: auto;
    margin-block-end: clamp(2rem, 5vw, 3.5rem);
    animation: hero-rise 1.2s var(--ease-luxe) both;
    transform: translateZ(0);
    image-rendering: auto;
  }

  .hero__triad {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: baseline;
    gap: 0.15em 0.35em;
    font-size: var(--fs-hero);
    font-weight: var(--fw-hero);
    letter-spacing: var(--tracking-hero);
    margin-block-end: 1.25rem;
  }

  .hero__word {
    display: inline-block;
    /* Cascade: word i lands at 350ms + i × 120ms (logo settles first). */
    animation: hero-rise 1.05s var(--ease-luxe) both;
    animation-delay: calc(350ms + var(--cascade, 0) * 120ms);
  }

  .hero__dot {
    color: var(--signal);
    font-size: 0.5em;
    animation: hero-fade 0.9s var(--ease-luxe) both;
    animation-delay: calc(410ms + var(--cascade, 0) * 120ms);
  }

  .hero__sub {
    font-size: clamp(1.1rem, 2.2vw, 1.35rem);
    color: var(--graphite);
    max-inline-size: 38ch;
    margin-block-end: 2.25rem;
    animation: hero-rise 1.05s var(--ease-luxe) both;
    animation-delay: 800ms;
  }

  .hero__cta {
    display: inline-flex;
    align-items: center;
    background: var(--signal);
    color: var(--on-ink);
    font-weight: 600;
    font-size: 1.05rem;
    padding: 0.85rem 1.9rem;
    border-radius: var(--radius-sm);
    animation: hero-rise 1.05s var(--ease-luxe) both;
    animation-delay: 920ms;
    transition:
      background var(--dur-fast) var(--ease-out),
      transform var(--dur-fast) var(--ease-out),
      box-shadow var(--dur-fast) var(--ease-out);
  }

  .hero__cta:hover {
    background: var(--signal-hover);
    color: var(--on-ink);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(36, 112, 229, 0.28);
  }

  @media (max-width: 720px) {
    .hero {
      min-block-size: calc(82svh - 68px);
      padding-block: clamp(3.25rem, 12vw, 5rem);
    }

    .hero__logo {
      inline-size: clamp(210px, 58vw, 270px);
      margin-block-end: clamp(1.4rem, 8vw, 2.5rem);
    }

    .hero__field {
      inset-block-start: 56px;
      opacity: 0.68;
    }

    .hero__field::before {
      inset: 12% -12% 12%;
      border-radius: 32px;
    }

    .hero__glass {
      inline-size: 92vw;
      block-size: 54vw;
      opacity: 0.46;
    }

    .hero__aura {
      filter: blur(34px);
    }

    .hero__aura--one {
      inset-inline-start: -20%;
      inset-block-start: 18%;
    }

    .hero__aura--two {
      inset-inline-end: -28%;
      inset-block-start: 20%;
    }

    .hero__aura--three {
      inset-inline-start: 20%;
      inset-block-end: 18%;
    }

    .hero__triad {
      gap: 0.12em 0.28em;
      line-height: 1.08;
      margin-block-end: 0.95rem;
    }

    .hero__sub {
      font-size: 1rem;
      line-height: 1.5;
      max-inline-size: 30ch;
      margin-block-end: 1.6rem;
    }

    .hero__cta {
      font-size: 0.98rem;
      padding: 0.78rem 1.45rem;
    }
  }

  @keyframes hero-rise {
    from {
      opacity: 0;
      transform: translateY(26px) scale(0.99);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .hero__aura--one {
      animation: hero-aura-one 16s var(--ease-luxe) infinite;
    }

    .hero__aura--two {
      animation: hero-aura-two 18s var(--ease-luxe) infinite;
    }

    .hero__aura--three {
      animation: hero-aura-three 20s var(--ease-luxe) infinite;
    }

    .hero__glass {
      animation: hero-glass-drift 15s var(--ease-luxe) infinite;
    }
  }

  @keyframes hero-aura-one {
    0%,
    100% {
      transform: translate3d(-5%, 0, 0) rotate(-10deg) scale(1);
    }

    50% {
      transform: translate3d(7%, -6%, 0) rotate(-4deg) scale(1.08);
    }
  }

  @keyframes hero-aura-two {
    0%,
    100% {
      transform: translate3d(7%, 0, 0) rotate(12deg) scale(1);
    }

    50% {
      transform: translate3d(-8%, 7%, 0) rotate(5deg) scale(1.06);
    }
  }

  @keyframes hero-aura-three {
    0%,
    100% {
      transform: translate3d(0, 10%, 0) rotate(-4deg) scale(1);
    }

    50% {
      transform: translate3d(-5%, -5%, 0) rotate(5deg) scale(1.12);
    }
  }

  @keyframes hero-glass-drift {
    0%,
    100% {
      transform: translate3d(-50%, -50%, 0) scale(1);
    }

    50% {
      transform: translate3d(-49%, -52%, 0) scale(1.03);
    }
  }

  @keyframes hero-fade {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
</style>
