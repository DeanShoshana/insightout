---
import { home } from '../content/home';
import { withBase } from '../lib/url';

const { triad, subline, cta } = home.hero;
const logoSrc = withBase('/brand/claritix/claritix-wordmark.webp');
---

<!-- Hero (SPEC §5.1 #1). Load cascade per §6: logo settles first, triad words
  stagger in (~120ms offsets), sub-line and CTA follow. Pure CSS keyframes -
     content is never JS-gated, and the global reduced-motion rule collapses the
     cascade to an instant final state. -->
<section class="hero" data-hero>
  <div class="hero__field" aria-hidden="true">
    <span class="hero__aura hero__aura--one"></span>
    <span class="hero__aura hero__aura--two"></span>
    <span class="hero__aura hero__aura--three"></span>
    <span class="hero__aura hero__aura--four"></span>
    <span class="hero__glass"></span>
  </div>

  <div class="container hero__inner" data-hero-inner>
    <img class="hero__logo" src={logoSrc} alt="Claritix" width="900" height="217" />

    <h1 class="hero__triad">
      {
        triad.map((word, i) => (
          <>
            {i > 0 && (
              <span class="hero__dot" aria-hidden="true">
                •
              </span>
            )}
            <span class="hero__word" style={`--cascade: ${i}`}>
              {word}
            </span>
          </>
        ))
      }
    </h1>

    <p class="hero__sub">{subline}</p>
    <a class="hero__cta" href="#contact" data-magnetic>{cta}</a>
  </div>
</section>

<script>
  // Scroll-linked hero exit (SPEC §6): content eases up/out with slight
  // scale-down as the user scrolls toward problem framing. Scroll position
  // drives the animation - no pinning, no scroll-jacking. GSAP is allowed
  // here and for the Engine scene only (SPEC §7).
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    gsap.registerPlugin(ScrollTrigger);
    gsap.to('[data-hero-inner]', {
      yPercent: -10,
      scale: 0.96,
      opacity: 0.3,
      ease: 'none',
      scrollTrigger: {
        trigger: '[data-hero]',
        start: 'top top',
        end: 'bottom 25%',
        scrub: true,
      },
    });
  }
</script>

<style>
  .hero {
    /* Tall, airy stage; nav sits transparent on top of it. */
    position: relative;
    overflow: visible;
    min-block-size: calc(88svh - 68px);
    display: flex;
    align-items: center;
    padding-block: clamp(4rem, 8vw, 7rem);
    isolation: isolate;
  }

  .hero__field {
    position: absolute;
    inset: -68px 0 -8%;
    z-index: -1;
    overflow: hidden;
    pointer-events: none;
  }

  .hero__field::before {
    content: '';
    position: absolute;
    inset: 0 -8% -10%;
    z-index: 2;
    background:
      radial-gradient(circle at 50% 24%, color-mix(in srgb, white 18%, transparent), transparent 28%),
      linear-gradient(180deg, color-mix(in srgb, white 10%, transparent), transparent 72%);
    -webkit-backdrop-filter: blur(36px) saturate(155%);
    backdrop-filter: blur(36px) saturate(155%);
    opacity: 0.92;
  }

  .hero__field::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 3;
    background:
      linear-gradient(90deg, transparent 0 42%, color-mix(in srgb, white 16%, transparent) 49%, transparent 56%),
      linear-gradient(180deg, color-mix(in srgb, var(--surface) 36%, transparent), transparent 38%, color-mix(in srgb, var(--surface) 74%, transparent));
    opacity: 0.66;
  }

  .hero__aura,
  .hero__glass {
    position: absolute;
    border-radius: 999px;
    display: block;
    will-change: transform;
  }

  .hero__aura {
    z-index: 0;
    filter: blur(52px);
    opacity: 0.7;
  }

  .hero__aura--one {
    inline-size: clamp(220px, 25vw, 420px);
    block-size: clamp(190px, 22vw, 350px);
    inset-inline-start: 4%;
    inset-block-start: 9%;
    background: color-mix(in srgb, var(--glass-lo) 62%, transparent);
    transform: translate3d(-7%, 0, 0) rotate(-11deg);
  }

  .hero__aura--two {
    inline-size: clamp(210px, 24vw, 390px);
    block-size: clamp(190px, 22vw, 350px);
    inset-inline-end: 6%;
    inset-block-start: 3%;
    background: color-mix(in srgb, var(--signal) 50%, transparent);
    transform: translate3d(8%, -2%, 0) rotate(13deg);
  }

  .hero__aura--three {
    inline-size: clamp(230px, 27vw, 450px);
    block-size: clamp(150px, 18vw, 300px);
    inset-inline-start: 32%;
    inset-block-end: 18%;
    background: color-mix(in srgb, var(--speed-from) 56%, transparent);
    opacity: 0.5;
    transform: translate3d(0, 12%, 0) rotate(-4deg);
  }

  .hero__aura--four {
    inline-size: clamp(170px, 20vw, 330px);
    block-size: clamp(150px, 18vw, 290px);
    inset-inline-end: 30%;
    inset-block-end: 28%;
    background: color-mix(in srgb, var(--ink) 18%, transparent);
    opacity: 0.22;
    transform: translate3d(4%, 6%, 0) rotate(8deg);
  }

  .hero__glass {
    z-index: 1;
    inline-size: 118vw;
    block-size: min(56vw, 700px);
    inset-inline-start: 50%;
    inset-block-start: 42%;
    transform: translate3d(-50%, -50%, 0);
    background:
      radial-gradient(circle at 24% 34%, color-mix(in srgb, white 22%, transparent), transparent 31%),
      radial-gradient(circle at 76% 22%, color-mix(in srgb, var(--glass-hi) 28%, transparent), transparent 34%),
      linear-gradient(135deg, color-mix(in srgb, white 14%, transparent), color-mix(in srgb, var(--surface) 3%, transparent));
    -webkit-backdrop-filter: blur(34px) saturate(155%);
    backdrop-filter: blur(34px) saturate(155%);
    opacity: 0.58;
  }

  .hero__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    transform-origin: 50% 0;
    will-change: transform, opacity;
  }

  .hero__logo {
    /* Wide wordmark (4.15:1) - sized by width; min stays within 360px gutters. */
    inline-size: clamp(240px, 36vw, 400px);
    block-size: auto;
    margin-block-end: clamp(2rem, 5vw, 3.5rem);
    animation: hero-rise 1.2s var(--ease-luxe) both;
    transform: translateZ(0);
    image-rendering: auto;
  }

  .hero__triad {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: baseline;
    gap: 0.15em 0.35em;
    font-size: var(--fs-hero);
    font-weight: var(--fw-hero);
    letter-spacing: var(--tracking-hero);
    margin-block-end: 1.25rem;
  }

  .hero__word {
    display: inline-block;
    /* Cascade: word i lands at 350ms + i × 120ms (logo settles first). */
    animation: hero-rise 1.05s var(--ease-luxe) both;
    animation-delay: calc(350ms + var(--cascade, 0) * 120ms);
  }

  .hero__dot {
    color: var(--signal);
    font-size: 0.5em;
    animation: hero-fade 0.9s var(--ease-luxe) both;
    animation-delay: calc(410ms + var(--cascade, 0) * 120ms);
  }

  .hero__sub {
    font-size: clamp(1.1rem, 2.2vw, 1.35rem);
    color: var(--graphite);
    max-inline-size: 38ch;
    margin-block-end: 2.25rem;
    animation: hero-rise 1.05s var(--ease-luxe) both;
    animation-delay: 800ms;
  }

  .hero__cta {
    display: inline-flex;
    align-items: center;
    background: var(--signal);
    color: var(--on-ink);
    font-weight: 600;
    font-size: 1.05rem;
    padding: 0.85rem 1.9rem;
    border-radius: var(--radius-sm);
    animation: hero-rise 1.05s var(--ease-luxe) both;
    animation-delay: 920ms;
    transition:
      background var(--dur-fast) var(--ease-out),
      transform var(--dur-fast) var(--ease-out),
      box-shadow var(--dur-fast) var(--ease-out);
  }

  .hero__cta:hover {
    background: var(--signal-hover);
    color: var(--on-ink);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(36, 112, 229, 0.28);
  }

  @media (max-width: 720px) {
    .hero {
      min-block-size: calc(82svh - 68px);
      padding-block: clamp(3.25rem, 12vw, 5rem);
    }

    .hero__logo {
      inline-size: clamp(210px, 58vw, 270px);
      margin-block-end: clamp(1.4rem, 8vw, 2.5rem);
    }

    .hero__field {
      inset-block-start: -56px;
      opacity: 0.68;
    }

    .hero__field::before {
      inset: 0 -26% -12%;
    }

    .hero__glass {
      inline-size: 135vw;
      block-size: 86vw;
      opacity: 0.44;
    }

    .hero__aura {
      filter: blur(38px);
    }

    .hero__aura--one {
      inset-inline-start: -34%;
      inset-block-start: 18%;
    }

    .hero__aura--two {
      inset-inline-end: -38%;
      inset-block-start: 13%;
    }

    .hero__aura--three {
      inset-inline-start: 10%;
      inset-block-end: 13%;
    }

    .hero__aura--four {
      inset-inline-end: 4%;
      inset-block-end: 28%;
    }

    .hero__triad {
      gap: 0.12em 0.28em;
      line-height: 1.08;
      margin-block-end: 0.95rem;
    }

    .hero__sub {
      font-size: 1rem;
      line-height: 1.5;
      max-inline-size: 30ch;
      margin-block-end: 1.6rem;
    }

    .hero__cta {
      font-size: 0.98rem;
      padding: 0.78rem 1.45rem;
    }
  }

  @keyframes hero-rise {
    from {
      opacity: 0;
      transform: translateY(26px) scale(0.99);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .hero__aura--one {
      animation: hero-aura-one 8.5s ease-in-out infinite;
    }

    .hero__aura--two {
      animation: hero-aura-two 9.5s ease-in-out infinite;
    }

    .hero__aura--three {
      animation: hero-aura-three 10.5s ease-in-out infinite;
    }

    .hero__aura--four {
      animation: hero-aura-four 11.5s ease-in-out infinite;
    }

    .hero__glass {
      animation: hero-glass-drift 8.5s ease-in-out infinite;
    }
  }

  @keyframes hero-aura-one {
    0%,
    100% {
      transform: translate3d(-7%, 0, 0) rotate(-11deg) scale(1);
    }

    45% {
      transform: translate3d(15%, -12%, 0) rotate(-3deg) scale(1.16);
    }

    72% {
      transform: translate3d(4%, 8%, 0) rotate(-7deg) scale(1.08);
    }
  }

  @keyframes hero-aura-two {
    0%,
    100% {
      transform: translate3d(8%, -2%, 0) rotate(13deg) scale(1);
    }

    42% {
      transform: translate3d(-16%, 10%, 0) rotate(4deg) scale(1.14);
    }

    70% {
      transform: translate3d(-4%, -9%, 0) rotate(9deg) scale(1.06);
    }
  }

  @keyframes hero-aura-three {
    0%,
    100% {
      transform: translate3d(0, 10%, 0) rotate(-4deg) scale(1);
    }

    46% {
      transform: translate3d(-12%, -10%, 0) rotate(6deg) scale(1.18);
    }

    76% {
      transform: translate3d(7%, -2%, 0) rotate(1deg) scale(1.08);
    }
  }

  @keyframes hero-aura-four {
    0%,
    100% {
      transform: translate3d(4%, 6%, 0) rotate(8deg) scale(1);
    }

    48% {
      transform: translate3d(-12%, -9%, 0) rotate(2deg) scale(1.2);
    }

    74% {
      transform: translate3d(7%, -4%, 0) rotate(11deg) scale(1.08);
    }
  }

  @keyframes hero-glass-drift {
    0%,
    100% {
      transform: translate3d(-50%, -50%, 0) scale(1);
    }

    50% {
      transform: translate3d(-48.5%, -52.5%, 0) scale(1.04);
    }
  }

  @keyframes hero-fade {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
</style>
