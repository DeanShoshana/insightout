---
import Base from '../layouts/Base.astro';
import { siteConfig } from '../../site.config';
import { withBase } from '../lib/url';
import { work } from '../content/work';

const enabled = siteConfig.flags.showWork;
const { hero, cases, closing } = work;
---

<Base
  title="Case Studies"
  description="Anonymized Claritix case studies showing how product, behavioral, market, and executive signal turn into usable business direction."
  noindex={!enabled}
>
  {
    enabled ? (
      <>
        <!-- DRAFT COPY - Case Studies launch page. -->
        <section class="work-hero" aria-labelledby="work-hero-headline">
          <div class="container work-hero__inner">
            <div class="work-hero__copy" data-reveal>
              <p class="section-head__kicker">{hero.kicker}</p>
              <h1 class="work-hero__headline" id="work-hero-headline">{hero.headline}</h1>
              <p class="work-hero__lede">{hero.lede}</p>

              <div class="work-hero__actions">
                <a class="work-hero__cta work-hero__cta--primary" href="#case-frames" data-magnetic>
                  Explore the frames
                </a>
                <a class="work-hero__cta work-hero__cta--secondary" href={withBase('/services')}>
                  See the connected services
                </a>
              </div>

              <p class="work-hero__note">{hero.note}</p>
            </div>

            <aside
              class="work-hero__studio"
              data-reveal
              data-spotlight
              style="--reveal-delay: 120ms"
              aria-label="Illustrative decision build"
            >
              <div class="studio__frame">
                <div class="studio__head">
                  <p>{hero.motionLabel}</p>
                  <strong>{hero.motionValue}</strong>
                </div>

                <div class="studio__stage" aria-hidden="true">
                  <div class="studio__inputs">
                    {
                      hero.rails.map((rail, i) => (
                        <article class="studio__input" style={`--studio-index: ${i}`}>
                          <span class="studio__input-dot"></span>
                          <div class="studio__input-copy">
                            <p>{rail}</p>
                            <span></span>
                          </div>
                          <div class="studio__input-flow">
                            <i></i>
                          </div>
                        </article>
                      ))
                    }
                  </div>

                  <article class="studio__decision">
                    <span class="studio__decision-kicker">Decision frame</span>
                    <strong>{hero.decisionTitle}</strong>
                    <p>{hero.decisionBody}</p>
                    <div class="studio__decision-bars">
                      <span></span>
                      <span></span>
                      <span></span>
                    </div>
                  </article>
                </div>

                <div class="studio__metrics">
                  {hero.metrics.map((metric) => (
                    <article class="studio__metric">
                      <span>{metric.label}</span>
                      <strong>{metric.value}</strong>
                    </article>
                  ))}
                </div>
              </div>
            </aside>
          </div>
        </section>

        <nav class="case-nav" aria-label="Case study navigation">
          <div class="container case-nav__inner">
            <ul>
              {
                cases.map((item) => (
                  <li>
                    <a href={`#${item.id}`} data-case-link={item.id}>
                      {item.navLabel}
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>
        </nav>

        <section class="case-track" id="case-frames" aria-labelledby="case-track-headline">
          <div class="container case-track__header">
            <div class="section-head" data-reveal>
              <p class="section-head__kicker">Build as scroll</p>
              <h2 class="section-head__headline" id="case-track-headline">
                Six ways the work resolves into a clearer move.
              </h2>
              <p class="section-head__lede">
                Every engagement starts in ambiguity somewhere different. The common pattern is that
                the signal stops competing for attention and starts aligning around one decision.
              </p>
            </div>
          </div>

          <div class="container case-track__grid">
            <div class="case-preview-wrap">
              <aside class="case-preview" data-reveal data-spotlight aria-live="polite">
                <div class="case-preview__visual" aria-hidden="true">
                  <span class="case-preview__ring case-preview__ring--outer"></span>
                  <span class="case-preview__ring case-preview__ring--middle"></span>
                  <span class="case-preview__ring case-preview__ring--inner"></span>
                  <span class="case-preview__node case-preview__node--top"></span>
                  <span class="case-preview__node case-preview__node--right"></span>
                  <span class="case-preview__node case-preview__node--bottom"></span>
                  <span class="case-preview__node case-preview__node--left"></span>
                  <span class="case-preview__sweep"></span>
                </div>

                <div class="case-preview__panels">
                  {
                    cases.map((item, i) => (
                      <article
                        class:list={['case-panel', { 'is-active': i === 0 }]}
                        data-case-panel={item.id}
                      >
                        <p class="case-panel__kicker">{item.kicker}</p>
                        <strong class="case-panel__value">{item.statValue}</strong>
                        <p class="case-panel__copy">{item.preview}</p>
                        <ul class="case-panel__signals">
                          {item.signals.map((signal) => (
                            <li>{signal}</li>
                          ))}
                        </ul>
                      </article>
                    ))
                  }
                </div>

                <div class="case-preview__progress" aria-hidden="true">
                  {
                    cases.map((item, i) => (
                      <span
                        class:list={['case-preview__step', { 'is-active': i === 0 }]}
                        data-case-step={item.id}
                      ></span>
                    ))
                  }
                </div>
              </aside>
            </div>

            <div class="case-list">
              <div class="case-list__rail" aria-hidden="true"></div>
              {
                cases.map((item, i) => (
                  <article
                    id={item.id}
                    class:list={['case-card', { 'is-active': i === 0 }]}
                    data-case={item.id}
                    data-reveal
                    data-spotlight
                    style={`--reveal-delay: ${i * 70}ms`}
                    aria-labelledby={`${item.id}-headline`}
                  >
                    <div class="case-card__header">
                      <div>
                        <p class="case-card__index">0{i + 1}</p>
                        <p class="case-card__kicker">{item.kicker}</p>
                      </div>
                      <div class="case-card__stat" aria-label={`${item.statLabel}: ${item.statValue}`}>
                        <span>{item.statLabel}</span>
                        <strong>{item.statValue}</strong>
                      </div>
                    </div>

                    <h3 class="case-card__headline" id={`${item.id}-headline`}>
                      {item.title}
                    </h3>
                    <p class="case-card__summary">{item.summary}</p>
                    <p class="case-card__outcome">{item.outcome}</p>

                    <ul class="case-card__signals">
                      {item.signals.map((signal) => (
                        <li>{signal}</li>
                      ))}
                    </ul>

                    <div class="case-card__services" aria-label="Connected services">
                      {item.services.map((service) => (
                        <a href={withBase(service.anchor)}>{service.label}</a>
                      ))}
                    </div>
                  </article>
                ))
              }
            </div>
          </div>
        </section>

        <section class="work-close" aria-labelledby="work-close-headline">
          <div class="container">
            <div class="work-close__surface" data-reveal data-spotlight>
              <div class="work-close__copy">
                <p class="section-head__kicker">{closing.kicker}</p>
                <h2 class="work-close__headline" id="work-close-headline">
                  {closing.headline}
                </h2>
                <p class="work-close__body">{closing.body}</p>
              </div>

              <div class="work-close__actions">
                <a class="work-close__link work-close__link--primary" href={withBase(closing.primary.href)} data-magnetic>
                  {closing.primary.label}
                </a>
                <a class="work-close__link work-close__link--secondary" href={withBase(closing.secondary.href)}>
                  {closing.secondary.label}
                </a>
              </div>
            </div>
          </div>
        </section>
      </>
    ) : (
      <section class="reserved">
        <div class="container">
          <>
            <!-- DRAFT COPY - reserved route placeholder (M1). -->
            <h1>Work</h1>
            <p class="reserved__note">This section is reserved and not yet published.</p>
          </>
        </div>
      </section>
    )
  }
</Base>

<script>
  const cards = Array.from(document.querySelectorAll<HTMLElement>('[data-case]'));
  const panels = new Map(
    Array.from(document.querySelectorAll<HTMLElement>('[data-case-panel]')).map((el) => [
      el.dataset.casePanel!,
      el,
    ])
  );
  const links = new Map(
    Array.from(document.querySelectorAll<HTMLAnchorElement>('[data-case-link]')).map((el) => [
      el.dataset.caseLink!,
      el,
    ])
  );
  const steps = new Map(
    Array.from(document.querySelectorAll<HTMLElement>('[data-case-step]')).map((el) => [
      el.dataset.caseStep!,
      el,
    ])
  );

  const setActive = (id: string) => {
    cards.forEach((card) => card.classList.toggle('is-active', card.dataset.case === id));
    panels.forEach((panel, key) => panel.classList.toggle('is-active', key === id));
    links.forEach((link, key) => {
      link.classList.toggle('is-active', key === id);
      if (key === id) link.setAttribute('aria-current', 'true');
      else link.removeAttribute('aria-current');
    });
    steps.forEach((step, key) => step.classList.toggle('is-active', key === id));
  };

  if (cards.length) {
    setActive(cards[0].dataset.case || '');

    const io = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((entry) => entry.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
        if (visible instanceof IntersectionObserverEntry) {
          const id = (visible.target as HTMLElement).dataset.case;
          if (id) setActive(id);
        }
      },
      {
        rootMargin: '-22% 0px -46% 0px',
        threshold: [0.2, 0.35, 0.5, 0.7],
      }
    );

    cards.forEach((card) => io.observe(card));
  }
</script>

<style>
  .work-hero {
    position: relative;
    overflow: clip;
    padding-block: clamp(3.2rem, 7vw, 6.5rem) clamp(2.6rem, 7vw, 5.5rem);
  }

  .work-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(
        620px circle at 18% 18%,
        color-mix(in srgb, var(--signal) 11%, transparent),
        transparent 62%
      ),
      radial-gradient(
        460px circle at 88% 20%,
        color-mix(in srgb, var(--glass-lo) 18%, transparent),
        transparent 64%
      );
    pointer-events: none;
  }

  .work-hero__inner {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1.02fr) minmax(320px, 0.98fr);
    gap: clamp(1.4rem, 3vw, 2rem);
    align-items: stretch;
  }

  .work-hero__copy,
  .work-hero__studio,
  .case-preview,
  .case-card,
  .work-close__surface {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
    isolation: isolate;
  }

  .work-hero__copy {
    padding: clamp(1.7rem, 4vw, 3rem);
    background:
      linear-gradient(140deg, color-mix(in srgb, var(--surface) 96%, transparent), var(--surface-2));
    border: 1px solid color-mix(in srgb, var(--hairline) 86%, transparent);
  }

  .work-hero__copy::after,
  .work-hero__studio::after,
  .case-preview::after,
  .case-card::after,
  .work-close__surface::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    background: radial-gradient(
      360px circle at var(--spot-x, 50%) var(--spot-y, 50%),
      color-mix(in srgb, var(--spotlight) 15%, transparent),
      transparent 68%
    );
    opacity: var(--spot-o, 0);
    transition: opacity 0.6s var(--ease-luxe);
  }

  .work-hero__headline {
    font-size: clamp(2.35rem, 5.6vw, 4.65rem);
    line-height: 0.98;
    max-inline-size: 9.2em;
    margin-block-end: 1rem;
  }

  .work-hero__lede {
    max-inline-size: 40rem;
    font-size: clamp(1.08rem, 2vw, 1.28rem);
    line-height: 1.58;
    color: var(--graphite);
    margin-block-end: 1.5rem;
  }

  .work-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-block-end: 1.2rem;
  }

  .work-hero__cta,
  .work-close__link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-block-size: 48px;
    padding: 0.75rem 1.1rem;
    border-radius: var(--radius-sm);
    font-weight: 600;
    text-align: center;
  }

  .work-hero__cta--primary,
  .work-close__link--primary {
    background: var(--signal);
    color: var(--on-ink);
  }

  .work-hero__cta--primary:hover,
  .work-close__link--primary:hover {
    background: var(--signal-hover);
    color: var(--on-ink);
  }

  .work-hero__cta--secondary,
  .work-close__link--secondary {
    background: color-mix(in srgb, var(--surface) 70%, transparent);
    color: var(--ink);
    border: 1px solid color-mix(in srgb, var(--hairline) 86%, transparent);
  }

  .work-hero__cta--secondary:hover,
  .work-close__link--secondary:hover {
    color: var(--ink);
    border-color: color-mix(in srgb, var(--signal) 34%, var(--hairline));
  }

  .work-hero__note {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.81rem;
    color: var(--graphite);
  }

  .work-hero__studio {
    min-block-size: 100%;
    padding: clamp(1.4rem, 3vw, 1.9rem);
    background:
      radial-gradient(
        300px circle at 24% 16%,
        color-mix(in srgb, var(--signal) 18%, transparent),
        transparent 68%
      ),
      radial-gradient(
        260px circle at 86% 24%,
        color-mix(in srgb, var(--glass-lo) 18%, transparent),
        transparent 70%
      ),
      linear-gradient(180deg, color-mix(in srgb, var(--ink-surface) 92%, transparent), var(--ink-surface));
    color: var(--on-ink);
    border: 1px solid color-mix(in srgb, white 9%, transparent);
  }

  .studio__frame {
    position: relative;
    min-block-size: 100%;
    display: grid;
    gap: 1.1rem;
  }

  .studio__head {
    position: relative;
    z-index: 1;
    display: grid;
    justify-items: start;
    gap: 0.32rem;
    max-inline-size: 14rem;
    padding-inline-start: 0.15rem;
  }

  .studio__head p,
  .studio__head strong {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.76rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .studio__head p {
    color: color-mix(in srgb, white 72%, transparent);
  }

  .studio__head strong {
    color: var(--on-ink);
    font-weight: 560;
    font-size: 0.8rem;
  }

  .studio__stage {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(200px, 0.9fr);
    gap: 1rem;
    align-items: center;
  }

  .studio__inputs {
    display: grid;
    gap: 0.78rem;
  }

  .studio__input {
    position: relative;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) minmax(40px, 0.7fr);
    align-items: center;
    gap: 0.75rem;
    padding: 0.78rem 0.85rem;
    border-radius: 18px;
    background:
      linear-gradient(
        130deg,
        color-mix(in srgb, white 10%, transparent),
        color-mix(in srgb, white 4%, transparent)
      );
    border: 1px solid color-mix(in srgb, white 10%, transparent);
    box-shadow: inset 0 1px 0 color-mix(in srgb, white 8%, transparent);
  }

  .studio__input-dot {
    inline-size: 0.6rem;
    block-size: 0.6rem;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--speed-from), var(--speed-to));
    box-shadow:
      0 0 0 6px color-mix(in srgb, var(--signal) 11%, transparent),
      0 0 20px color-mix(in srgb, var(--signal) 22%, transparent);
  }

  .studio__input-copy {
    min-inline-size: 0;
  }

  .studio__input-copy p {
    margin: 0 0 0.35rem;
    font-size: 0.94rem;
    font-weight: 560;
  }

  .studio__input-copy span {
    display: block;
    block-size: 1px;
    background: color-mix(in srgb, white 14%, transparent);
  }

  .studio__input-flow {
    position: relative;
    block-size: 2px;
    border-radius: 999px;
    background: color-mix(in srgb, white 12%, transparent);
    overflow: hidden;
  }

  .studio__input-flow i {
    position: absolute;
    inset-block: 0;
    inline-size: 34%;
    border-radius: inherit;
    background: linear-gradient(90deg, transparent, var(--speed-from), transparent);
    box-shadow: 0 0 16px color-mix(in srgb, var(--signal) 28%, transparent);
  }

  .studio__decision {
    position: relative;
    padding: 1.15rem;
    border-radius: 22px;
    background:
      radial-gradient(
        220px circle at 82% 12%,
        color-mix(in srgb, var(--signal) 15%, transparent),
        transparent 62%
      ),
      linear-gradient(
        145deg,
        color-mix(in srgb, white 10%, transparent),
        color-mix(in srgb, white 4%, transparent)
      );
    border: 1px solid color-mix(in srgb, white 10%, transparent);
    box-shadow:
      0 18px 36px color-mix(in srgb, black 12%, transparent),
      inset 0 1px 0 color-mix(in srgb, white 10%, transparent);
  }

  .studio__decision::before {
    content: '';
    position: absolute;
    inset-inline-start: -1rem;
    inset-block-start: 50%;
    inline-size: 1.4rem;
    block-size: 1px;
    background: linear-gradient(90deg, color-mix(in srgb, white 18%, transparent), var(--speed-from));
  }

  .studio__decision-kicker {
    display: block;
    margin-block-end: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.055em;
    text-transform: uppercase;
    color: color-mix(in srgb, white 72%, transparent);
  }

  .studio__decision strong {
    display: block;
    margin-block-end: 0.65rem;
    font-size: clamp(1.35rem, 2.6vw, 1.95rem);
    line-height: 1.05;
    letter-spacing: var(--tracking-display);
  }

  .studio__decision p {
    margin: 0;
    font-size: 0.96rem;
    color: color-mix(in srgb, white 78%, transparent);
  }

  .studio__decision-bars {
    display: grid;
    gap: 0.5rem;
    margin-block-start: 1rem;
  }

  .studio__decision-bars span {
    display: block;
    block-size: 5px;
    border-radius: 999px;
    background: color-mix(in srgb, white 12%, transparent);
    overflow: hidden;
  }

  .studio__decision-bars span:nth-child(1) {
    inline-size: 92%;
  }

  .studio__decision-bars span:nth-child(2) {
    inline-size: 68%;
  }

  .studio__decision-bars span:nth-child(3) {
    inline-size: 84%;
  }

  .studio__metrics {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.8rem;
  }

  .studio__metric {
    padding: 0.9rem;
    border-radius: calc(var(--radius-sm) + 2px);
    background: color-mix(in srgb, white 7%, transparent);
    border: 1px solid color-mix(in srgb, white 8%, transparent);
    backdrop-filter: blur(10px);
  }

  .studio__metric span,
  .studio__metric strong {
    display: block;
  }

  .studio__metric span {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: color-mix(in srgb, white 64%, transparent);
    margin-block-end: 0.45rem;
  }

  .studio__metric strong {
    font-size: clamp(1.2rem, 2vw, 1.7rem);
    letter-spacing: var(--tracking-display);
  }

  .case-nav {
    position: sticky;
    inset-block-start: 68px;
    z-index: calc(var(--z-nav) - 1);
    background: color-mix(in srgb, var(--surface) 82%, transparent);
    -webkit-backdrop-filter: saturate(180%) blur(14px);
    backdrop-filter: saturate(180%) blur(14px);
    border-block: 1px solid color-mix(in srgb, var(--hairline) 82%, transparent);
  }

  .case-nav__inner ul {
    display: flex;
    gap: 0.75rem;
    list-style: none;
    margin: 0;
    padding: 0.7rem 0;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .case-nav__inner a {
    display: inline-flex;
    align-items: center;
    min-block-size: 40px;
    padding-inline: 0.95rem;
    border-radius: 999px;
    white-space: nowrap;
    color: var(--graphite);
    background: color-mix(in srgb, var(--surface) 64%, transparent);
    border: 1px solid color-mix(in srgb, var(--hairline) 82%, transparent);
    transition:
      color var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out),
      background var(--dur-fast) var(--ease-out),
      transform var(--dur-fast) var(--ease-out);
  }

  .case-nav__inner a:hover,
  .case-nav__inner a.is-active {
    color: var(--ink);
    border-color: color-mix(in srgb, var(--signal) 34%, var(--hairline));
    background: color-mix(in srgb, var(--signal) 8%, var(--surface));
    transform: translateY(-1px);
  }

  .case-track {
    padding-block: clamp(2.2rem, 5vw, 4rem) var(--section-pad);
  }

  .case-track__header {
    margin-block-end: clamp(2.2rem, 5vw, 3.6rem);
  }

  .case-track__grid {
    display: grid;
    grid-template-columns: minmax(290px, 0.78fr) minmax(0, 1.22fr);
    gap: clamp(1.25rem, 3vw, 2rem);
    align-items: stretch;
  }

  .case-preview-wrap {
    position: relative;
    align-self: stretch;
  }

  .case-preview {
    position: sticky;
    inset-block-start: 132px;
    padding: clamp(1.25rem, 2.5vw, 1.6rem);
    background:
      radial-gradient(
        240px circle at 50% 22%,
        color-mix(in srgb, var(--signal) 14%, transparent),
        transparent 68%
      ),
      linear-gradient(180deg, color-mix(in srgb, var(--ink-surface) 90%, transparent), var(--ink-surface));
    color: var(--on-ink);
    border: 1px solid color-mix(in srgb, white 9%, transparent);
  }

  .case-preview__visual {
    position: relative;
    aspect-ratio: 1.08;
    margin-block-end: 1.2rem;
  }

  .case-preview__ring,
  .case-preview__node,
  .case-preview__sweep {
    position: absolute;
  }

  .case-preview__ring {
    inset: 50%;
    border-radius: 999px;
