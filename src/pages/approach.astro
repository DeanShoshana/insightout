---
import Base from '../layouts/Base.astro';
import PageIntro from '../components/PageIntro.astro';
import EngineDiagram from '../components/EngineDiagram.astro';
import AdvisoryCircle from '../components/AdvisoryCircle.astro';
import { approach } from '../content/approach';
import { siteConfig } from '../../site.config';

const { intro, origin, decisionFrame, model, operatingSystem } = approach;
---

<Base
  title="Approach"
  description="How Claritix combines product, technology, analytics, and strategy to turn evidence into decisions."
>
  <!-- DRAFT COPY - Approach (SPEC §5.4): the differentiation page. -->
  <PageIntro kicker={intro.kicker} headline={intro.headline} lede={intro.lede} />

  <!-- §5.4 #1 - origin arc -->
  <section class="origin" aria-labelledby="origin-headline">
    <div class="container origin__inner">
      <div class="origin__copy-block" data-reveal>
        <h2 class="origin__headline" id="origin-headline">{origin.headline}</h2>
        <div class="origin__copy">
          {origin.paragraphs.map((p) => <p>{p}</p>)}
        </div>
      </div>

      <aside
        class="decision-frame"
        data-reveal
        data-spotlight
        style="--reveal-delay: 120ms"
        aria-labelledby="decision-frame-headline"
      >
        <p class="decision-frame__kicker">{decisionFrame.kicker}</p>
        <h3 class="decision-frame__headline" id="decision-frame-headline">{decisionFrame.headline}</h3>
        <p class="decision-frame__body">{decisionFrame.body}</p>

        <div class="decision-frame__map" aria-hidden="true">
          <div class="decision-frame__signals">
            {decisionFrame.signals.map((signal, i) => <span style={`--signal-index: ${i}`}>{signal}</span>)}
          </div>
          <div class="decision-frame__artifact">{decisionFrame.artifact}</div>
        </div>
      </aside>
    </div>
  </section>

  <!-- §5.4 #2 - the model: three engines feed the seat -->
  <section class="model" aria-labelledby="model-headline">
    <div class="container">
      <header class="section-head" data-reveal>
        <p class="section-head__kicker">The model</p>
        <h2 class="section-head__headline" id="model-headline">{model.headline}</h2>
        <p class="section-head__lede">{model.body}</p>
      </header>
      <div class="model__surface" data-reveal data-spotlight style="--reveal-delay: 120ms">
        <div class="model__rail" aria-hidden="true">
          <span>Product</span>
          <span>Behavior</span>
          <span>Data</span>
          <span>Market</span>
        </div>
        <EngineDiagram caption={model.diagramCaption} />
      </div>
    </div>
  </section>

  <!-- Enhancement spec: no public timing commitments. -->
  <section class="system" aria-labelledby="system-headline">
    <div class="container">
      <header class="section-head" data-reveal>
        <p class="section-head__kicker">Working together</p>
        <h2 class="section-head__headline" id="system-headline">{operatingSystem.headline}</h2>
        <p class="section-head__lede">{operatingSystem.lede}</p>
      </header>

      <div class="system__grid">
        {
          operatingSystem.parts.map((part, i) => (
            <article class="system-card" data-reveal data-spotlight style={`--reveal-delay: ${i * 80}ms`}>
              <div class:list={['system-card__visual', `system-card__visual--${part.visual}`]} aria-hidden="true">
                <span class="system-card__aura"></span>
                <span class="system-card__line system-card__line--one"></span>
                <span class="system-card__line system-card__line--two"></span>
                <span class="system-card__float system-card__float--primary">
                  <span></span>
                  <span></span>
                  <span></span>
                </span>
                <span class="system-card__float system-card__float--secondary">
                  <span></span>
                  <span></span>
                </span>
                <span class="system-card__dot system-card__dot--one"></span>
                <span class="system-card__dot system-card__dot--two"></span>
              </div>
              <p class="system-card__number">0{i + 1}</p>
              <p class="system-card__kicker">{part.kicker}</p>
              <h3 class="system-card__name">{part.name}</h3>
              <p class="system-card__body">{part.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- §5.4 #4 - Advisory Circle: built, shipped dark until MOUs (§4). -->
  {siteConfig.flags.showNetwork && <AdvisoryCircle />}
</Base>

<style>
  .origin {
    padding-block: clamp(2rem, 6vw, 5rem) var(--section-pad);
  }

  .origin__inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 0.92fr);
    gap: clamp(1.5rem, 4vw, 4rem);
    align-items: center;
  }

  @media (max-width: 860px) {
    .origin__inner {
      grid-template-columns: 1fr;
    }
  }

  .origin__headline {
    font-size: clamp(2rem, 4.2vw, 3.25rem);
    margin-block-end: clamp(1rem, 2vw, 1.5rem);
  }

  .origin__copy p {
    color: var(--graphite);
    font-size: clamp(1.05rem, 1.6vw, 1.2rem);
  }

  .origin__copy p:last-child {
    color: var(--ink);
    margin-block-end: 0;
  }

  .decision-frame,
  .model__surface,
  .system-card {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
    isolation: isolate;
  }

  .decision-frame {
    padding: clamp(1.5rem, 3vw, 2.4rem);
    min-block-size: clamp(420px, 44vw, 540px);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    background:
      radial-gradient(
        420px circle at 78% 18%,
        color-mix(in srgb, var(--signal) 15%, transparent),
        transparent 62%
      ),
      linear-gradient(
        145deg,
        var(--surface) 0%,
        var(--glass-hi) 52%,
        color-mix(in srgb, var(--glass-lo) 34%, var(--glass-hi)) 100%
      );
  }

  .decision-frame::after,
  .model__surface::after,
  .system-card::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    background: radial-gradient(
      320px circle at var(--spot-x, 50%) var(--spot-y, 50%),
      color-mix(in srgb, var(--signal) 10%, transparent),
      transparent 70%
    );
    opacity: var(--spot-o, 0);
    transition: opacity 0.6s var(--ease-luxe);
  }

  .decision-frame__kicker,
  .system-card__kicker {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--signal-text);
    margin-block-end: 0.65rem;
  }

  .decision-frame__headline {
    font-size: clamp(1.55rem, 3vw, 2.15rem);
    max-inline-size: 11ch;
    margin-block-end: 0.75rem;
  }

  .decision-frame__body {
    max-inline-size: 34ch;
    color: var(--graphite);
    margin: 0;
  }

  .decision-frame__map {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: clamp(1rem, 2.6vw, 2rem);
    align-items: center;
    margin-block-start: clamp(2rem, 6vw, 4rem);
  }

  .decision-frame__signals {
    display: grid;
    gap: 0.75rem;
  }

  .decision-frame__signals span {
    position: relative;
    display: flex;
    align-items: center;
    min-block-size: 2.5rem;
    padding-inline: 0.85rem 2.4rem;
    border: 1px solid color-mix(in srgb, var(--signal) 18%, var(--hairline));
    border-radius: var(--radius-sm);
    background: color-mix(in srgb, var(--surface) 76%, transparent);
    color: var(--ink);
    font-weight: 600;
    font-size: 0.88rem;
  }

  .decision-frame__signals span::after {
    content: '';
    position: absolute;
    inset-inline-start: calc(100% - 0.25rem);
    inset-block-start: 50%;
    inline-size: clamp(1.3rem, 3vw, 2.4rem);
    block-size: 2px;
    background: color-mix(in srgb, var(--signal) 58%, var(--glass-lo));
    transform: translateY(-50%);
    transform-origin: left center;
  }

  .decision-frame__artifact {
    display: grid;
    place-items: center;
    inline-size: clamp(6.2rem, 14vw, 8rem);
    aspect-ratio: 1;
    border-radius: 26px;
    background: var(--ink-surface);
    color: var(--on-ink);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    text-transform: uppercase;
    box-shadow:
      0 18px 44px rgba(16, 24, 40, 0.2),
      inset 0 0 0 1px color-mix(in srgb, var(--speed-from) 20%, transparent);
  }

  .model {
    background: var(--surface-2);
    padding-block: var(--section-pad);
  }

  .model__surface {
    padding: clamp(1.25rem, 3vw, 2.5rem);
    background:
      radial-gradient(
        460px circle at 72% 20%,
        color-mix(in srgb, var(--signal) 10%, transparent),
        transparent 64%
      ),
      linear-gradient(145deg, var(--surface) 0%, var(--surface-2) 100%);
  }

  .model__rail {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-block-end: clamp(1.5rem, 3vw, 2.4rem);
  }

  .model__rail span {
    padding: 0.45rem 0.7rem;
    border: 1px solid var(--hairline);
    border-radius: 999px;
    color: var(--graphite);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
  }

  .system {
    padding-block: var(--section-pad);
  }

  .system__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(1rem, 2.5vw, 1.75rem);
  }

  @media (max-width: 1100px) {
    .system__grid {
      grid-template-columns: repeat(2, 1fr);
      max-inline-size: 560px;
      margin-inline: auto;
    }
  }

  @media (max-width: 680px) {
    .system__grid {
      grid-template-columns: 1fr;
    }
  }

  .system-card {
    background: var(--surface);
    padding: clamp(1.5rem, 3vw, 2rem);
    min-block-size: 100%;
    transition:
      transform var(--dur-hover) var(--ease-luxe),
      box-shadow var(--dur-hover) var(--ease-luxe);
  }

  .system-card:hover {
    box-shadow: var(--shadow-card-hover);
  }

  .system-card__visual {
    position: relative;
    block-size: 138px;
    margin-block-end: 1.5rem;
    border-radius: 22px;
    background:
      radial-gradient(
        210px circle at 74% 16%,
        color-mix(in srgb, var(--signal) 14%, transparent),
        transparent 62%
      ),
      linear-gradient(
        145deg,
        color-mix(in srgb, var(--surface) 84%, transparent) 0%,
        var(--glass-hi) 54%,
        color-mix(in srgb, var(--glass-lo) 28%, var(--glass-hi)) 100%
      );
    overflow: hidden;
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, white 55%, transparent),
      0 18px 46px color-mix(in srgb, var(--ink) 7%, transparent);
  }

  .system-card__visual::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(120deg, transparent, color-mix(in srgb, white 24%, transparent), transparent),
      linear-gradient(180deg, color-mix(in srgb, white 18%, transparent), transparent 44%);
    opacity: 0.56;
    transform: translateX(-22%);
  }

  .system-card__aura,
  .system-card__line,
  .system-card__float,
  .system-card__dot {
    position: absolute;
    display: block;
  }

  .system-card__aura {
    inline-size: 170px;
    block-size: 104px;
    inset-inline-start: 50%;
    inset-block-start: 50%;
    border-radius: 999px;
    background: color-mix(in srgb, var(--signal) 24%, transparent);
    filter: blur(24px);
    opacity: 0.54;
    transform: translate3d(-50%, -50%, 0);
  }

  .system-card__line {
    block-size: 1px;
    border-radius: 999px;
    background: linear-gradient(
      90deg,
      transparent,
      color-mix(in srgb, var(--signal) 48%, transparent),
      transparent
    );
    opacity: 0.62;
    transform-origin: center;
  }

  .system-card__line--one {
    inline-size: 72%;
    inset-inline-start: 12%;
    inset-block-start: 46%;
    transform: rotate(-9deg);
  }

  .system-card__line--two {
    inline-size: 58%;
    inset-inline-start: 24%;
    inset-block-start: 64%;
    transform: rotate(8deg);
    opacity: 0.42;
  }

  .system-card__float {
    z-index: 1;
    border: 1px solid color-mix(in srgb, var(--signal) 16%, var(--hairline));
    border-radius: 16px;
    background:
      linear-gradient(
        145deg,
        color-mix(in srgb, var(--surface) 78%, transparent),
        color-mix(in srgb, var(--glass-hi) 44%, transparent)
      );
    -webkit-backdrop-filter: blur(12px) saturate(135%);
    backdrop-filter: blur(12px) saturate(135%);
    box-shadow:
      0 18px 42px color-mix(in srgb, var(--ink) 8%, transparent),
      inset 0 1px 0 color-mix(in srgb, white 56%, transparent);
  }

  .system-card__float span {
    position: absolute;
    display: block;
    border-radius: 999px;
    background: color-mix(in srgb, var(--glass-lo) 70%, transparent);
  }

  .system-card__float--primary {
    inline-size: 104px;
    block-size: 70px;
    inset-inline-start: 14%;
    inset-block-start: 24%;
    transform: rotate(-7deg);
  }

  .system-card__float--primary span:nth-child(1) {
    inline-size: 56%;
    block-size: 4px;
    inset-inline-start: 16%;
    inset-block-start: 28%;
  }

  .system-card__float--primary span:nth-child(2) {
    inline-size: 42%;
    block-size: 4px;
    inset-inline-start: 16%;
    inset-block-start: 48%;
  }

  .system-card__float--primary span:nth-child(3) {
    inline-size: 24%;
    block-size: 4px;
    inset-inline-start: 16%;
    inset-block-start: 68%;
    background: var(--signal);
  }

  .system-card__float--secondary {
    inline-size: 62px;
    block-size: 86px;
    inset-inline-end: 15%;
    inset-block-start: 18%;
    transform: rotate(6deg);
  }

  .system-card__float--secondary span:nth-child(1) {
    inline-size: 54%;
    block-size: 3px;
    inset-inline-start: 22%;
    inset-block-start: 34%;
  }

  .system-card__float--secondary span:nth-child(2) {
    inline-size: 36%;
    block-size: 3px;
    inset-inline-start: 22%;
    inset-block-start: 54%;
    background: var(--signal);
  }

  .system-card__dot {
    z-index: 2;
    inline-size: 11px;
    block-size: 11px;
    border-radius: 999px;
    background: var(--signal);
    box-shadow: 0 0 0 8px color-mix(in srgb, var(--signal) 12%, transparent);
  }

  .system-card__dot--one {
    inset-inline-start: 47%;
    inset-block-start: 40%;
  }

  .system-card__dot--two {
    inset-inline-end: 30%;
    inset-block-end: 25%;
    opacity: 0.72;
  }

  .system-card__visual--product .system-card__float--primary {
    inline-size: 110px;
    block-size: 74px;
  }

  .system-card__visual--product .system-card__float--secondary {
    inline-size: 54px;
    block-size: 90px;
    inset-inline-end: 14%;
  }

  .system-card__visual--technology .system-card__float--primary {
    inline-size: 96px;
    block-size: 86px;
    inset-block-start: 20%;
  }

  .system-card__visual--technology .system-card__float--secondary {
    inline-size: 58px;
    block-size: 58px;
    inset-block-start: 34%;
  }

  .system-card__visual--analytics .system-card__float--primary {
    inline-size: 96px;
    block-size: 76px;
  }

  .system-card__visual--analytics .system-card__float--primary span {
    inset-inline-start: auto;
    inset-block-end: 16%;
    inline-size: 6px;
    border-radius: 999px 999px 0 0;
  }

  .system-card__visual--analytics .system-card__float--primary span:nth-child(1) {
    inset-inline-start: 18%;
    block-size: 28%;
  }

  .system-card__visual--analytics .system-card__float--primary span:nth-child(2) {
    inset-inline-start: 42%;
    block-size: 48%;
  }

  .system-card__visual--analytics .system-card__float--primary span:nth-child(3) {
    inset-inline-start: 66%;
    block-size: 64%;
  }

  .system-card__visual--strategy {
    background:
      radial-gradient(
        210px circle at 70% 30%,
        color-mix(in srgb, var(--speed-from) 18%, transparent),
        transparent 66%
      ),
      linear-gradient(
        145deg,
        var(--ink-surface) 0%,
        color-mix(in srgb, var(--signal) 18%, var(--ink-surface)) 100%
      );
  }

  .system-card__visual--strategy .system-card__aura {
    background: color-mix(in srgb, var(--speed-from) 28%, transparent);
  }

  .system-card__visual--strategy .system-card__line,
  .system-card__visual--strategy .system-card__dot {
    background: var(--speed-from);
  }

  .system-card__visual--strategy .system-card__float {
    border-color: color-mix(in srgb, var(--speed-from) 24%, transparent);
    background:
      linear-gradient(
        145deg,
        color-mix(in srgb, var(--ink-surface) 70%, transparent),
        color-mix(in srgb, var(--signal) 18%, transparent)
      );
  }

  .system-card__visual--strategy .system-card__float span {
    background: color-mix(in srgb, var(--speed-from) 62%, transparent);
  }

  .system-card__number {
    font-family: var(--font-mono);
    color: var(--graphite);
    margin-block-end: 2rem;
  }

  .system-card__name {
    font-size: 1.4rem;
    margin-block-end: 1rem;
  }

  .system-card__body {
    color: var(--graphite);
    margin: 0;
  }

  @media (prefers-reduced-motion: no-preference) {
    .decision-frame,
    .model__surface,
    .system-card {
      transition:
        transform var(--dur-hover) var(--ease-luxe),
        box-shadow var(--dur-hover) var(--ease-luxe);
    }

    .decision-frame:hover,
    .model__surface:hover,
    .system-card:hover {
      transform: translateY(-6px);
    }

    :global(.js) [data-reveal]:not(.in) .decision-frame__signals span::after {
      transform: translateY(-50%) scaleX(0);
    }

    :global(.js) [data-reveal].in .decision-frame__signals span::after {
      transition: transform 1000ms var(--ease-luxe);
      transition-delay: calc(220ms + var(--signal-index) * 90ms);
    }
  }

  @media (max-width: 720px) {
    .origin {
      padding-block-start: 1.5rem;
    }

    .decision-frame {
      min-block-size: auto;
    }

    .decision-frame__headline {
      max-inline-size: 12ch;
    }

    .decision-frame__map {
      grid-template-columns: 1fr;
      margin-block-start: 2rem;
    }

    .decision-frame__signals span {
      padding-inline-end: 0.85rem;
    }

    .decision-frame__signals span::after {
      display: none;
    }

    .decision-frame__artifact {
      inline-size: 100%;
      aspect-ratio: auto;
      min-block-size: 4.5rem;
      border-radius: var(--radius-card);
    }

    .model__surface {
      padding: 1rem;
    }

    .system__grid {
      gap: 1rem;
    }

    .system-card__visual {
      block-size: 126px;
      margin-block-end: 1.2rem;
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .system-card__aura {
      animation: system-aura-drift 9s var(--ease-luxe) infinite;
    }

    .system-card__float--primary {
      animation: system-float-primary 8s var(--ease-luxe) infinite;
    }

    .system-card__float--secondary {
      animation: system-float-secondary 8.5s var(--ease-luxe) infinite;
    }
  }

  @keyframes system-aura-drift {
    0%,
    100% {
      transform: translate3d(-50%, -50%, 0) scale(1);
    }

    50% {
      transform: translate3d(-46%, -54%, 0) scale(1.08);
    }
  }

  @keyframes system-float-primary {
    0%,
    100% {
      transform: translate3d(0, 0, 0) rotate(-7deg);
    }

    50% {
      transform: translate3d(7px, -7px, 0) rotate(-4deg);
    }
  }

  @keyframes system-float-secondary {
    0%,
    100% {
      transform: translate3d(0, 0, 0) rotate(6deg);
    }

    50% {
      transform: translate3d(-6px, 8px, 0) rotate(3deg);
    }
  }
</style>
