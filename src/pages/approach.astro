---
import Base from '../layouts/Base.astro';
import PageIntro from '../components/PageIntro.astro';
import EngineDiagram from '../components/EngineDiagram.astro';
import AdvisoryCircle from '../components/AdvisoryCircle.astro';
import { approach } from '../content/approach';
import { siteConfig } from '../../site.config';

const { intro, origin, decisionFrame, model, operatingSystem } = approach;
---

<Base
  title="Approach"
  description="How Claritix combines product, technology, analytics, and strategy to turn evidence into decisions."
>
  <!-- DRAFT COPY - Approach (SPEC §5.4): the differentiation page. -->
  <PageIntro kicker={intro.kicker} headline={intro.headline} lede={intro.lede} />

  <!-- §5.4 #1 - origin arc -->
  <section class="origin" aria-labelledby="origin-headline">
    <div class="container origin__inner">
      <div class="origin__copy-block" data-reveal>
        <h2 class="origin__headline" id="origin-headline">{origin.headline}</h2>
        <div class="origin__copy">
          {origin.paragraphs.map((p) => <p>{p}</p>)}
        </div>
      </div>

      <aside
        class="decision-frame"
        data-reveal
        data-spotlight
        style="--reveal-delay: 120ms"
        aria-labelledby="decision-frame-headline"
      >
        <p class="decision-frame__kicker">{decisionFrame.kicker}</p>
        <h3 class="decision-frame__headline" id="decision-frame-headline">{decisionFrame.headline}</h3>
        <p class="decision-frame__body">{decisionFrame.body}</p>

        <div class="decision-frame__map" aria-hidden="true">
          <div class="decision-frame__signals">
            {decisionFrame.signals.map((signal, i) => <span style={`--signal-index: ${i}`}>{signal}</span>)}
          </div>
          <div class="decision-frame__artifact">{decisionFrame.artifact}</div>
        </div>
      </aside>
    </div>
  </section>

  <!-- §5.4 #2 - the model: three engines feed the seat -->
  <section class="model" aria-labelledby="model-headline">
    <div class="container">
      <header class="section-head" data-reveal>
        <p class="section-head__kicker">The model</p>
        <h2 class="section-head__headline" id="model-headline">{model.headline}</h2>
        <p class="section-head__lede">{model.body}</p>
      </header>
      <div class="model__surface" data-reveal data-spotlight style="--reveal-delay: 120ms">
        <div class="model__rail" aria-hidden="true">
          <span>Product</span>
          <span>Behavior</span>
          <span>Data</span>
          <span>Market</span>
        </div>
        <EngineDiagram caption={model.diagramCaption} />
      </div>
    </div>
  </section>

  <!-- Enhancement spec: no public timing commitments. -->
  <section class="system" aria-labelledby="system-headline">
    <div class="container">
      <header class="section-head" data-reveal>
        <p class="section-head__kicker">Working together</p>
        <h2 class="section-head__headline" id="system-headline">{operatingSystem.headline}</h2>
        <p class="section-head__lede">{operatingSystem.lede}</p>
      </header>

      <div class="system__grid">
        {
          operatingSystem.parts.map((part, i) => (
            <article class="system-card" data-reveal data-spotlight style={`--reveal-delay: ${i * 80}ms`}>
              <div class:list={['system-card__visual', `system-card__visual--${part.visual}`]} aria-hidden="true">
                <span class="system-card__track"></span>
                <span class="system-card__track"></span>
                <span class="system-card__node"></span>
                <span class="system-card__panel"></span>
              </div>
              <p class="system-card__number">0{i + 1}</p>
              <p class="system-card__kicker">{part.kicker}</p>
              <h3 class="system-card__name">{part.name}</h3>
              <p class="system-card__body">{part.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- §5.4 #4 - Advisory Circle: built, shipped dark until MOUs (§4). -->
  {siteConfig.flags.showNetwork && <AdvisoryCircle />}
</Base>

<style>
  .origin {
    padding-block: clamp(2rem, 6vw, 5rem) var(--section-pad);
  }

  .origin__inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 0.92fr);
    gap: clamp(1.5rem, 4vw, 4rem);
    align-items: center;
  }

  @media (max-width: 860px) {
    .origin__inner {
      grid-template-columns: 1fr;
    }
  }

  .origin__headline {
    font-size: clamp(2rem, 4.2vw, 3.25rem);
    margin-block-end: clamp(1rem, 2vw, 1.5rem);
  }

  .origin__copy p {
    color: var(--graphite);
    font-size: clamp(1.05rem, 1.6vw, 1.2rem);
  }

  .origin__copy p:last-child {
    color: var(--ink);
    margin-block-end: 0;
  }

  .decision-frame,
  .model__surface,
  .system-card {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
    isolation: isolate;
  }

  .decision-frame {
    padding: clamp(1.5rem, 3vw, 2.4rem);
    min-block-size: clamp(420px, 44vw, 540px);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    background:
      radial-gradient(
        420px circle at 78% 18%,
        color-mix(in srgb, var(--signal) 15%, transparent),
        transparent 62%
      ),
      linear-gradient(
        145deg,
        var(--surface) 0%,
        var(--glass-hi) 52%,
        color-mix(in srgb, var(--glass-lo) 34%, var(--glass-hi)) 100%
      );
  }

  .decision-frame::after,
  .model__surface::after,
  .system-card::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    background: radial-gradient(
      320px circle at var(--spot-x, 50%) var(--spot-y, 50%),
      color-mix(in srgb, var(--signal) 10%, transparent),
      transparent 70%
    );
    opacity: var(--spot-o, 0);
    transition: opacity 0.6s var(--ease-luxe);
  }

  .decision-frame__kicker,
  .system-card__kicker {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--signal-text);
    margin-block-end: 0.65rem;
  }

  .decision-frame__headline {
    font-size: clamp(1.55rem, 3vw, 2.15rem);
    max-inline-size: 11ch;
    margin-block-end: 0.75rem;
  }

  .decision-frame__body {
    max-inline-size: 34ch;
    color: var(--graphite);
    margin: 0;
  }

  .decision-frame__map {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: clamp(1rem, 2.6vw, 2rem);
    align-items: center;
    margin-block-start: clamp(2rem, 6vw, 4rem);
  }

  .decision-frame__signals {
    display: grid;
    gap: 0.75rem;
  }

  .decision-frame__signals span {
    position: relative;
    display: flex;
    align-items: center;
    min-block-size: 2.5rem;
    padding-inline: 0.85rem 2.4rem;
    border: 1px solid color-mix(in srgb, var(--signal) 18%, var(--hairline));
    border-radius: var(--radius-sm);
    background: color-mix(in srgb, var(--surface) 76%, transparent);
    color: var(--ink);
    font-weight: 600;
    font-size: 0.88rem;
  }

  .decision-frame__signals span::after {
    content: '';
    position: absolute;
    inset-inline-start: calc(100% - 0.25rem);
    inset-block-start: 50%;
    inline-size: clamp(1.3rem, 3vw, 2.4rem);
    block-size: 2px;
    background: color-mix(in srgb, var(--signal) 58%, var(--glass-lo));
    transform: translateY(-50%);
    transform-origin: left center;
  }

  .decision-frame__artifact {
    display: grid;
    place-items: center;
    inline-size: clamp(6.2rem, 14vw, 8rem);
    aspect-ratio: 1;
    border-radius: 26px;
    background: var(--ink-surface);
    color: var(--on-ink);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    text-transform: uppercase;
    box-shadow:
      0 18px 44px rgba(16, 24, 40, 0.2),
      inset 0 0 0 1px color-mix(in srgb, var(--speed-from) 20%, transparent);
  }

  .model {
    background: var(--surface-2);
    padding-block: var(--section-pad);
  }

  .model__surface {
    padding: clamp(1.25rem, 3vw, 2.5rem);
    background:
      radial-gradient(
        460px circle at 72% 20%,
        color-mix(in srgb, var(--signal) 10%, transparent),
        transparent 64%
      ),
      linear-gradient(145deg, var(--surface) 0%, var(--surface-2) 100%);
  }

  .model__rail {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-block-end: clamp(1.5rem, 3vw, 2.4rem);
  }

  .model__rail span {
    padding: 0.45rem 0.7rem;
    border: 1px solid var(--hairline);
    border-radius: 999px;
    color: var(--graphite);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
  }

  .system {
    padding-block: var(--section-pad);
  }

  .system__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(1rem, 2.5vw, 1.75rem);
  }

  @media (max-width: 1100px) {
    .system__grid {
      grid-template-columns: repeat(2, 1fr);
      max-inline-size: 560px;
      margin-inline: auto;
    }
  }

  @media (max-width: 680px) {
    .system__grid {
      grid-template-columns: 1fr;
    }
  }

  .system-card {
    background: var(--surface);
    padding: clamp(1.5rem, 3vw, 2rem);
    min-block-size: 100%;
    transition:
      transform var(--dur-hover) var(--ease-luxe),
      box-shadow var(--dur-hover) var(--ease-luxe);
  }

  .system-card:hover {
    box-shadow: var(--shadow-card-hover);
  }

  .system-card__visual {
    position: relative;
    block-size: 118px;
    margin-block-end: 1.5rem;
    border-radius: 16px;
    background:
      radial-gradient(
        160px circle at 72% 24%,
        color-mix(in srgb, var(--signal) 18%, transparent),
        transparent 64%
      ),
      linear-gradient(
        145deg,
        var(--surface) 0%,
        var(--glass-hi) 58%,
        color-mix(in srgb, var(--glass-lo) 32%, var(--glass-hi)) 100%
      );
    overflow: hidden;
  }

  .system-card__track,
  .system-card__node,
  .system-card__panel {
    position: absolute;
    border-radius: 999px;
  }

  .system-card__track {
    inline-size: 48%;
    block-size: 3px;
    inset-inline-start: 18%;
    background: color-mix(in srgb, var(--glass-lo) 80%, var(--signal));
  }

  .system-card__track:nth-child(1) {
    inset-block-start: 38%;
    transform: rotate(-11deg);
  }

  .system-card__track:nth-child(2) {
    inset-block-start: 58%;
    transform: rotate(9deg);
    opacity: 0.7;
  }

  .system-card__node {
    inline-size: 16px;
    block-size: 16px;
    inset-inline-start: 54%;
    inset-block-start: 45%;
    background: var(--signal);
    box-shadow: 0 0 0 8px color-mix(in srgb, var(--signal) 11%, transparent);
  }

  .system-card__panel {
    inline-size: 44px;
    block-size: 34px;
    inset-inline-end: 17%;
    inset-block-start: 36%;
    border-radius: 10px;
    border: 2px solid color-mix(in srgb, var(--signal) 58%, var(--glass-lo));
    background: color-mix(in srgb, var(--surface) 64%, transparent);
  }

  .system-card__visual--product .system-card__panel {
    inline-size: 54px;
    block-size: 38px;
    inset-inline-start: 17%;
    inset-inline-end: auto;
  }

  .system-card__visual--product .system-card__node {
    inset-inline-start: 68%;
  }

  .system-card__visual--technology .system-card__track {
    inline-size: 34%;
    inset-inline-start: 18%;
  }

  .system-card__visual--technology .system-card__panel {
    inline-size: 38px;
    block-size: 52px;
  }

  .system-card__visual--analytics .system-card__track {
    inline-size: 3px;
    block-size: 44%;
    inset-block-start: 38%;
    transform: none;
  }

  .system-card__visual--analytics .system-card__track:nth-child(1) {
    inset-inline-start: 28%;
  }

  .system-card__visual--analytics .system-card__track:nth-child(2) {
    inset-inline-start: 42%;
    block-size: 30%;
  }

  .system-card__visual--strategy {
    background:
      radial-gradient(
        160px circle at 70% 30%,
        color-mix(in srgb, var(--speed-from) 20%, transparent),
        transparent 66%
      ),
      linear-gradient(
        145deg,
        var(--ink-surface) 0%,
        color-mix(in srgb, var(--signal) 18%, var(--ink-surface)) 100%
      );
  }

  .system-card__visual--strategy .system-card__track,
  .system-card__visual--strategy .system-card__node {
    background: var(--speed-from);
  }

  .system-card__visual--strategy .system-card__panel {
    border-color: color-mix(in srgb, var(--speed-from) 70%, transparent);
    background: color-mix(in srgb, var(--ink-surface) 76%, transparent);
  }

  .system-card__number {
    font-family: var(--font-mono);
    color: var(--graphite);
    margin-block-end: 2rem;
  }

  .system-card__name {
    font-size: 1.4rem;
    margin-block-end: 1rem;
  }

  .system-card__body {
    color: var(--graphite);
    margin: 0;
  }

  @media (prefers-reduced-motion: no-preference) {
    .decision-frame,
    .model__surface,
    .system-card {
      transition:
        transform var(--dur-hover) var(--ease-luxe),
        box-shadow var(--dur-hover) var(--ease-luxe);
    }

    .decision-frame:hover,
    .model__surface:hover,
    .system-card:hover {
      transform: translateY(-6px);
    }

    :global(.js) [data-reveal]:not(.in) .decision-frame__signals span::after {
      transform: translateY(-50%) scaleX(0);
    }

    :global(.js) [data-reveal].in .decision-frame__signals span::after {
      transition: transform 1000ms var(--ease-luxe);
      transition-delay: calc(220ms + var(--signal-index) * 90ms);
    }
  }

  @media (max-width: 720px) {
    .origin {
      padding-block-start: 1.5rem;
    }

    .decision-frame {
      min-block-size: auto;
    }

    .decision-frame__headline {
      max-inline-size: 12ch;
    }

    .decision-frame__map {
      grid-template-columns: 1fr;
      margin-block-start: 2rem;
    }

    .decision-frame__signals span {
      padding-inline-end: 0.85rem;
    }

    .decision-frame__signals span::after {
      display: none;
    }

    .decision-frame__artifact {
      inline-size: 100%;
      aspect-ratio: auto;
      min-block-size: 4.5rem;
      border-radius: var(--radius-card);
    }

    .model__surface {
      padding: 1rem;
    }

    .system__grid {
      gap: 1rem;
    }

    .system-card__visual {
      block-size: 104px;
      margin-block-end: 1.2rem;
    }
  }
</style>
