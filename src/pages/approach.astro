---
import Base from '../layouts/Base.astro';
import PageIntro from '../components/PageIntro.astro';
import EngineDiagram from '../components/EngineDiagram.astro';
import AdvisoryCircle from '../components/AdvisoryCircle.astro';
import { approach } from '../content/approach';
import { siteConfig } from '../../site.config';

const { intro, origin, model, operatingSystem } = approach;
---

<Base
  title="Approach"
  description="How Claritix combines product, technology, analytics, and strategy to turn evidence into decisions."
>
  <!-- DRAFT COPY - Approach (SPEC §5.4): the differentiation page. -->
  <PageIntro kicker={intro.kicker} headline={intro.headline} lede={intro.lede} />

  <!-- §5.4 #1 - origin arc -->
  <section class="origin" aria-labelledby="origin-headline">
    <div class="container origin__inner" data-reveal>
      <h2 class="origin__headline" id="origin-headline">{origin.headline}</h2>
      <div class="origin__copy">
        {origin.paragraphs.map((p) => <p>{p}</p>)}
      </div>
    </div>
  </section>

  <!-- §5.4 #2 - the model: three engines feed the seat -->
  <section class="model" aria-labelledby="model-headline">
    <div class="container">
      <header class="section-head" data-reveal>
        <p class="section-head__kicker">The model</p>
        <h2 class="section-head__headline" id="model-headline">{model.headline}</h2>
        <p class="section-head__lede">{model.body}</p>
      </header>
      <EngineDiagram caption={model.diagramCaption} />
    </div>
  </section>

  <!-- Enhancement spec: no public timing commitments. -->
  <section class="system" aria-labelledby="system-headline">
    <div class="container">
      <header class="section-head" data-reveal>
        <p class="section-head__kicker">Working together</p>
        <h2 class="section-head__headline" id="system-headline">{operatingSystem.headline}</h2>
        <p class="section-head__lede">{operatingSystem.lede}</p>
      </header>

      <div class="system__grid">
        {
          operatingSystem.parts.map((part, i) => (
            <article class="system-card" data-reveal data-spotlight style={`--reveal-delay: ${i * 80}ms`}>
              <p class="system-card__number">0{i + 1}</p>
              <p class="system-card__kicker">{part.kicker}</p>
              <h3 class="system-card__name">{part.name}</h3>
              <p class="system-card__body">{part.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- §5.4 #4 - Advisory Circle: built, shipped dark until MOUs (§4). -->
  {siteConfig.flags.showNetwork && <AdvisoryCircle />}
</Base>

<style>
  .origin {
    padding-block: clamp(2rem, 5vw, 4rem);
  }

  .origin__inner {
    display: grid;
    grid-template-columns: 1fr 1.6fr;
    gap: clamp(1.5rem, 4vw, 4rem);
    align-items: start;
  }

  @media (max-width: 860px) {
    .origin__inner {
      grid-template-columns: 1fr;
    }
  }

  .origin__headline {
    font-size: clamp(1.6rem, 3vw, 2.25rem);
    margin: 0;
  }

  .origin__copy p {
    color: var(--graphite);
    font-size: 1.1rem;
  }

  .origin__copy p:last-child {
    color: var(--ink);
    margin-block-end: 0;
  }

  .model {
    background: var(--surface-2);
    padding-block: var(--section-pad);
  }

  .system {
    padding-block: var(--section-pad);
  }

  .system__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(1rem, 2.5vw, 1.75rem);
  }

  @media (max-width: 1100px) {
    .system__grid {
      grid-template-columns: repeat(2, 1fr);
      max-inline-size: 560px;
      margin-inline: auto;
    }
  }

  @media (max-width: 680px) {
    .system__grid {
      grid-template-columns: 1fr;
    }
  }

  .system-card {
    position: relative;
    overflow: hidden;
    background: var(--surface);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
    padding: clamp(1.5rem, 3vw, 2rem);
    min-block-size: 100%;
    transition:
      transform var(--dur-hover) var(--ease-luxe),
      box-shadow var(--dur-hover) var(--ease-luxe);
  }

  .system-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-card-hover);
  }

  .system-card::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    background: radial-gradient(
      260px circle at var(--spot-x, 50%) var(--spot-y, 50%),
      color-mix(in srgb, var(--signal) 9%, transparent),
      transparent 70%
    );
    opacity: var(--spot-o, 0);
    transition: opacity 0.6s var(--ease-luxe);
  }

  .system-card__number {
    font-family: var(--font-mono);
    color: var(--graphite);
    margin-block-end: 2rem;
  }

  .system-card__kicker {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--signal-text);
    margin-block-end: 0.5rem;
  }

  .system-card__name {
    font-size: 1.4rem;
    margin-block-end: 1rem;
  }

  .system-card__body {
    color: var(--graphite);
    margin: 0;
  }
</style>
