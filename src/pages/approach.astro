---
import Base from '../layouts/Base.astro';
import PageIntro from '../components/PageIntro.astro';
import EngineDiagram from '../components/EngineDiagram.astro';
import AdvisoryCircle from '../components/AdvisoryCircle.astro';
import { approach } from '../content/approach';
import { siteConfig } from '../../site.config';

const { intro, origin, decisionFrame, model, operatingSystem } = approach;
---

<Base
  title="Approach"
  description="How Claritix combines product, technology, analytics, and strategy to turn evidence into decisions."
>
  <!-- DRAFT COPY - Approach (SPEC §5.4): the differentiation page. -->
  <PageIntro kicker={intro.kicker} headline={intro.headline} lede={intro.lede} />

  <!-- §5.4 #1 - origin arc -->
  <section class="origin" aria-labelledby="origin-headline">
    <div class="container origin__inner">
      <div class="origin__copy-block" data-reveal>
        <h2 class="origin__headline" id="origin-headline">{origin.headline}</h2>
        <div class="origin__copy">
          {origin.paragraphs.map((p) => <p>{p}</p>)}
        </div>
      </div>

      <aside
        class="decision-frame"
        data-reveal
        data-spotlight
        style="--reveal-delay: 120ms"
        aria-labelledby="decision-frame-headline"
      >
        <p class="decision-frame__kicker">{decisionFrame.kicker}</p>
        <h3 class="decision-frame__headline" id="decision-frame-headline">{decisionFrame.headline}</h3>
        <p class="decision-frame__body">{decisionFrame.body}</p>

        <div class="decision-frame__map" aria-hidden="true">
          <div class="decision-frame__artifact">{decisionFrame.artifact}</div>
          <div class="decision-frame__orbit">
            {decisionFrame.signals.map((signal, i) => <span style={`--signal-index: ${i}`}>{signal}</span>)}
          </div>
        </div>
      </aside>
    </div>
  </section>

  <!-- §5.4 #2 - the model: three engines feed the seat -->
  <section class="model" aria-labelledby="model-headline">
    <div class="container">
      <header class="section-head" data-reveal>
        <p class="section-head__kicker">The model</p>
        <h2 class="section-head__headline" id="model-headline">{model.headline}</h2>
        <p class="section-head__lede">{model.body}</p>
      </header>
      <div class="model__surface" data-reveal data-spotlight style="--reveal-delay: 120ms">
        <div class="model__rail" aria-hidden="true">
          <span>Product</span>
          <span>Behavior</span>
          <span>Data</span>
          <span>Market</span>
        </div>
        <EngineDiagram caption={model.diagramCaption} />
      </div>
    </div>
  </section>

  <!-- Enhancement spec: no public timing commitments. -->
  <section class="system" aria-labelledby="system-headline">
    <div class="container">
      <header class="section-head" data-reveal>
        <p class="section-head__kicker">Working together</p>
        <h2 class="section-head__headline" id="system-headline">{operatingSystem.headline}</h2>
        <p class="section-head__lede">{operatingSystem.lede}</p>
      </header>

      <div class="system__stage" data-reveal data-spotlight style="--reveal-delay: 120ms">
        <div class="system-visual" aria-hidden="true">
          <span class="system-visual__aura system-visual__aura--one"></span>
          <span class="system-visual__aura system-visual__aura--two"></span>
          <span class="system-visual__line system-visual__line--one"></span>
          <span class="system-visual__line system-visual__line--two"></span>
          <span class="system-visual__float system-visual__float--product">
            <span></span>
            <span></span>
            <span></span>
          </span>
          <span class="system-visual__float system-visual__float--tech">
            <span></span>
            <span></span>
          </span>
          <span class="system-visual__float system-visual__float--analytics">
            <span></span>
            <span></span>
            <span></span>
          </span>
          <span class="system-visual__node system-visual__node--one"></span>
          <span class="system-visual__node system-visual__node--two"></span>
          <span class="system-visual__node system-visual__node--three"></span>
        </div>

        <div class="system__story">
          {
            operatingSystem.parts.map((part, i) => (
              <article class="system-text" style={`--reveal-delay: ${220 + i * 80}ms`}>
                <p class="system-text__number">0{i + 1}</p>
                <div>
                  <p class="system-text__kicker">{part.kicker}</p>
                  <h3 class="system-text__name">{part.name}</h3>
                  <p class="system-text__body">{part.body}</p>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- §5.4 #4 - Advisory Circle: built, shipped dark until MOUs (§4). -->
  {siteConfig.flags.showNetwork && <AdvisoryCircle />}
</Base>

<style>
  .origin {
    padding-block: clamp(2rem, 6vw, 5rem) var(--section-pad);
  }

  .origin__inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 0.92fr);
    gap: clamp(1.5rem, 4vw, 4rem);
    align-items: center;
  }

  @media (max-width: 860px) {
    .origin__inner {
      grid-template-columns: 1fr;
    }
  }

  .origin__headline {
    font-size: clamp(2rem, 4.2vw, 3.25rem);
    margin-block-end: clamp(1rem, 2vw, 1.5rem);
  }

  .origin__copy p {
    color: var(--graphite);
    font-size: clamp(1.05rem, 1.6vw, 1.2rem);
  }

  .origin__copy p:last-child {
    color: var(--ink);
    margin-block-end: 0;
  }

  .decision-frame,
  .model__surface,
  .system__stage {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
    isolation: isolate;
  }

  .decision-frame {
    padding: clamp(1.5rem, 3vw, 2.4rem);
    min-block-size: clamp(420px, 44vw, 540px);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    background:
      radial-gradient(
        420px circle at 78% 18%,
        color-mix(in srgb, var(--signal) 15%, transparent),
        transparent 62%
      ),
      linear-gradient(
        145deg,
        var(--surface) 0%,
        var(--glass-hi) 52%,
        color-mix(in srgb, var(--glass-lo) 34%, var(--glass-hi)) 100%
      );
  }

  .decision-frame::after,
  .model__surface::after,
  .system__stage::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    background: radial-gradient(
      320px circle at var(--spot-x, 50%) var(--spot-y, 50%),
      color-mix(in srgb, var(--spotlight) 18%, transparent),
      transparent 70%
    );
    filter: hue-rotate(30deg) saturate(1.22);
    opacity: var(--spot-o, 0);
    transition: opacity 0.6s var(--ease-luxe);
  }

  .decision-frame__kicker,
  .system-text__kicker {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--signal-text);
    margin-block-end: 0.65rem;
  }

  .decision-frame__headline {
    font-size: clamp(1.55rem, 3vw, 2.15rem);
    max-inline-size: 11ch;
    margin-block-end: 0.75rem;
  }

  .decision-frame__body {
    max-inline-size: 34ch;
    color: var(--graphite);
    margin: 0;
  }

  .decision-frame__map {
    position: relative;
    display: grid;
    place-items: center;
    inline-size: min(100%, 430px);
    aspect-ratio: 1;
    margin-inline: auto;
    margin-block-start: clamp(2rem, 6vw, 4rem);
  }

  .decision-frame__map::before,
  .decision-frame__map::after {
    content: '';
    position: absolute;
    inset: 13%;
    border: 1px solid color-mix(in srgb, var(--signal) 18%, transparent);
    border-radius: 999px;
    pointer-events: none;
  }

  .decision-frame__map::after {
    inset: 25%;
    border-color: color-mix(in srgb, var(--glass-lo) 32%, transparent);
    background:
      radial-gradient(
        circle at 50% 50%,
        color-mix(in srgb, var(--surface) 62%, transparent),
        transparent 58%
      );
  }

  .decision-frame__orbit {
    position: absolute;
    inset: 0;
    border-radius: 999px;
  }

  .decision-frame__orbit span {
    position: absolute;
    display: flex;
    align-items: center;
    justify-content: center;
    inline-size: clamp(8.6rem, 36vw, 11.2rem);
    min-block-size: 2.55rem;
    padding-inline: 0.8rem;
    border: 1px solid color-mix(in srgb, var(--signal) 18%, var(--hairline));
    border-radius: 999px;
    background: color-mix(in srgb, var(--surface) 74%, transparent);
    -webkit-backdrop-filter: blur(12px) saturate(130%);
    backdrop-filter: blur(12px) saturate(130%);
    color: var(--ink);
    font-weight: 600;
    font-size: clamp(0.78rem, 1.5vw, 0.9rem);
    line-height: 1.2;
    text-align: center;
    box-shadow:
      0 14px 32px color-mix(in srgb, var(--ink) 7%, transparent),
      inset 0 1px 0 color-mix(in srgb, white 56%, transparent);
  }

  .decision-frame__orbit span::after {
    content: '';
    position: absolute;
    inset: -0.45rem;
    border-radius: inherit;
    border: 1px solid color-mix(in srgb, var(--signal) 10%, transparent);
    opacity: 0.62;
    pointer-events: none;
  }

  .decision-frame__orbit span:nth-child(1) {
    inset-inline-start: 50%;
    inset-block-start: 0;
    transform: translate(-50%, 0);
  }

  .decision-frame__orbit span:nth-child(2) {
    inset-inline-end: 0;
    inset-block-start: 50%;
    transform: translate(0, -50%);
  }

  .decision-frame__orbit span:nth-child(3) {
    inset-inline-start: 50%;
    inset-block-end: 0;
    transform: translate(-50%, 0);
  }

  .decision-frame__orbit span:nth-child(4) {
    inset-inline-start: 0;
    inset-block-start: 50%;
    transform: translate(0, -50%);
  }

  .decision-frame__artifact {
    position: relative;
    z-index: 2;
    display: grid;
    place-items: center;
    inline-size: clamp(7rem, 18vw, 9rem);
    aspect-ratio: 1;
    border-radius: 999px;
    background: var(--ink-surface);
    color: var(--on-ink);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    text-transform: uppercase;
    box-shadow:
      0 22px 54px rgba(16, 24, 40, 0.24),
      0 0 0 12px color-mix(in srgb, var(--signal) 8%, transparent),
      inset 0 0 0 1px color-mix(in srgb, var(--speed-from) 22%, transparent);
  }

  .model {
    background: var(--surface-2);
    padding-block: var(--section-pad);
  }

  .model__surface {
    padding: clamp(1.25rem, 3vw, 2.5rem);
    background:
      radial-gradient(
        460px circle at 72% 20%,
        color-mix(in srgb, var(--signal) 10%, transparent),
        transparent 64%
      ),
      linear-gradient(145deg, var(--surface) 0%, var(--surface-2) 100%);
  }

  .model__rail {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-block-end: clamp(1.5rem, 3vw, 2.4rem);
  }

  .model__rail span {
    padding: 0.45rem 0.7rem;
    border: 1px solid var(--hairline);
    border-radius: 999px;
    color: var(--graphite);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
  }

  .system {
    padding-block: var(--section-pad);
  }

  .system__stage {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(360px, 1.05fr);
    gap: clamp(2rem, 5vw, 5rem);
    align-items: center;
    padding: clamp(1.3rem, 3.8vw, 3.5rem);
    background:
      radial-gradient(
        620px circle at 24% 16%,
        color-mix(in srgb, var(--signal) 13%, transparent),
        transparent 64%
      ),
      linear-gradient(145deg, var(--surface) 0%, var(--surface-2) 100%);
  }

  @media (max-width: 1100px) {
    .system__stage {
      grid-template-columns: 1fr;
    }
  }

  .system-visual {
    position: relative;
    min-block-size: clamp(360px, 42vw, 520px);
    border-radius: calc(var(--radius-card) + 8px);
    background:
      radial-gradient(
        360px circle at 68% 24%,
        color-mix(in srgb, var(--signal) 18%, transparent),
        transparent 60%
      ),
      linear-gradient(
        145deg,
        color-mix(in srgb, var(--surface) 78%, transparent),
        color-mix(in srgb, var(--glass-hi) 64%, transparent)
      );
    overflow: hidden;
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, white 55%, transparent),
      0 28px 80px color-mix(in srgb, var(--ink) 9%, transparent);
  }

  .system-visual::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 24% 24%, color-mix(in srgb, white 22%, transparent), transparent 32%),
      linear-gradient(120deg, transparent, color-mix(in srgb, white 24%, transparent), transparent);
    opacity: 0.68;
    -webkit-backdrop-filter: blur(10px) saturate(120%);
    backdrop-filter: blur(10px) saturate(120%);
  }

  .system-visual__aura,
  .system-visual__line,
  .system-visual__float,
  .system-visual__node {
    position: absolute;
    display: block;
  }

  .system-visual__aura {
    border-radius: 999px;
    filter: blur(32px);
    opacity: 0.58;
  }

  .system-visual__aura--one {
    inline-size: 320px;
    block-size: 210px;
    inset-inline-start: 10%;
    inset-block-start: 18%;
    background: color-mix(in srgb, var(--glass-lo) 48%, transparent);
  }

  .system-visual__aura--two {
    inline-size: 280px;
    block-size: 240px;
    inset-inline-end: 4%;
    inset-block-end: 10%;
    background: color-mix(in srgb, var(--signal) 28%, transparent);
  }

  .system-visual__line {
    block-size: 1px;
    border-radius: 999px;
    background: linear-gradient(
      90deg,
      transparent,
      color-mix(in srgb, var(--signal) 48%, transparent),
      transparent
    );
    opacity: 0.54;
    transform-origin: center;
  }

  .system-visual__line--one {
    inline-size: 72%;
    inset-inline-start: 12%;
    inset-block-start: 43%;
    transform: rotate(-9deg);
  }

  .system-visual__line--two {
    inline-size: 66%;
    inset-inline-start: 18%;
    inset-block-start: 60%;
    transform: rotate(8deg);
  }

  .system-visual__float {
    z-index: 1;
    border: 1px solid color-mix(in srgb, var(--signal) 16%, var(--hairline));
    border-radius: 22px;
    background:
      linear-gradient(
        145deg,
        color-mix(in srgb, var(--surface) 78%, transparent),
        color-mix(in srgb, var(--glass-hi) 44%, transparent)
      );
    -webkit-backdrop-filter: blur(12px) saturate(135%);
    backdrop-filter: blur(12px) saturate(135%);
    box-shadow:
      0 24px 58px color-mix(in srgb, var(--ink) 10%, transparent),
      inset 0 1px 0 color-mix(in srgb, white 56%, transparent);
  }

  .system-visual__float span {
    position: absolute;
    display: block;
    border-radius: 999px;
    background: color-mix(in srgb, var(--glass-lo) 70%, transparent);
  }

  .system-visual__float--product {
    inline-size: clamp(190px, 19vw, 250px);
    block-size: clamp(124px, 12vw, 160px);
    inset-inline-start: 9%;
    inset-block-start: 18%;
    transform: rotate(-7deg);
  }

  .system-visual__float--product span:nth-child(1) {
    inline-size: 56%;
    block-size: 5px;
    inset-inline-start: 16%;
    inset-block-start: 28%;
  }

  .system-visual__float--product span:nth-child(2) {
    inline-size: 42%;
    block-size: 5px;
    inset-inline-start: 16%;
    inset-block-start: 48%;
  }

  .system-visual__float--product span:nth-child(3) {
    inline-size: 24%;
    block-size: 5px;
    inset-inline-start: 16%;
    inset-block-start: 68%;
    background: var(--signal);
  }

  .system-visual__float--tech {
    inline-size: clamp(106px, 11vw, 142px);
    block-size: clamp(160px, 16vw, 210px);
    inset-inline-end: 14%;
    inset-block-start: 15%;
    transform: rotate(6deg);
  }

  .system-visual__float--tech span:nth-child(1) {
    inline-size: 54%;
    block-size: 4px;
    inset-inline-start: 22%;
    inset-block-start: 34%;
  }

  .system-visual__float--tech span:nth-child(2) {
    inline-size: 36%;
    block-size: 4px;
    inset-inline-start: 22%;
    inset-block-start: 54%;
    background: var(--signal);
  }

  .system-visual__float--analytics {
    inline-size: clamp(170px, 17vw, 225px);
    block-size: clamp(118px, 12vw, 154px);
    inset-inline-start: 38%;
    inset-block-end: 15%;
    transform: rotate(4deg);
  }

  .system-visual__float--analytics span {
    inset-block-end: 16%;
    inline-size: 8px;
    border-radius: 999px 999px 0 0;
  }

  .system-visual__float--analytics span:nth-child(1) {
    inset-inline-start: 23%;
    block-size: 30%;
  }

  .system-visual__float--analytics span:nth-child(2) {
    inset-inline-start: 48%;
    block-size: 52%;
  }

  .system-visual__float--analytics span:nth-child(3) {
    inset-inline-start: 72%;
    block-size: 68%;
    background: var(--signal);
  }

  .system-visual__node {
    z-index: 2;
    inline-size: 13px;
    block-size: 13px;
    border-radius: 999px;
    background: var(--signal);
    box-shadow: 0 0 0 8px color-mix(in srgb, var(--signal) 12%, transparent);
  }

  .system-visual__node--one {
    inset-inline-start: 47%;
    inset-block-start: 39%;
  }

  .system-visual__node--two {
    inset-inline-end: 30%;
    inset-block-end: 25%;
    opacity: 0.72;
  }

  .system-visual__node--three {
    inset-inline-start: 20%;
    inset-block-end: 24%;
    opacity: 0.62;
  }

  .system__story {
    display: grid;
    gap: clamp(1.1rem, 2vw, 1.5rem);
  }

  .system-text {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: clamp(1rem, 2vw, 1.5rem);
    padding-block-end: clamp(1.1rem, 2vw, 1.5rem);
    border-block-end: 1px solid color-mix(in srgb, var(--hairline) 78%, transparent);
  }

  .system-text:last-child {
    padding-block-end: 0;
    border-block-end: 0;
  }

  .system-text__number {
    font-family: var(--font-mono);
    color: var(--graphite);
    margin: 0;
  }

  .system-text__name {
    font-size: clamp(1.45rem, 2.2vw, 2rem);
    margin-block-end: 0.55rem;
  }

  .system-text__body {
    color: var(--graphite);
    margin: 0;
  }

  @media (prefers-reduced-motion: no-preference) {
    .decision-frame,
    .model__surface,
    .system__stage {
      transition:
        transform var(--dur-hover) var(--ease-luxe),
        box-shadow var(--dur-hover) var(--ease-luxe);
    }

    .decision-frame:hover,
    .model__surface:hover,
    .system__stage:hover {
      transform: translateY(-6px);
    }

    .decision-frame__orbit {
      animation: decision-orbit 28s linear infinite;
    }

    .decision-frame__orbit span:nth-child(1) {
      animation: decision-counter-orbit-top 28s linear infinite;
    }

    .decision-frame__orbit span:nth-child(2) {
      animation: decision-counter-orbit-right 28s linear infinite;
    }

    .decision-frame__orbit span:nth-child(3) {
      animation: decision-counter-orbit-bottom 28s linear infinite;
    }

    .decision-frame__orbit span:nth-child(4) {
      animation: decision-counter-orbit-left 28s linear infinite;
    }

    .decision-frame__map::before {
      animation: decision-ring 7s var(--ease-luxe) infinite;
    }

    :global(.js) [data-reveal]:not(.in) .decision-frame__orbit span:nth-child(1) {
      opacity: 0;
      transform: translate(-50%, 0) scale(0.92);
    }

    :global(.js) [data-reveal]:not(.in) .decision-frame__orbit span:nth-child(2) {
      opacity: 0;
      transform: translate(0, -50%) scale(0.92);
    }

    :global(.js) [data-reveal]:not(.in) .decision-frame__orbit span:nth-child(3) {
      opacity: 0;
      transform: translate(-50%, 0) scale(0.92);
    }

    :global(.js) [data-reveal]:not(.in) .decision-frame__orbit span:nth-child(4) {
      opacity: 0;
      transform: translate(0, -50%) scale(0.92);
    }

    :global(.js) [data-reveal].in .decision-frame__orbit span {
      transition:
        opacity 900ms var(--ease-luxe),
        transform 900ms var(--ease-luxe);
      transition-delay: calc(160ms + var(--signal-index) * 90ms);
    }
  }

  @keyframes decision-orbit {
    to {
      transform: rotate(360deg);
    }
  }

  @keyframes decision-counter-orbit-top {
    to {
      transform: translate(-50%, 0) rotate(-360deg);
    }
  }

  @keyframes decision-counter-orbit-right {
    to {
      transform: translate(0, -50%) rotate(-360deg);
    }
  }

  @keyframes decision-counter-orbit-bottom {
    to {
      transform: translate(-50%, 0) rotate(-360deg);
    }
  }

  @keyframes decision-counter-orbit-left {
    to {
      transform: translate(0, -50%) rotate(-360deg);
    }
  }

  @keyframes decision-ring {
    0%,
    100% {
      transform: scale(1);
      opacity: 0.78;
    }

    50% {
      transform: scale(1.05);
      opacity: 1;
    }
  }

  @media (max-width: 720px) {
    .origin {
      padding-block-start: 1.5rem;
    }

    .decision-frame {
      min-block-size: auto;
    }

    .decision-frame__headline {
      max-inline-size: 12ch;
    }

    .decision-frame__map {
      inline-size: min(100%, 340px);
      margin-block-start: 2.5rem;
    }

    .decision-frame__artifact {
      inline-size: 6.2rem;
    }

    .decision-frame__orbit span {
      inline-size: 8.2rem;
      min-block-size: 2.35rem;
      font-size: 0.74rem;
    }

    .model__surface {
      padding: 1rem;
    }

    .system__stage {
      padding: 1rem;
      gap: 1.5rem;
    }

    .system-visual {
      min-block-size: 310px;
    }

    .system-visual__float--product {
      inline-size: 168px;
      block-size: 112px;
      inset-inline-start: 4%;
    }

    .system-visual__float--tech {
      inline-size: 94px;
      block-size: 142px;
      inset-inline-end: 5%;
    }

