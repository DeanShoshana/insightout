---
import Base from '../layouts/Base.astro';
import PageIntro from '../components/PageIntro.astro';
import ServiceVisual, { type ServiceVisualVariant } from '../components/ServiceVisual.astro';
import { industries } from '../content/industries';
import { services } from '../content/services';
import { withBase } from '../lib/url';

const { intro, items, closing } = industries;
const serviceNav = services.pillars.map(({ id, navLabel }) => ({ id, navLabel }));
const visualMap: Record<(typeof items)[number]['visual'], ServiceVisualVariant> = {
  product: 'product',
  behavior: 'behavior',
  data: 'data',
  market: 'market',
};
const signalCards = [
  { label: 'Product reality', body: 'Concept, requirements, prototype, and production-ready direction.' },
  { label: 'Behavioral signal', body: 'HCI in action: journeys, patterns, friction - all the way to conversion.' },
  { label: 'Research & Analytics', body: 'Not dashboards - insights: from BI KPIs to board reporting.' },
  { label: 'Market superiority', body: 'From data-backed penetration to nailing the GTM.' },
  { label: 'Business decision', body: 'Where business strategy meets market reality.' },
];
---

<Base
  title="Industries"
  description="Technology, e-commerce & retail, and brands & CPG - framed as the problems each industry brings to the table."
>
  <!-- DRAFT COPY - Industries (SPEC §5.3): problem statements, engaged
       pillars, representative questions. No logos, no client grids. -->
  <PageIntro kicker={intro.kicker} headline={intro.headline} lede={intro.lede} />

  <nav class="subnav" aria-label="Service practices">
    <div class="container subnav__inner">
      <ul>
        {
          serviceNav.map((p) => (
            <li>
              <a class="subnav__link" href={withBase(`/services#${p.id}`)}>
                {p.navLabel}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </nav>

  <div class="industries">
    <div class="industries__signal" data-reveal aria-label="Evidence signals Claritix connects across industries">
      <div class="industries__signal-glow" aria-hidden="true"></div>
      <div class="industries__signal-track">
        {[0, 1].map((setIndex) => (
          <div class="industries__signal-set" aria-hidden={setIndex === 1 ? 'true' : undefined}>
            {signalCards.map((card, i) => (
              <article class="signal-card" style={`--signal-card-index: ${i}`}>
                <div class="signal-card__meta">
                  <span>{String(i + 1).padStart(2, '0')}</span>
                  <p>{card.label}</p>
                </div>
                <span>{card.body}</span>
              </article>
            ))}
          </div>
        ))}
      </div>
    </div>

    <div class="container">
      {
        items.map((item, i) => (
          <article class="industry" data-reveal data-spotlight style={`--reveal-delay: ${i * 80}ms`}>
            <div class="industry__visual" aria-hidden="true">
              <ServiceVisual variant={visualMap[item.visual]} size="feature" />
            </div>

            <div class="industry__story">
              <h2 class="industry__label">{item.label}</h2>
              <p class="industry__entry">{item.entry}</p>
              <p class="industry__problem">{item.problem}</p>
            </div>

            <div class="industry__detail">
              <p class="industry__detail-label">Representative question</p>
              <p class="industry__question">“{item.question}”</p>

              <p class="industry__detail-label">Added value</p>
              <p class="industry__value">{item.value}</p>

              <p class="industry__pillars-label">Typically engages</p>
              <ul class="industry__pillars">
                {item.pillars.map((p) => (
                  <li>
                    <a href={withBase(p.anchor)}>{p.label}</a>
                  </li>
                ))}
              </ul>

              <a class="industry__cta" href={withBase(item.cta.anchor)}>
                {item.cta.label}
                <span aria-hidden="true">→</span>
              </a>
            </div>
          </article>
        ))
      }

      <aside class="industries__closing" data-reveal>
        <p>{closing}</p>
        <a href={withBase('/services#product')}>
          See how the services connect
          <span aria-hidden="true">→</span>
        </a>
      </aside>
    </div>
  </div>
</Base>

<style>
  .industries {
    padding-block: 0 var(--section-pad);
  }

  .subnav {
    position: sticky;
    inset-block-start: 68px;
    z-index: calc(var(--z-nav) - 1);
    background: color-mix(in srgb, var(--surface) 85%, transparent);
    -webkit-backdrop-filter: saturate(180%) blur(12px);
    backdrop-filter: saturate(180%) blur(12px);
    border-block: 1px solid var(--hairline);
  }

  .subnav__inner ul {
    display: flex;
    gap: clamp(1.25rem, 3vw, 2.5rem);
    list-style: none;
    margin: 0;
    padding: 0;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .subnav__link {
    display: inline-block;
    padding-block: 0.85rem;
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--graphite);
    white-space: nowrap;
    border-block-end: 2px solid transparent;
    transition:
      color var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out);
  }

  .subnav__link:hover {
    color: var(--ink);
    border-block-end-color: var(--signal);
  }

  .industries__signal {
    position: relative;
    margin-block: clamp(0.75rem, 2vw, 1.75rem) clamp(2.75rem, 5vw, 4.5rem);
    padding-block: clamp(1.1rem, 3vw, 1.65rem);
    overflow: hidden;
    background:
      linear-gradient(
        90deg,
        color-mix(in srgb, var(--surface) 0%, transparent),
        color-mix(in srgb, var(--surface-2) 72%, transparent) 16%,
        color-mix(in srgb, var(--surface-2) 72%, transparent) 84%,
        color-mix(in srgb, var(--surface) 0%, transparent)
      );
    border-block: 1px solid color-mix(in srgb, var(--hairline) 76%, transparent);
    isolation: isolate;
  }

  .industries__signal::before,
  .industries__signal::after {
    content: '';
    position: absolute;
    inset-block: 0;
    z-index: 2;
    inline-size: clamp(2.5rem, 10vw, 9rem);
    pointer-events: none;
  }

  .industries__signal::before {
    inset-inline-start: 0;
    background: linear-gradient(90deg, var(--surface), transparent);
  }

  .industries__signal::after {
    inset-inline-end: 0;
    background: linear-gradient(270deg, var(--surface), transparent);
  }

  .industries__signal-glow {
    position: absolute;
    inset: 1px 0 auto;
    block-size: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      color-mix(in srgb, var(--signal) 45%, transparent),
      transparent
    );
    opacity: 0.85;
  }

  .industries__signal-track {
    display: flex;
    inline-size: max-content;
    gap: 0;
  }

  .industries__signal-set {
    display: flex;
    align-items: stretch;
    gap: clamp(0.9rem, 2vw, 1.25rem);
    padding-inline-end: clamp(0.9rem, 2vw, 1.25rem);
  }

  .signal-card {
    position: relative;
    flex: 0 0 clamp(260px, 27vw, 390px);
    min-block-size: 156px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 1.4rem;
    padding: clamp(1.1rem, 2vw, 1.35rem);
    border-radius: calc(var(--radius-card) + 2px);
    background:
      radial-gradient(
        220px circle at 78% 14%,
        color-mix(in srgb, var(--signal) 14%, transparent),
        transparent 64%
      ),
      linear-gradient(
        150deg,
        color-mix(in srgb, var(--surface) 96%, var(--glass-hi)) 0%,
        color-mix(in srgb, var(--glass-hi) 58%, var(--surface)) 58%,
        color-mix(in srgb, var(--glass-lo) 30%, var(--glass-hi)) 100%
      );
    box-shadow:
      0 20px 60px color-mix(in srgb, var(--ink) 8%, transparent),
      inset 0 1px 0 color-mix(in srgb, white 72%, transparent);
    overflow: hidden;
  }

  .signal-card::before {
    content: '';
    position: absolute;
    inset-inline: clamp(1.1rem, 2vw, 1.35rem);
    inset-block-start: 50%;
    block-size: 1px;
    background: linear-gradient(
      90deg,
      color-mix(in srgb, var(--signal) 12%, transparent),
      color-mix(in srgb, var(--signal) 68%, transparent),
      color-mix(in srgb, var(--signal) 12%, transparent)
    );
    opacity: 0.45;
  }

  .signal-card::after {
    content: '';
    position: absolute;
    inset-block-start: calc(50% - 4px);
    inset-inline-start: clamp(1.1rem, 2vw, 1.35rem);
    inline-size: 9px;
    block-size: 9px;
    border-radius: 999px;
    background: var(--signal);
    box-shadow: 0 0 0 7px color-mix(in srgb, var(--signal) 14%, transparent);
  }

  .signal-card__meta {
    display: flex;
    align-items: baseline;
    gap: 0.7rem;
  }

  .signal-card__meta span {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: color-mix(in srgb, var(--signal-text) 70%, var(--graphite));
  }

  .signal-card p {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--signal-text);
    margin: 0;
  }

  .signal-card > span {
    display: block;
    color: var(--ink);
    font-weight: 650;
    line-height: 1.35;
    max-inline-size: 19rem;
  }

  @media (prefers-reduced-motion: no-preference) {
    .industries__signal-track {
      animation: industries-signal 38s linear infinite;
      will-change: transform;
    }

    .industries__signal:hover .industries__signal-track {
      animation-play-state: paused;
    }

    .signal-card::after {
      animation: signal-node 3.8s var(--ease-luxe) infinite;
      animation-delay: calc(var(--signal-card-index) * 180ms);
    }
  }

  @keyframes industries-signal {
    to {
      transform: translate3d(-50%, 0, 0);
    }
  }

  @keyframes signal-node {
    0%,
    48%,
    100% {
      transform: translate3d(0, 0, 0) scale(1);
      opacity: 0.72;
    }

    18% {
      transform: translate3d(calc(100% + 15rem), 0, 0) scale(1.08);
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .industries__signal {
      overflow-x: auto;
    }

    .industries__signal::before,
    .industries__signal::after {
      display: none;
    }

    .industries__signal-track {
      padding-inline: var(--gutter);
    }
  }

  [data-theme='dark'] .industries__signal {
    background:
      linear-gradient(
        90deg,
        transparent,
        color-mix(in srgb, var(--surface-2) 70%, transparent) 18%,
        color-mix(in srgb, var(--surface-2) 70%, transparent) 82%,
        transparent
      );
  }

  [data-theme='dark'] .signal-card {
    background:
      radial-gradient(
        260px circle at 78% 14%,
        color-mix(in srgb, var(--signal) 22%, transparent),
        transparent 66%
      ),
      linear-gradient(
        150deg,
        color-mix(in srgb, var(--surface) 88%, var(--ink)) 0%,
        color-mix(in srgb, var(--surface-2) 82%, var(--glass-hi)) 100%
      );
    box-shadow:
      0 24px 72px color-mix(in srgb, black 34%, transparent),
      inset 0 1px 0 color-mix(in srgb, white 9%, transparent);
  }

  .industry {
    position: relative;
    display: grid;
    grid-template-columns: minmax(210px, 0.72fr) minmax(0, 1fr) minmax(290px, 0.9fr);
    gap: clamp(1.5rem, 4vw, 4rem);
    align-items: center;
    margin-block-end: clamp(1.25rem, 3vw, 2rem);
    padding: clamp(1.25rem, 3vw, 2rem);
    border-radius: var(--radius-card);
    background:
      radial-gradient(
        420px circle at var(--spot-x, 72%) var(--spot-y, 18%),
        color-mix(in srgb, var(--spotlight) 14%, transparent),
        transparent 64%
      ),
      var(--surface);
    box-shadow: var(--shadow-card);
    overflow: hidden;
    transition:
      transform var(--dur-hover) var(--ease-luxe),
      box-shadow var(--dur-hover) var(--ease-luxe);
  }

  .industry:hover {
    box-shadow: var(--shadow-card-hover);
  }

  .industry::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    border-radius: inherit;
    background: radial-gradient(
      360px circle at var(--spot-x, 50%) var(--spot-y, 50%),
      color-mix(in srgb, var(--spotlight) 14%, transparent),
      transparent 70%
    );
    filter: hue-rotate(26deg) saturate(1.12);
    opacity: var(--spot-o, 0);
    transition: opacity 0.6s var(--ease-luxe);
  }

  .industry__visual {
    position: relative;
    display: grid;
    place-items: center;
    aspect-ratio: 1.08;
    border-radius: calc(var(--radius-card) - 4px);
    background:
      radial-gradient(
        260px circle at 68% 22%,
        color-mix(in srgb, var(--signal) 15%, transparent),
        transparent 62%
      ),
      linear-gradient(
        150deg,
        var(--surface) 0%,
        var(--glass-hi) 58%,
        color-mix(in srgb, var(--glass-lo) 34%, var(--glass-hi)) 100%
      );
    overflow: hidden;
  }

  .industry__visual :global(.service-visual) {
    inline-size: min(86%, 320px);
  }

  @media (max-width: 860px) {
    .industry {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .industry__visual {
      max-inline-size: 340px;
      inline-size: 100%;
      margin-inline: auto;
    }
  }

  .industry__label {
    font-size: clamp(1.8rem, 3.4vw, 2.65rem);
    margin-block-end: 0.75rem;
  }

  .industry__entry {
    font-weight: 600;
    color: var(--ink);
    margin-block-end: 1rem;
  }

  .industry__problem {
    color: var(--graphite);
    font-size: 1.05rem;
    margin: 0;
  }

  .industry__detail {
    position: relative;
    z-index: 1;
    padding-inline-start: clamp(0rem, 2vw, 1.25rem);
    border-inline-start: 1px solid var(--hairline);
  }

  .industry__detail-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--graphite);
    margin-block: 0 0.35rem;
  }

  .industry__question {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    color: var(--signal-text);
    max-inline-size: 24rem;
    margin-block: 0 1.35rem;
  }

  .industry__value {
    color: var(--graphite);
    font-size: 0.98rem;
    margin-block-end: 1.5rem;
  }

  .industry__pillars-label {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--graphite);
    margin-block-end: 0.5rem;
  }

  .industry__pillars {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 0.75rem;
    margin: 0;
    padding: 0;
  }

  .industry__pillars a {
    display: inline-block;
    font-size: 0.9rem;
    font-weight: 500;
    padding: 0.35rem 0.8rem;
    border: 1px solid var(--hairline);
    border-radius: 999px;
    background: var(--surface);
    transition:
      border-color var(--dur-fast) var(--ease-out),
      transform var(--dur-fast) var(--ease-out);
  }

  .industry__pillars a:hover {
    border-color: var(--signal);
    transform: translateY(-1px);
  }

  .industry__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-block-start: 1.5rem;
    font-weight: 700;
  }

  .industry__cta span {
    transition: transform var(--dur-fast) var(--ease-out);
  }

  .industry__cta:hover span {
    transform: translateX(3px);
  }

  .industries__closing {
    max-inline-size: 52rem;
    margin-block-start: clamp(2rem, 5vw, 4rem);
    padding: clamp(1.6rem, 4vw, 2.4rem);
    border-radius: var(--radius-card);
    background:
      radial-gradient(
        360px circle at 82% 16%,
        color-mix(in srgb, var(--signal) 12%, transparent),
        transparent 62%
      ),
      var(--surface-2);
    box-shadow: var(--shadow-card);
  }

  .industries__closing p {
    font-size: clamp(1.2rem, 2.4vw, 1.6rem);
    font-weight: 600;
    line-height: 1.35;
    letter-spacing: var(--tracking-display);
    margin-block-end: 1rem;
  }

  .industries__closing a {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-weight: 600;
  }

  .industries__closing span {
    transition: transform var(--dur-fast) var(--ease-out);
  }

  .industries__closing a:hover span {
    transform: translateX(3px);
  }

  @media (prefers-reduced-motion: no-preference) {
    .industry:hover {
      transform: translateY(-6px);
    }
  }

  @media (max-width: 720px) {
    .signal-card::before {
      inset-block-start: 44%;
    }

    .signal-card::after {
      inset-block-start: calc(44% - 4px);
    }

    .industry {
      padding: 1rem;
    }

    .industry__detail {
      padding-inline-start: 0;
      border-inline-start: 0;
      border-block-start: 1px solid var(--hairline);
      padding-block-start: 1rem;
    }

    .industry__visual {
      max-inline-size: 310px;
    }

    .industry__label {
      font-size: clamp(1.9rem, 9vw, 2.35rem);
    }

    .industry__problem,
    .industry__value {
      font-size: 1rem;
      line-height: 1.55;
    }

    .industries__closing {
      padding: 1.25rem;
    }
  }
</style>
