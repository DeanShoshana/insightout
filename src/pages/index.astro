---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import PillarCard from '../components/PillarCard.astro';
import EngineDiagram from '../components/EngineDiagram.astro';
import IndustryBlock from '../components/IndustryBlock.astro';
import ContactCTA from '../components/ContactCTA.astro';
import ServiceVisual from '../components/ServiceVisual.astro';
import { home } from '../content/home';
import { withBase } from '../lib/url';
---

<Base>
  <!-- §5.1 #1 - Hero -->
  <Hero />

  <!-- §5.1 #2 - Problem framing. DRAFT COPY -->
  <section class="problem">
    <div class="container problem__inner">
      <div class="problem__copy" data-reveal>
        <h2 class="visually-hidden">The problem</h2>
        <p class="problem__statement">{home.problem.statement}</p>
      </div>

      <aside
        class="problem__product"
        data-reveal
        data-spotlight
        style="--reveal-delay: 120ms"
        aria-labelledby="problem-product-headline"
      >
        <div class="problem__visual" aria-hidden="true">
          <div class="product-stage">
            <div class="product-stage__screen product-stage__screen--desktop">
              <span></span>
              <span></span>
              <span></span>
            </div>
            <div class="product-stage__screen product-stage__screen--mobile">
              <span></span>
              <span></span>
            </div>
            <div class="product-stage__rail">
              <span></span>
              <span></span>
              <span></span>
            </div>
            <div class="product-stage__chip product-stage__chip--one">Concept</div>
            <div class="product-stage__chip product-stage__chip--two">Prototype</div>
            <div class="product-stage__chip product-stage__chip--three">Evidence</div>
            <ServiceVisual variant="product" size="card" />
          </div>
        </div>
        <p class="problem__kicker">Product reality</p>
        <h3 id="problem-product-headline">From question to buildable direction.</h3>
        <ul>
          <li>Product characterization</li>
          <li>Mockups and user flows</li>
          <li>Requirements and measurement logic</li>
        </ul>
      </aside>
    </div>
  </section>

  <!-- §5.1 #3 - Outcome-first services narrative. Leads with Pillar 4's
       outcome; the three engines follow as "how that gets built". DRAFT COPY -->
  <section class="services">
    <div class="container">
      <header class="services__header" data-reveal>
        <div class="section-head">
          <p class="section-head__kicker">{home.services.kicker}</p>
          <h2 class="section-head__headline">{home.services.headline}</h2>
          <p class="section-head__lede">{home.services.lede}</p>
        </div>
        <div class="services__artifact" aria-hidden="true">
          <span>Product</span>
          <span>Analytics</span>
          <span>Market</span>
          <strong>Decision</strong>
        </div>
      </header>

      <div class="services__seat-shell">
        <PillarCard
          variant="seat"
          motif="streams"
          pillar={home.services.seat.pillar}
          headline={home.services.seat.headline}
          body={home.services.seat.body}
          offerings={home.services.seat.offerings}
          href={home.services.seat.href}
          linkLabel={home.services.seat.linkLabel}
        />
      </div>

      <!-- The signature scene (§6, M4): pins briefly while scroll scrubs the
           streams' draw-in → convergence → pulse → decision resolve. With
           reduced motion or no JS, this is simply the static diagram. -->
      <div class="engine-scene" data-engine-scene>
        <p class="services__engines-intro" data-reveal>{home.services.enginesIntro}</p>
        <EngineDiagram caption={home.services.diagramCaption} />
      </div>

      <div class="services__grid">
        {
          home.services.engines.map((engine, i) => (
            <PillarCard
              pillar={engine.pillar}
              headline={engine.headline}
              offerings={engine.offerings}
              href={engine.href}
              linkLabel={home.services.engineLinkLabel}
              revealDelay={i * 80}
              motif={engine.motif}
            />
          ))
        }
      </div>
    </div>
  </section>

  <!-- §5.1 #4 - Approach teaser. DRAFT COPY -->
  <section class="approach">
    <div class="container">
      <div class="approach__surface" data-reveal data-spotlight>
        <div class="approach__copy">
          <p class="section-head__kicker">{home.approach.kicker}</p>
          <h2 class="section-head__headline">{home.approach.headline}</h2>
          <p class="approach__body">{home.approach.body}</p>
          <a class="approach__link" href={withBase(home.approach.href)}>
            {home.approach.linkLabel}
            <span aria-hidden="true">→</span>
          </a>
        </div>

        <div class="approach__signal" aria-hidden="true">
          <span>Product</span>
          <span>Business need</span>
          <span>Data discipline</span>
          <strong>Growth question</strong>
        </div>
      </div>
    </div>
  </section>

  <!-- §5.1 #5 - Industries strip, three-label default (§3 OPEN). DRAFT COPY -->
  <section class="industries">
    <div class="container">
      <header class="section-head" data-reveal>
        <p class="section-head__kicker">{home.industries.kicker}</p>
        <h2 class="section-head__headline">{home.industries.headline}</h2>
      </header>
      <div class="industries__grid">
        {
          home.industries.items.map((item, i) => (
            <IndustryBlock label={item.label} blurb={item.blurb} revealDelay={i * 80} />
          ))
        }
      </div>
    </div>
  </section>

  <!-- §5.1 #6 - Closing CTA -->
  <ContactCTA />
</Base>

<script>
  // The pinned Engine scene (SPEC §6 signature scene, M4 art direction:
  // Apple-cinematic). Scroll position scrubs the whole sequence - scrub: 1
  // adds a weighted lag, native scroll speed is never overridden, and the
  // pin releases after convergence. Every hidden initial state is set HERE
  // via JS: with reduced motion or no JS the diagram is simply its final,
  // fully-converged self with no pin.
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  const scene = document.querySelector('[data-engine-scene]');
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (scene && !reduce) {
    gsap.registerPlugin(ScrollTrigger);

    const tl = gsap.timeline({
      defaults: { ease: 'power2.inOut' },
      scrollTrigger: {
        trigger: scene,
        start: 'top top',
        end: '+=130%',
        pin: true,
        scrub: 1,
        anticipatePin: 1,
      },
    });

    // Both responsive variants (wide/tall) are choreographed identically at
    // the same timeline positions; only one is visible at a time.
    scene.querySelectorAll('.engine__svg').forEach((svg) => {
      const streams = Array.from(svg.querySelectorAll<SVGPathElement>('.engine__stream'));
      const labels = Array.from(svg.querySelectorAll('.engine__labels text'));
      const node = svg.querySelector('.engine__node');
      const pulse = svg.querySelector('.engine__pulse');
      const out = svg.querySelector<SVGPathElement>('.engine__out');
      const artifact = svg.querySelector('.engine__artifact');
      if (!node || !pulse || !out || !artifact) return;

      // Initial states - JS-only, so non-animated visitors see the final state.
      streams.forEach((p) => {
        const len = p.getTotalLength();
        gsap.set(p, { strokeDasharray: len, strokeDashoffset: len });
      });
      const outLen = out.getTotalLength();
      gsap.set(out, { strokeDasharray: outLen, strokeDashoffset: outLen });
      gsap.set(labels, { opacity: 0 });
      gsap.set(node, { scale: 0 });
      gsap.set(artifact, { opacity: 0, y: 12, scale: 0.96 });

      // 1) Streams draw in sequentially, each label resolving with its stream.
      streams.forEach((p, i) => {
        tl.to(p, { strokeDashoffset: 0, duration: 1.2, ease: 'power3.inOut' }, i * 0.8);
        if (labels[i]) tl.to(labels[i], { opacity: 1, duration: 0.5, ease: 'power2.out' }, i * 0.8 + 0.55);
      });

      // 2) Convergence: the node lands with weight.
      tl.to(node, { scale: 1, duration: 0.45, ease: 'back.out(2.5)' }, 2.75);

      // 3) The accent line runs out toward the decision…
      tl.to(out, { strokeDashoffset: 0, duration: 0.85, ease: 'power2.inOut' }, 3.2);

      // 4) …the node pulses once on the accent (immediateRender off: the
      // ring must stay invisible until the playhead actually reaches it)…
      tl.fromTo(
        pulse,
        { opacity: 0.7, scale: 1 },
        { opacity: 0, scale: 3, duration: 0.7, ease: 'power2.out', immediateRender: false },
        3.3
      );

      // 5) …and THE DECISION resolves in.
      tl.to(artifact, { opacity: 1, y: 0, scale: 1, duration: 0.8, ease: 'power3.out' }, 3.7);
    });
  }
</script>

<style>
  /* Section headers use the shared .section-head classes (global.css). */

  /* ---- Problem framing: one oversized, quiet statement ---- */
  .problem {
    padding-block: clamp(4.5rem, 10vw, 11rem);
  }

  .problem__inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.42fr);
    gap: clamp(1.25rem, 4vw, 3rem);
    align-items: stretch;
  }

  .problem__copy,
  .problem__product,
  .approach__surface {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-card);
    isolation: isolate;
  }

  .problem__copy {
    display: flex;
    align-items: center;
    padding: clamp(1.4rem, 4vw, 3rem);
    background:
      radial-gradient(
        520px circle at 82% 16%,
        color-mix(in srgb, var(--signal) 10%, transparent),
        transparent 66%
      ),
      linear-gradient(145deg, var(--surface) 0%, var(--surface-2) 100%);
    box-shadow: var(--shadow-card);
  }

  .problem__statement {
    position: relative;
    z-index: 1;
    font-size: clamp(1.45rem, 3.3vw, 2.35rem);
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: var(--tracking-display);
    max-inline-size: 25em;
    margin: 0;
  }

  .problem__product {
    min-block-size: 100%;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: clamp(1.25rem, 3vw, 1.8rem);
    background:
      radial-gradient(
        360px circle at 70% 18%,
        color-mix(in srgb, var(--signal) 18%, transparent),
        transparent 64%
      ),
      linear-gradient(
        150deg,
        var(--surface) 0%,
        var(--glass-hi) 58%,
        color-mix(in srgb, var(--glass-lo) 34%, var(--glass-hi)) 100%
      );
    box-shadow: var(--shadow-card);
    transition:
      transform var(--dur-hover) var(--ease-luxe),
      box-shadow var(--dur-hover) var(--ease-luxe);
  }

  .problem__product::after,
  .approach__surface::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    background: radial-gradient(
      340px circle at var(--spot-x, 50%) var(--spot-y, 50%),
      color-mix(in srgb, var(--signal) 10%, transparent),
      transparent 70%
    );
    opacity: var(--spot-o, 0);
    transition: opacity 0.6s var(--ease-luxe);
  }

  .problem__visual {
    position: relative;
    display: grid;
    place-items: center;
    min-block-size: clamp(190px, 24vw, 260px);
    margin-block-end: clamp(1rem, 3vw, 1.6rem);
    overflow: hidden;
    border-radius: calc(var(--radius-card) - 4px);
  }

  .problem__visual :global(.service-visual) {
    position: relative;
    z-index: 3;
    max-inline-size: 260px;
    opacity: 0.9;
  }

  .product-stage {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
  }

  .product-stage::before {
    content: '';
    position: absolute;
    inset: 12% 8%;
    border-radius: 999px;
    background: color-mix(in srgb, var(--signal) 16%, transparent);
    filter: blur(28px);
    opacity: 0.82;
  }

  .product-stage__screen {
    position: absolute;
    border: 1px solid color-mix(in srgb, var(--signal) 28%, var(--hairline));
    background:
      linear-gradient(
        145deg,
        color-mix(in srgb, var(--surface) 90%, transparent),
        color-mix(in srgb, var(--glass-hi) 56%, transparent)
      );
    box-shadow:
      0 18px 44px color-mix(in srgb, var(--ink) 9%, transparent),
      inset 0 1px 0 color-mix(in srgb, white 60%, transparent);
  }

  .product-stage__screen--desktop {
    inline-size: 58%;
    aspect-ratio: 1.7;
    inset-inline-start: 9%;
    inset-block-start: 20%;
    border-radius: 18px;
  }

  .product-stage__screen--mobile {
    inline-size: 23%;
    aspect-ratio: 0.68;
    inset-inline-end: 12%;
    inset-block-start: 27%;
    border-radius: 18px;
  }

  .product-stage__screen span {
    position: absolute;
    inset-inline-start: 16%;
    inline-size: 54%;
    block-size: 4px;
    border-radius: 999px;
    background: color-mix(in srgb, var(--glass-lo) 72%, var(--surface));
  }

  .product-stage__screen span:nth-child(1) {
    inset-block-start: 28%;
  }

  .product-stage__screen span:nth-child(2) {
    inset-block-start: 48%;
    inline-size: 38%;
  }

  .product-stage__screen span:nth-child(3) {
    inset-block-start: 68%;
    inline-size: 22%;
    background: var(--signal);
  }

  .product-stage__rail {
    position: absolute;
    inset-inline: 11%;
    inset-block-end: 22%;
    block-size: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      color-mix(in srgb, var(--signal) 72%, transparent),
      transparent
    );
  }

  .product-stage__rail span {
    position: absolute;
    inset-block-start: -4px;
    inline-size: 9px;
    block-size: 9px;
    border-radius: 999px;
    background: var(--signal);
    box-shadow: 0 0 0 7px color-mix(in srgb, var(--signal) 12%, transparent);
  }

  .product-stage__rail span:nth-child(1) {
    inset-inline-start: 4%;
  }

  .product-stage__rail span:nth-child(2) {
    inset-inline-start: 48%;
  }

  .product-stage__rail span:nth-child(3) {
    inset-inline-end: 5%;
  }

  .product-stage__chip {
    position: absolute;
    z-index: 4;
    padding: 0.36rem 0.55rem;
    border: 1px solid color-mix(in srgb, var(--signal) 22%, var(--hairline));
    border-radius: 999px;
    background: color-mix(in srgb, var(--surface) 74%, transparent);
    -webkit-backdrop-filter: blur(10px);
    backdrop-filter: blur(10px);
    color: var(--signal-text);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    box-shadow: 0 12px 28px color-mix(in srgb, var(--ink) 8%, transparent);
  }

  .product-stage__chip--one {
    inset-inline-start: 4%;
    inset-block-start: 8%;
  }

  .product-stage__chip--two {
    inset-inline-end: 2%;
    inset-block-start: 5%;
  }

  .product-stage__chip--three {
    inset-inline-start: 28%;
    inset-block-end: 8%;
  }

  .problem__kicker {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--signal-text);
    margin-block: 0 0.65rem;
  }

  .problem__product h3 {
    font-size: clamp(1.35rem, 2.6vw, 1.85rem);
    max-inline-size: 11em;
    margin-block-end: 1.1rem;
  }

  .problem__product ul {
    display: grid;
    gap: 0.55rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .problem__product li {
    position: relative;
    padding-inline-start: 1rem;
    color: var(--graphite);
    font-weight: 600;
    line-height: 1.35;
  }

  .problem__product li::before {
    content: '';
    position: absolute;
    inset-inline-start: 0;
    inset-block-start: 0.62em;
    inline-size: 0.45rem;
    block-size: 0.45rem;
    border-radius: 999px;
    background: var(--signal);
  }

  /* ---- Services narrative ---- */
  .services {
    background: var(--surface-2);
    padding-block: var(--section-pad);
  }

  .services__header {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(220px, 0.36fr);
    gap: clamp(1.25rem, 4vw, 4rem);
    align-items: end;
    margin-block-end: clamp(1.75rem, 4vw, 3rem);
  }

  .services__header .section-head {
    margin-block-end: 0;
  }

  .services__artifact {
    display: grid;
    gap: 0.55rem;
    padding: 1rem;
    border-radius: var(--radius-card);
    background:
      radial-gradient(
        240px circle at 78% 18%,
        color-mix(in srgb, var(--signal) 20%, transparent),
        transparent 64%
      ),
      var(--ink-surface);
    color: var(--on-ink);
    box-shadow: var(--shadow-card);
  }

  .services__artifact span,
  .services__artifact strong {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.8rem;
    min-block-size: 2.35rem;
    padding: 0.5rem 0.7rem;
    border-radius: var(--radius-sm);
    border: 1px solid color-mix(in srgb, white 12%, transparent);
    font-size: 0.9rem;
  }

  .services__artifact span {
    color: color-mix(in srgb, var(--on-ink) 76%, transparent);
  }

  .services__artifact strong {
    background: color-mix(in srgb, var(--signal) 22%, transparent);
  }

  .services__artifact span::after,
  .services__artifact strong::after {
    content: '';
    inline-size: 0.5rem;
    block-size: 0.5rem;
    border-radius: 999px;
    background: var(--speed-from);
    box-shadow: 0 0 0 6px color-mix(in srgb, var(--speed-from) 11%, transparent);
  }

  .services__seat-shell {
    max-inline-size: 100%;
  }

  .services__engines-intro {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--graphite);
    text-align: center;
    margin-block: 0 1.5rem;
  }

  .engine-scene {
    margin-block-start: clamp(3rem, 6vw, 5rem);
  }

  /* With JS the scene is a full-viewport frame so the pin reads composed.
     Without JS it stays an ordinary block (no dead space). */
  :global(html.js) .engine-scene {
    min-block-size: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .services__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    /* M4: more generous lineup spacing (BACKLOG Entry A). */
    gap: clamp(1.25rem, 3vw, 2.25rem);
    margin-block-start: clamp(2.5rem, 5vw, 4rem);
  }

  @media (max-width: 1120px) {
    .services__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 980px) {
    .services__grid {
      grid-template-columns: 1fr;
      max-inline-size: 560px;
      margin-inline: auto;
    }
  }

  /* ---- Approach teaser ---- */
  .approach {
    padding-block: var(--section-pad);
  }

  .approach__surface {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(260px, 0.52fr);
    gap: clamp(1.5rem, 5vw, 5rem);
    align-items: end;
    padding: clamp(1.6rem, 4vw, 3rem);
    background:
      radial-gradient(
        480px circle at 82% 18%,
        color-mix(in srgb, var(--signal) 12%, transparent),
        transparent 64%
      ),
      linear-gradient(145deg, var(--surface) 0%, var(--surface-2) 100%);
    box-shadow: var(--shadow-card);
    transition:
      transform var(--dur-hover) var(--ease-luxe),
      box-shadow var(--dur-hover) var(--ease-luxe);
  }

  .approach__copy {
    position: relative;
    z-index: 1;
    max-inline-size: 46rem;
  }

  .approach__body {
    font-size: clamp(1.08rem, 1.8vw, 1.25rem);
    color: var(--graphite);
    margin-block-end: 1.5rem;
  }

  .approach__link {
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .approach__link span {
    transition: transform var(--dur-fast) var(--ease-out);
  }

  .approach__link:hover span {
    transform: translateX(3px);
  }

  .approach__signal {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 0.7rem;
    padding: 1rem;
    border-radius: var(--radius-card);
    background: color-mix(in srgb, var(--surface) 70%, transparent);
    border: 1px solid var(--hairline);
  }

  .approach__signal span,
  .approach__signal strong {
    position: relative;
    min-block-size: 2.7rem;
    display: flex;
    align-items: center;
    padding-inline: 0.8rem 2.2rem;
    border-radius: var(--radius-sm);
    background:
      linear-gradient(
        90deg,
        color-mix(in srgb, var(--glass-hi) 58%, transparent),
        color-mix(in srgb, var(--surface) 50%, transparent)
      );
    color: var(--ink);
    font-weight: 650;
  }

  .approach__signal strong {
    background: var(--ink-surface);
    color: var(--on-ink);
  }

  .approach__signal span::after,
  .approach__signal strong::after {
    content: '';
    position: absolute;
    inset-inline-end: 0.8rem;
    inset-block-start: 50%;
    inline-size: 0.55rem;
    block-size: 0.55rem;
    transform: translateY(-50%);
    border-radius: 999px;
    background: var(--signal);
    box-shadow: 0 0 0 7px color-mix(in srgb, var(--signal) 13%, transparent);
  }

  /* ---- Industries strip ---- */
  .industries {
    /* M2b: alternate rhythm - surface / surface-2 down the page, so it isn't
       one flat sheet. Sequence: hero/problem W → services S2 → approach W →
       industries S2 → contact W → footer S2. */
    background: var(--surface-2);
    padding-block: var(--section-pad);
  }

  .industries__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1rem, 3vw, 1.6rem);
  }

  @media (prefers-reduced-motion: no-preference) {
    .problem__product:hover,
    .approach__surface:hover {
      transform: translateY(-6px);
      box-shadow: var(--shadow-card-hover);
    }

    .product-stage__screen--desktop {
      animation: product-float-a 9s var(--ease-luxe) infinite;
    }

    .product-stage__screen--mobile {
      animation: product-float-b 8s var(--ease-luxe) infinite;
    }

    .product-stage__chip {
      animation: product-chip-drift 7s var(--ease-luxe) infinite;
    }

    .product-stage__chip--two {
      animation-delay: -1.7s;
    }

    .product-stage__chip--three {
      animation-delay: -3s;
    }

    .product-stage__rail span {
      animation: product-node-run 4.2s var(--ease-luxe) infinite;
    }

    .product-stage__rail span:nth-child(2) {
      animation-delay: 280ms;
