---
import Base from '../layouts/Base.astro';
import PageIntro from '../components/PageIntro.astro';
import ServiceVisual, { type ServiceVisualVariant } from '../components/ServiceVisual.astro';
import { services } from '../content/services';

const { intro, pillars, toolingNote } = services;
const visualMap: Record<(typeof pillars)[number]['visual'], ServiceVisualVariant> = {
  devices: 'product',
  behavior: 'behavior',
  dashboard: 'data',
  signals: 'market',
  decision: 'advisory',
};
---

<Base
  title="Services"
  description="Technology/product direction, behavioral analytics, business intelligence, market intelligence, and product strategy advisory - five services, one operating system."
>
  <!-- DRAFT COPY - Services: one page, five anchored sections. -->
  <PageIntro kicker={intro.kicker} headline={intro.headline} lede={intro.lede} />

  <!-- Sticky sub-nav: service anchors, scrollspy active state (§6 micro). -->
  <nav class="subnav" aria-label="Service practices">
    <div class="container subnav__inner">
      <ul>
        {
          pillars.map((p) => (
            <li>
              <a class="subnav__link" href={`#${p.id}`} data-spy={p.id}>
                {p.navLabel}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </nav>

  {
    pillars.map((p, i) => (
      <section
        class:list={['pillar', `pillar--${p.id}`, { 'pillar--seat': p.id === 'advisory' }]}
        id={p.id}
        aria-labelledby={`${p.id}-headline`}
      >
        <div class="container pillar__inner">
          <div
            class="pillar__visual"
            data-reveal
            data-spotlight
            style={`--reveal-delay: ${i * 50}ms`}
            aria-hidden="true"
          >
            <ServiceVisual variant={visualMap[p.visual]} size="feature" />
          </div>

          <header data-reveal>
            <p class="pillar__count">0{i + 1}</p>
            <p class="section-head__kicker pillar__kicker">{p.pillar}</p>
            <h2 class="pillar__headline" id={`${p.id}-headline`}>
              {p.headline}
            </h2>
            <p class="pillar__body">{p.body}</p>
          </header>

          <div class="pillar__detail" data-reveal style="--reveal-delay: 80ms">
            <ul class="pillar__offerings">
              {p.offerings.map((o) => (
                <li>{o}</li>
              ))}
            </ul>
            <p class="pillar__example">{p.example}</p>
            {p.footnote && <p class="pillar__footnote">{p.footnote}</p>}
          </div>
        </div>
      </section>
    ))
  }

  <!-- §5.2 footer line - the only place tool names live. -->
  <div class="tooling">
    <div class="container">
      <p class="tooling__note">{toolingNote}</p>
    </div>
  </div>
</Base>

<script>
  // Scrollspy for the sticky sub-nav: the section crossing the upper third of
  // the viewport is current. Highlight only - scrolling stays native (§6).
  const links = new Map<string, HTMLAnchorElement>();
  document
    .querySelectorAll<HTMLAnchorElement>('.subnav__link[data-spy]')
    .forEach((a) => links.set(a.dataset.spy!, a));

  const setActive = (id: string) => {
    links.forEach((a, key) => {
      a.classList.toggle('is-active', key === id);
      if (key === id) a.setAttribute('aria-current', 'true');
      else a.removeAttribute('aria-current');
    });
  };

  const io = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) setActive(entry.target.id);
      }
    },
    // A horizontal band around the upper third of the viewport.
    { rootMargin: '-25% 0px -65% 0px', threshold: 0 }
  );
  document.querySelectorAll('section.pillar[id]').forEach((s) => io.observe(s));
</script>

<style>
  /* ---- Sticky sub-nav ---- */
  .subnav {
    position: sticky;
    /* Below the main nav (68px). */
    inset-block-start: 68px;
    z-index: calc(var(--z-nav) - 1);
    background: color-mix(in srgb, var(--surface) 85%, transparent);
    -webkit-backdrop-filter: saturate(180%) blur(12px);
    backdrop-filter: saturate(180%) blur(12px);
    border-block: 1px solid var(--hairline);
  }

  .subnav__inner ul {
    display: flex;
    gap: clamp(1.25rem, 3vw, 2.5rem);
    list-style: none;
    margin: 0;
    padding: 0;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .subnav__link {
    display: inline-block;
    padding-block: 0.85rem;
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--graphite);
    white-space: nowrap;
    border-block-end: 2px solid transparent;
    transition:
      color var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out);
  }

  .subnav__link:hover {
    color: var(--ink);
  }

  .subnav__link.is-active {
    color: var(--ink);
    border-block-end-color: var(--signal);
  }

  /* ---- Pillar sections ---- */
  .pillar {
    padding-block: clamp(4rem, 8vw, 7rem);
    /* Clear the stacked nav (68px) + sub-nav (~48px) on anchor jumps. */
    scroll-margin-block-start: 132px;
  }

  .pillar:nth-of-type(even) {
    background: var(--surface-2);
  }

  .pillar__inner {
    display: grid;
    grid-template-columns: minmax(220px, 0.8fr) minmax(0, 1.05fr) minmax(0, 1fr);
    gap: clamp(1.75rem, 4vw, 4rem);
    align-items: center;
  }

  @media (max-width: 1060px) {
    .pillar__inner {
      grid-template-columns: 1fr 1fr;
    }

    .pillar__visual {
      grid-column: 1 / -1;
      max-inline-size: 420px;
    }
  }

  @media (max-width: 860px) {
    .pillar__inner {
      grid-template-columns: 1fr;
    }

    .pillar__visual {
      max-inline-size: 360px;
    }
  }

  .pillar__visual {
    position: relative;
    inline-size: 100%;
    aspect-ratio: 1.25;
    display: grid;
    place-items: center;
    overflow: hidden;
    border-radius: var(--radius-card);
    background:
      radial-gradient(
        260px circle at 70% 20%,
        color-mix(in srgb, var(--signal) 14%, transparent),
        transparent 62%
      ),
      linear-gradient(
        150deg,
        var(--surface) 0%,
        var(--glass-hi) 56%,
        color-mix(in srgb, var(--glass-lo) 34%, var(--glass-hi)) 100%
    );
    box-shadow: var(--shadow-card);
    isolation: isolate;
    transition:
      box-shadow var(--dur-hover) var(--ease-luxe),
      transform var(--dur-hover) var(--ease-luxe);
  }

  .pillar__visual::before,
  .pillar__visual::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .pillar__visual::before {
    z-index: 0;
    background:
      radial-gradient(
        230px circle at 22% 22%,
        color-mix(in srgb, var(--surface) 82%, transparent),
        transparent 68%
      ),
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--surface) 34%, transparent),
        transparent 64%
      );
    opacity: 0.72;
    transition: opacity var(--dur-hover) var(--ease-luxe);
  }

  .pillar__visual::after {
    z-index: 2;
    border-radius: inherit;
    background: radial-gradient(
      320px circle at var(--spot-x, 50%) var(--spot-y, 50%),
      color-mix(in srgb, var(--signal) 10%, transparent),
      transparent 70%
    );
    opacity: var(--spot-o, 0);
    transition: opacity 0.6s var(--ease-luxe);
  }

  .pillar__visual :global(.service-visual) {
    position: relative;
    z-index: 1;
    inline-size: min(88%, 360px);
    transition: transform var(--dur-hover) var(--ease-luxe);
  }

  .pillar--seat .pillar__visual {
    background:
      radial-gradient(
        280px circle at 72% 30%,
        color-mix(in srgb, var(--speed-from) 20%, transparent),
        transparent 62%
      ),
      linear-gradient(
        150deg,
        var(--ink-surface) 0%,
        color-mix(in srgb, var(--signal) 14%, var(--ink-surface)) 68%,
        color-mix(in srgb, var(--signal) 26%, var(--ink-surface)) 100%
      );
  }

  .pillar--seat .pillar__visual::before {
    background:
      radial-gradient(
        250px circle at 24% 24%,
        color-mix(in srgb, var(--speed-from) 18%, transparent),
        transparent 70%
      ),
      linear-gradient(180deg, rgba(255, 255, 255, 0.08), transparent 62%);
  }

  .pillar--seat .pillar__visual::after {
    background: radial-gradient(
      340px circle at var(--spot-x, 50%) var(--spot-y, 50%),
      color-mix(in srgb, var(--speed-from) 13%, transparent),
      transparent 72%
    );
  }

  .pillar__visual:hover {
    box-shadow: var(--shadow-card-hover);
  }

  @media (prefers-reduced-motion: no-preference) {
    .pillar__visual:hover {
      transform: translate3d(0, -6px, 0);
    }

    .pillar__visual:hover::before {
      opacity: 0.9;
    }

    .pillar__visual:hover :global(.service-visual) {
      transform: translate3d(0, -3px, 0) scale(1.02);
    }
  }

  .pillar__count {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--graphite);
    margin-block-end: 1.25rem;
  }

  .pillar__headline {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    margin-block-end: 0.75rem;
  }

  .pillar__body {
    color: var(--graphite);
    font-size: 1.1rem;
    margin: 0;
  }

  .pillar__offerings {
    list-style: none;
    margin: 0 0 1.5rem;
    padding: 0;
  }

  .pillar__offerings li {
    padding-block: 0.65rem;
    padding-inline-start: 1.2rem;
    position: relative;
    border-block-end: 1px solid var(--hairline);
  }

  .pillar__offerings li:first-child {
    border-block-start: 1px solid var(--hairline);
  }

  .pillar__offerings li::before {
    content: '';
    position: absolute;
    inset-inline-start: 0;
    inset-block-start: 1.25em;
    inline-size: 0.45rem;
    block-size: 2px;
    border-radius: 1px;
    background: var(--signal);
  }

  .pillar__example {
    color: var(--graphite);
    font-size: 0.975rem;
    margin-block-end: 0.75rem;
  }

  .pillar__footnote {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--graphite);
    margin: 0;
  }

  /* ---- Pillar 4: the seat - elevated ink section (§5.2 / §6).
       .pillar.pillar--seat: must outrank .pillar:nth-of-type(even). ---- */
  .pillar.pillar--seat {
    background: var(--ink-surface);
    color: var(--on-ink);
  }

  .pillar--seat .pillar__count,
  .pillar--seat .pillar__body,
  .pillar--seat .pillar__example,
  .pillar--seat .pillar__footnote {
    color: rgba(255, 255, 255, 0.78);
  }

  .pillar--seat .pillar__kicker {
    color: var(--speed-from);
  }

  .pillar--seat .pillar__offerings li {
    border-color: rgba(255, 255, 255, 0.16);
  }

  .pillar--seat .pillar__offerings li::before {
    background: var(--speed-from);
  }

  /* ---- Tooling note ---- */
  .tooling {
    border-block-start: 1px solid var(--hairline);
    padding-block: 2rem;
    background: var(--surface-2);
  }

  .tooling__note {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--graphite);
    margin: 0;
  }
</style>
