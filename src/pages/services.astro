---
import Base from '../layouts/Base.astro';
import PageIntro from '../components/PageIntro.astro';
import { services } from '../content/services';

const { intro, pillars, toolingNote } = services;
---

<Base
  title="Services"
  description="Technology/product direction, behavioral analytics, business intelligence, market intelligence, and product strategy advisory - five services, one operating system."
>
  <!-- DRAFT COPY - Services: one page, five anchored sections. -->
  <PageIntro kicker={intro.kicker} headline={intro.headline} lede={intro.lede} />

  <!-- Sticky sub-nav: service anchors, scrollspy active state (§6 micro). -->
  <nav class="subnav" aria-label="Service practices">
    <div class="container subnav__inner">
      <ul>
        {
          pillars.map((p) => (
            <li>
              <a class="subnav__link" href={`#${p.id}`} data-spy={p.id}>
                {p.navLabel}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </nav>

  {
    pillars.map((p, i) => (
      <section
        class:list={['pillar', `pillar--${p.id}`, { 'pillar--seat': p.id === 'advisory' }]}
        id={p.id}
        aria-labelledby={`${p.id}-headline`}
      >
        <div class="container pillar__inner">
          <div class="pillar__visual" data-reveal style={`--reveal-delay: ${i * 50}ms`} aria-hidden="true">
            {p.visual === 'devices' && (
              <svg viewBox="0 0 360 260" class="service-viz service-viz--devices">
                <rect class="viz-panel" x="52" y="46" width="196" height="126" rx="22" />
                <path class="viz-line viz-line--signal" d="M 82 122 C 116 96, 142 128, 174 96 S 218 78, 230 72" />
                <path class="viz-line viz-line--soft" d="M 96 152 H 168" />
                <rect class="viz-phone" x="224" y="92" width="72" height="118" rx="20" />
                <path class="viz-line viz-line--soft" d="M 244 122 H 276" />
                <path class="viz-line viz-line--signal" d="M 244 146 H 270" />
                <circle class="viz-dot" cx="260" cy="190" r="5" />
              </svg>
            )}
            {p.visual === 'behavior' && (
              <svg viewBox="0 0 360 260" class="service-viz service-viz--behavior">
                <path class="viz-line" d="M 92 160 L 156 112 L 114 62 M 156 112 L 242 84 L 272 150 L 156 112 M 92 160 L 242 178" />
                <circle class="viz-node" cx="114" cy="62" r="16" />
                <circle class="viz-node" cx="92" cy="160" r="15" />
                <circle class="viz-node viz-node--signal" cx="156" cy="112" r="21" />
                <circle class="viz-node" cx="242" cy="84" r="15" />
                <circle class="viz-node" cx="272" cy="150" r="14" />
                <circle class="viz-node" cx="242" cy="178" r="15" />
              </svg>
            )}
            {p.visual === 'dashboard' && (
              <svg viewBox="0 0 360 260" class="service-viz service-viz--dashboard">
                <rect class="viz-panel" x="58" y="52" width="244" height="156" rx="24" />
                <rect class="viz-tile" x="80" y="78" width="82" height="46" rx="12" />
                <rect class="viz-tile" x="178" y="78" width="82" height="46" rx="12" />
                <path class="viz-line viz-line--signal" d="M 88 176 C 120 160, 142 178, 164 150 S 212 138, 252 112" />
                <rect class="viz-bar" x="84" y="142" width="28" height="44" rx="6" />
                <rect class="viz-bar" x="122" y="154" width="28" height="32" rx="6" />
                <rect class="viz-bar" x="160" y="130" width="28" height="56" rx="6" />
                <circle class="viz-dot" cx="252" cy="112" r="7" />
              </svg>
            )}
            {p.visual === 'signals' && (
              <svg viewBox="0 0 360 260" class="service-viz service-viz--signals">
                <path class="viz-line" d="M 76 70 C 124 82, 142 116, 176 130" />
                <path class="viz-line" d="M 80 192 C 124 174, 142 146, 176 130" />
                <path class="viz-line" d="M 282 78 C 236 86, 212 112, 176 130" />
                <path class="viz-line" d="M 284 188 C 238 178, 212 146, 176 130" />
                <circle class="viz-node" cx="76" cy="70" r="15" />
                <circle class="viz-node" cx="80" cy="192" r="15" />
                <circle class="viz-node" cx="282" cy="78" r="15" />
                <circle class="viz-node" cx="284" cy="188" r="15" />
                <circle class="viz-node viz-node--signal" cx="176" cy="130" r="23" />
                <path class="viz-line viz-line--signal" d="M 176 130 L 226 130" />
                <rect class="viz-chip" x="226" y="116" width="64" height="28" rx="10" />
              </svg>
            )}
            {p.visual === 'decision' && (
              <svg viewBox="0 0 360 260" class="service-viz service-viz--decision">
                <path class="viz-line" d="M 74 82 C 128 82, 138 130, 178 130" />
                <path class="viz-line" d="M 74 178 C 128 178, 138 130, 178 130" />
                <path class="viz-line" d="M 74 130 L 178 130" />
                <circle class="viz-dot" cx="178" cy="130" r="8" />
                <path class="viz-line viz-line--signal" d="M 186 130 L 238 130" />
                <rect class="viz-panel" x="238" y="82" width="76" height="96" rx="16" />
                <rect class="viz-chip" x="254" y="106" width="44" height="8" rx="4" />
                <rect class="viz-chip" x="254" y="128" width="34" height="8" rx="4" />
                <rect class="viz-chip" x="254" y="150" width="52" height="8" rx="4" />
              </svg>
            )}
          </div>

          <header data-reveal>
            <p class="pillar__count">0{i + 1}</p>
            <p class="section-head__kicker pillar__kicker">{p.pillar}</p>
            <h2 class="pillar__headline" id={`${p.id}-headline`}>
              {p.headline}
            </h2>
            <p class="pillar__body">{p.body}</p>
          </header>

          <div class="pillar__detail" data-reveal style="--reveal-delay: 80ms">
            <ul class="pillar__offerings">
              {p.offerings.map((o) => (
                <li>{o}</li>
              ))}
            </ul>
            <p class="pillar__example">{p.example}</p>
            {p.footnote && <p class="pillar__footnote">{p.footnote}</p>}
          </div>
        </div>
      </section>
    ))
  }

  <!-- §5.2 footer line - the only place tool names live. -->
  <div class="tooling">
    <div class="container">
      <p class="tooling__note">{toolingNote}</p>
    </div>
  </div>
</Base>

<script>
  // Scrollspy for the sticky sub-nav: the section crossing the upper third of
  // the viewport is current. Highlight only - scrolling stays native (§6).
  const links = new Map<string, HTMLAnchorElement>();
  document
    .querySelectorAll<HTMLAnchorElement>('.subnav__link[data-spy]')
    .forEach((a) => links.set(a.dataset.spy!, a));

  const setActive = (id: string) => {
    links.forEach((a, key) => {
      a.classList.toggle('is-active', key === id);
      if (key === id) a.setAttribute('aria-current', 'true');
      else a.removeAttribute('aria-current');
    });
  };

  const io = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) setActive(entry.target.id);
      }
    },
    // A horizontal band around the upper third of the viewport.
    { rootMargin: '-25% 0px -65% 0px', threshold: 0 }
  );
  document.querySelectorAll('section.pillar[id]').forEach((s) => io.observe(s));
</script>

<style>
  /* ---- Sticky sub-nav ---- */
  .subnav {
    position: sticky;
    /* Below the main nav (68px). */
    inset-block-start: 68px;
    z-index: calc(var(--z-nav) - 1);
    background: color-mix(in srgb, var(--surface) 85%, transparent);
    -webkit-backdrop-filter: saturate(180%) blur(12px);
    backdrop-filter: saturate(180%) blur(12px);
    border-block: 1px solid var(--hairline);
  }

  .subnav__inner ul {
    display: flex;
    gap: clamp(1.25rem, 3vw, 2.5rem);
    list-style: none;
    margin: 0;
    padding: 0;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .subnav__link {
    display: inline-block;
    padding-block: 0.85rem;
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--graphite);
    white-space: nowrap;
    border-block-end: 2px solid transparent;
    transition:
      color var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out);
  }

  .subnav__link:hover {
    color: var(--ink);
  }

  .subnav__link.is-active {
    color: var(--ink);
    border-block-end-color: var(--signal);
  }

  /* ---- Pillar sections ---- */
  .pillar {
    padding-block: clamp(4rem, 8vw, 7rem);
    /* Clear the stacked nav (68px) + sub-nav (~48px) on anchor jumps. */
    scroll-margin-block-start: 132px;
  }

  .pillar:nth-of-type(even) {
    background: var(--surface-2);
  }

  .pillar__inner {
    display: grid;
    grid-template-columns: minmax(220px, 0.8fr) minmax(0, 1.05fr) minmax(0, 1fr);
    gap: clamp(1.75rem, 4vw, 4rem);
    align-items: start;
  }

  @media (max-width: 1060px) {
    .pillar__inner {
      grid-template-columns: 1fr 1fr;
    }

    .pillar__visual {
      grid-column: 1 / -1;
      max-inline-size: 420px;
    }
  }

  @media (max-width: 860px) {
    .pillar__inner {
      grid-template-columns: 1fr;
    }

    .pillar__visual {
      max-inline-size: 360px;
    }
  }

  .pillar__visual {
    position: relative;
    inline-size: 100%;
    aspect-ratio: 1.25;
    display: grid;
    place-items: center;
    overflow: hidden;
    border-radius: var(--radius-card);
    background:
      radial-gradient(
        260px circle at 70% 20%,
        color-mix(in srgb, var(--signal) 14%, transparent),
        transparent 62%
      ),
      linear-gradient(
        150deg,
        var(--surface) 0%,
        var(--glass-hi) 56%,
        color-mix(in srgb, var(--glass-lo) 34%, var(--glass-hi)) 100%
      );
    box-shadow: var(--shadow-card);
  }

  .pillar--seat .pillar__visual {
    background:
      radial-gradient(
        280px circle at 72% 30%,
        color-mix(in srgb, var(--speed-from) 20%, transparent),
        transparent 62%
      ),
      linear-gradient(
        150deg,
        var(--ink-surface) 0%,
        color-mix(in srgb, var(--signal) 14%, var(--ink-surface)) 68%,
        color-mix(in srgb, var(--signal) 26%, var(--ink-surface)) 100%
      );
  }

  .service-viz {
    inline-size: 92%;
    block-size: auto;
  }

  .viz-panel,
  .viz-phone {
    fill: color-mix(in srgb, var(--glass-hi) 76%, var(--surface));
    stroke: var(--glass-lo);
    stroke-width: 4;
  }

  .pillar--seat .viz-panel,
  .pillar--seat .viz-phone {
    fill: color-mix(in srgb, var(--surface) 8%, var(--ink-surface));
  }

  .viz-screen,
  .viz-tile {
    fill: color-mix(in srgb, var(--glass-hi) 86%, var(--surface));
  }

  .viz-chip,
  .viz-bar {
    fill: var(--glass-lo);
  }

  .viz-dot,
  .viz-node--signal {
    fill: var(--signal);
  }

  .viz-node {
    fill: var(--glass-lo);
  }

  .viz-line {
    fill: none;
    stroke: var(--glass-lo);
    stroke-width: 4;
    stroke-linecap: round;
    stroke-linejoin: round;
    opacity: 0.9;
  }

  .viz-line--soft {
    stroke: var(--glass-lo);
  }

  .viz-line--signal {
    stroke: var(--signal);
    opacity: 1;
  }

  @media (prefers-reduced-motion: no-preference) {
    .service-viz * {
      transform-box: fill-box;
      transform-origin: center;
    }

    .pillar:hover .viz-node,
    .pillar:hover .viz-dot {
      transform: scale(1.08);
    }

    .pillar:hover .viz-line--signal {
      transform: translate3d(3px, 0, 0);
    }

    .service-viz--devices .viz-phone,
    .service-viz--dashboard .viz-dot,
    .service-viz--signals .viz-node--signal,
    .service-viz--decision .viz-panel {
      transition: transform var(--dur-hover) var(--ease-luxe);
    }

    .pillar:hover .service-viz--devices .viz-phone {
      transform: translate3d(6px, 3px, 0);
    }

    .pillar:hover .service-viz--dashboard .viz-dot,
    .pillar:hover .service-viz--signals .viz-node--signal {
      transform: scale(1.14);
    }

    .pillar:hover .service-viz--decision .viz-panel {
      transform: translate3d(5px, 0, 0);
    }
  }

  .pillar__count {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--graphite);
    margin-block-end: 1.25rem;
  }

  .pillar__headline {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    margin-block-end: 0.75rem;
  }

  .pillar__body {
    color: var(--graphite);
    font-size: 1.1rem;
    margin: 0;
  }

  .pillar__offerings {
    list-style: none;
    margin: 0 0 1.5rem;
    padding: 0;
  }

  .pillar__offerings li {
    padding-block: 0.65rem;
    padding-inline-start: 1.2rem;
    position: relative;
    border-block-end: 1px solid var(--hairline);
  }

  .pillar__offerings li:first-child {
    border-block-start: 1px solid var(--hairline);
  }

  .pillar__offerings li::before {
    content: '';
    position: absolute;
    inset-inline-start: 0;
    inset-block-start: 1.25em;
    inline-size: 0.45rem;
    block-size: 2px;
    border-radius: 1px;
    background: var(--signal);
  }

  .pillar__example {
    color: var(--graphite);
    font-size: 0.975rem;
    margin-block-end: 0.75rem;
  }

  .pillar__footnote {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--graphite);
    margin: 0;
  }

  /* ---- Pillar 4: the seat - elevated ink section (§5.2 / §6).
       .pillar.pillar--seat: must outrank .pillar:nth-of-type(even). ---- */
  .pillar.pillar--seat {
    background: var(--ink-surface);
    color: var(--on-ink);
  }

  .pillar--seat .pillar__count,
  .pillar--seat .pillar__body,
  .pillar--seat .pillar__example,
  .pillar--seat .pillar__footnote {
    color: rgba(255, 255, 255, 0.78);
  }

  .pillar--seat .pillar__kicker {
    color: var(--speed-from);
  }

  .pillar--seat .pillar__offerings li {
    border-color: rgba(255, 255, 255, 0.16);
  }

  .pillar--seat .pillar__offerings li::before {
    background: var(--speed-from);
  }

  /* ---- Tooling note ---- */
  .tooling {
    border-block-start: 1px solid var(--hairline);
    padding-block: 2rem;
    background: var(--surface-2);
  }

  .tooling__note {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--graphite);
    margin: 0;
  }
</style>
