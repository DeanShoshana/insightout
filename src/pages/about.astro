---
import Base from '../layouts/Base.astro';
import PageIntro from '../components/PageIntro.astro';
import { about } from '../content/about';

const { intro, thesis, sections } = about;
---

<Base
  title="About"
  description="Why Claritix exists and how the firm turns data and research into the decisions leaders actually have to make."
>
  <!-- DRAFT COPY - About (SPEC §5.5, revised M5a): a company story, no founder. -->
  <PageIntro kicker={intro.kicker} headline={intro.headline} lede={intro.lede} />

  <section class="thesis" aria-label="The Claritix thesis">
    <div class="container">
      <p class="thesis__statement" data-reveal>{thesis}</p>
    </div>
  </section>

  {
    sections.map((s, i) => (
      <section
        class:list={['story', { 'story--alt': i % 2 === 0 }]}
        aria-labelledby={`${s.id}-headline`}
      >
        <div class="container story__inner" data-reveal>
          <h2 class="story__headline" id={`${s.id}-headline`}>
            {s.headline}
          </h2>
          <p class="story__body">{s.body}</p>
        </div>
      </section>
    ))
  }
</Base>

<style>
  .thesis {
    padding-block: clamp(2rem, 5vw, 4rem);
  }

  .thesis__statement {
    font-size: clamp(1.3rem, 2.6vw, 1.8rem);
    font-weight: 600;
    line-height: 1.4;
    letter-spacing: var(--tracking-display);
    max-inline-size: 34em;
    margin: 0;
  }

  .story {
    padding-block: var(--section-pad);
  }

  /* Alternate surface so the two blocks read as distinct steps. */
  .story--alt {
    background: var(--surface-2);
  }

  .story__inner {
    display: grid;
    grid-template-columns: 1fr 1.6fr;
    gap: clamp(1.5rem, 4vw, 4rem);
    align-items: start;
  }

  @media (max-width: 860px) {
    .story__inner {
      grid-template-columns: 1fr;
    }
  }

  .story__headline {
    font-size: clamp(1.6rem, 3vw, 2.25rem);
    margin: 0;
  }

  .story__body {
    color: var(--graphite);
    font-size: 1.1rem;
    margin: 0;
  }
</style>
