---
import Base from '../layouts/Base.astro';
import PageIntro from '../components/PageIntro.astro';
import { withBase } from '../lib/url';
import { about } from '../content/about';

const { intro, thesis, system, sections, proof, closing } = about;
---

<Base
  title="About"
  description="Why Claritix exists and how the firm turns data and research into the decisions leaders actually have to make."
>
  <!-- DRAFT COPY - About (SPEC §5.5, revised M5a): a company story, no founder. -->
  <PageIntro kicker={intro.kicker} headline={intro.headline} lede={intro.lede} />

  <section class="thesis" aria-label="The Claritix thesis">
    <div class="container thesis__inner">
      <div class="thesis__surface" data-reveal data-spotlight>
        <p class="thesis__kicker">Company thesis</p>
        <p class="thesis__statement">{thesis}</p>
      </div>

      <aside class="thesis__artifact" data-reveal style="--reveal-delay: 120ms" aria-label="Claritix operating spine">
        <div class="artifact__orbit" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </div>
        <p>Product</p>
        <p>Analytics</p>
        <p>Strategy</p>
      </aside>
    </div>
  </section>

  <section class="system" aria-labelledby="system-headline">
    <div class="container">
      <header class="section-head" data-reveal>
        <p class="section-head__kicker">{system.kicker}</p>
        <h2 class="section-head__headline" id="system-headline">{system.headline}</h2>
        <p class="section-head__lede">{system.lede}</p>
      </header>

      <div class="system__rail" data-reveal data-spotlight style="--reveal-delay: 120ms">
        {system.nodes.map((node, i) => (
          <article class="system-node" style={`--node-index: ${i}`}>
            <p class="system-node__label">{node.label}</p>
            <h3>{node.title}</h3>
            <p>{node.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  {
    sections.map((s, i) => (
      <section
        class:list={['story', { 'story--alt': i % 2 === 0 }]}
        aria-labelledby={`${s.id}-headline`}
      >
        <div class="container story__inner">
          <div class="story__index" data-reveal aria-hidden="true">0{i + 1}</div>
          <div class="story__copy" data-reveal style={`--reveal-delay: ${i * 80}ms`}>
            <p class="story__kicker">{s.kicker}</p>
            <h2 class="story__headline" id={`${s.id}-headline`}>
              {s.headline}
            </h2>
            <p class="story__body">{s.body}</p>
          </div>
        </div>
      </section>
    ))
  }

  <section class="proof" aria-labelledby="proof-headline">
    <div class="container proof__inner">
      <div class="proof__copy" data-reveal>
        <p class="section-head__kicker">{proof.kicker}</p>
        <h2 class="proof__headline" id="proof-headline">{proof.headline}</h2>
      </div>

      <div class="proof__stack">
        {proof.points.map((point, i) => (
          <article class="proof-card" data-reveal data-spotlight style={`--reveal-delay: ${i * 90}ms`}>
            <span>{String(i + 1).padStart(2, '0')}</span>
            <p>{point}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="about-close" aria-label="About closing statement">
    <div class="container">
      <div class="about-close__surface" data-reveal data-spotlight>
        <p>{closing}</p>
        <a href={withBase('/services#product')} data-magnetic>
          See the connected services
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>
</Base>

<style>
  .thesis {
    padding-block: clamp(1.5rem, 5vw, 4rem) var(--section-pad);
  }

  .thesis__inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(260px, 0.42fr);
    gap: clamp(1.2rem, 3vw, 2rem);
    align-items: stretch;
  }

  .thesis__surface,
  .thesis__artifact,
  .system__rail,
  .proof-card,
  .about-close__surface {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
    isolation: isolate;
  }

  .thesis__surface,
  .about-close__surface {
    padding: clamp(1.6rem, 4vw, 3rem);
    background:
      radial-gradient(
        520px circle at 82% 16%,
        color-mix(in srgb, var(--signal) 14%, transparent),
        transparent 64%
      ),
      linear-gradient(145deg, var(--surface) 0%, var(--surface-2) 100%);
  }

  .thesis__surface::after,
  .system__rail::after,
  .proof-card::after,
  .about-close__surface::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    background: radial-gradient(
      360px circle at var(--spot-x, 50%) var(--spot-y, 50%),
      color-mix(in srgb, var(--spotlight) 14%, transparent),
      transparent 70%
    );
    filter: hue-rotate(26deg) saturate(1.12);
    opacity: var(--spot-o, 0);
    transition: opacity 0.6s var(--ease-luxe);
  }

  .thesis__kicker,
  .story__kicker,
  .system-node__label {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.055em;
    text-transform: uppercase;
    color: var(--signal-text);
    margin-block: 0 0.8rem;
  }

  .thesis__statement {
    position: relative;
    z-index: 1;
    font-size: clamp(1.45rem, 3.2vw, 2.35rem);
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: var(--tracking-display);
    max-inline-size: 25em;
    margin: 0;
  }

  .thesis__artifact {
    min-block-size: 100%;
    display: grid;
    align-content: end;
    gap: 0.55rem;
    padding: clamp(1.4rem, 3vw, 2rem);
    background:
      radial-gradient(
        340px circle at 50% 26%,
        color-mix(in srgb, var(--signal) 22%, transparent),
        transparent 66%
      ),
      var(--ink-surface);
    color: var(--on-ink);
  }

  .thesis__artifact p {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin: 0;
    padding-block: 0.75rem;
    border-block-end: 1px solid color-mix(in srgb, white 15%, transparent);
    font-weight: 650;
  }

  .thesis__artifact p::after {
    content: '';
    inline-size: 0.52rem;
    block-size: 0.52rem;
    border-radius: 999px;
    background: var(--speed-from);
    box-shadow: 0 0 0 7px color-mix(in srgb, var(--speed-from) 12%, transparent);
  }

  .artifact__orbit {
    position: absolute;
    inset-block-start: clamp(2.8rem, 6vw, 4.4rem);
    inset-inline: clamp(1.2rem, 3vw, 2rem);
    aspect-ratio: 1.5;
    opacity: 0.86;
  }

  .artifact__orbit span {
    position: absolute;
    inset: 0;
    border: 1px solid color-mix(in srgb, var(--speed-from) 36%, transparent);
    border-radius: 999px;
    transform: rotate(calc(var(--orbit-index, 0) * 22deg));
  }

  .artifact__orbit span:nth-child(1) {
    --orbit-index: -1;
  }

  .artifact__orbit span:nth-child(3) {
    --orbit-index: 1;
  }

  .system {
    padding-block: var(--section-pad);
    background: var(--surface-2);
  }

  .system__rail {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    background:
      radial-gradient(
        540px circle at 78% 18%,
        color-mix(in srgb, var(--signal) 12%, transparent),
        transparent 66%
      ),
      var(--surface);
  }

  .system-node {
    position: relative;
    min-block-size: 290px;
    padding: clamp(1.25rem, 2.8vw, 2rem);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    border-inline-start: 1px solid var(--hairline);
  }

  .system-node:first-child {
    border-inline-start: 0;
  }

  .system-node::before {
    content: '';
    position: absolute;
    inset-inline: clamp(1.25rem, 2.8vw, 2rem);
    inset-block-start: clamp(1.25rem, 2.8vw, 2rem);
    block-size: 2px;
    background: linear-gradient(
      90deg,
      color-mix(in srgb, var(--signal) 18%, transparent),
      color-mix(in srgb, var(--signal) 72%, transparent),
      color-mix(in srgb, var(--signal) 10%, transparent)
    );
  }

  .system-node::after {
    content: '';
    position: absolute;
    inset-inline-start: clamp(1.25rem, 2.8vw, 2rem);
    inset-block-start: calc(clamp(1.25rem, 2.8vw, 2rem) - 4px);
    inline-size: 10px;
    block-size: 10px;
    border-radius: 999px;
    background: var(--signal);
    box-shadow: 0 0 0 8px color-mix(in srgb, var(--signal) 12%, transparent);
  }

  .system-node h3 {
    font-size: clamp(1.2rem, 2vw, 1.55rem);
    max-inline-size: 13em;
    margin-block-end: 0.85rem;
  }

  .system-node p:last-child {
    color: var(--graphite);
    margin: 0;
  }

  .story {
    padding-block: var(--section-pad);
  }

  /* Alternate surface so the two blocks read as distinct steps. */
  .story--alt {
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--surface-2) 76%, transparent),
        var(--surface)
      );
  }

  .story__inner {
    display: grid;
    grid-template-columns: minmax(120px, 0.32fr) minmax(0, 1fr);
    gap: clamp(1.5rem, 6vw, 7rem);
    align-items: start;
    max-inline-size: 980px;
  }

  .story__index {
    position: sticky;
    inset-block-start: 9rem;
    font-family: var(--font-mono);
    font-size: clamp(3rem, 8vw, 7rem);
    line-height: 0.9;
    color: color-mix(in srgb, var(--signal) 16%, transparent);
    letter-spacing: -0.04em;
  }

  .story__copy {
    max-inline-size: 45rem;
  }

  .story__headline {
    font-size: clamp(2rem, 4.4vw, 3.35rem);
    margin-block-end: 1rem;
  }

  .story__body {
    color: var(--graphite);
    font-size: clamp(1.08rem, 1.8vw, 1.25rem);
    margin: 0;
  }

  .proof {
    padding-block: var(--section-pad);
    background: var(--surface-2);
  }

  .proof__inner {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(320px, 1.1fr);
    gap: clamp(1.5rem, 5vw, 5rem);
    align-items: start;
  }

  .proof__copy {
    position: sticky;
    inset-block-start: 8rem;
  }

  .proof__headline {
    font-size: clamp(2rem, 4.4vw, 3.25rem);
    margin: 0;
  }

  .proof__stack {
    display: grid;
    gap: 0.9rem;
  }

  .proof-card {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 1rem;
    align-items: start;
    padding: clamp(1.2rem, 2.6vw, 1.7rem);
    background:
      radial-gradient(
        280px circle at 84% 12%,
        color-mix(in srgb, var(--signal) 9%, transparent),
        transparent 64%
      ),
      var(--surface);
  }

  .proof-card span {
    font-family: var(--font-mono);
    color: var(--signal-text);
    font-size: 0.82rem;
  }

  .proof-card p {
    margin: 0;
    color: var(--ink);
    font-weight: 600;
    line-height: 1.4;
  }

  .about-close {
    padding-block: var(--section-pad);
  }

  .about-close__surface {
    max-inline-size: 820px;
  }

  .about-close__surface p {
    position: relative;
    z-index: 1;
    font-size: clamp(1.35rem, 3vw, 2rem);
    font-weight: 650;
    line-height: 1.3;
    letter-spacing: var(--tracking-display);
    margin-block-end: 1.3rem;
  }

  .about-close__surface a {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.75rem 1rem;
    border-radius: 999px;
    background: var(--signal);
    color: var(--on-ink);
    font-weight: 700;
    box-shadow: 0 12px 28px color-mix(in srgb, var(--signal) 24%, transparent);
  }

  .about-close__surface span {
    transition: transform var(--dur-fast) var(--ease-out);
  }

  .about-close__surface a:hover span {
    transform: translateX(3px);
  }

  @media (prefers-reduced-motion: no-preference) {
    .thesis__surface,
    .system__rail,
    .proof-card,
    .about-close__surface {
      transition:
        transform var(--dur-hover) var(--ease-luxe),
        box-shadow var(--dur-hover) var(--ease-luxe);
    }

    .thesis__surface:hover,
    .system__rail:hover,
    .proof-card:hover,
    .about-close__surface:hover {
      transform: translateY(-6px);
      box-shadow: var(--shadow-card-hover);
    }

    .artifact__orbit {
      animation: about-orbit 18s linear infinite;
    }

    .system-node::after {
      animation: about-node 3.8s var(--ease-luxe) infinite;
      animation-delay: calc(var(--node-index) * 160ms);
    }
  }

  @keyframes about-orbit {
    to {
      transform: rotate(360deg);
    }
  }

  @keyframes about-node {
    0%,
    54%,
    100% {
      transform: translate3d(0, 0, 0) scale(1);
      opacity: 0.72;
    }

    18% {
      transform: translate3d(calc(100% + 9rem), 0, 0) scale(1.08);
      opacity: 1;
    }
  }

  @media (max-width: 980px) {
    .thesis__inner,
    .proof__inner {
      grid-template-columns: 1fr;
    }

    .thesis__artifact {
      min-block-size: 260px;
    }

    .system__rail {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .system-node:nth-child(odd) {
      border-inline-start: 0;
    }

    .proof__copy {
      position: static;
    }
  }

  @media (max-width: 720px) {
    .thesis {
      padding-block-start: 1rem;
    }

    .thesis__surface,
    .about-close__surface {
      padding: 1.25rem;
    }

    .thesis__statement {
      font-size: clamp(1.45rem, 7.4vw, 2rem);
      line-height: 1.2;
    }

    .system__rail {
      grid-template-columns: 1fr;
    }

    .system-node {
      min-block-size: 230px;
      border-inline-start: 0;
      border-block-start: 1px solid var(--hairline);
    }

    .system-node:first-child {
      border-block-start: 0;
    }

    .story__inner {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }

    .story__index {
      position: static;
      font-size: 3rem;
    }

    .story__headline,
    .proof__headline {
      font-size: clamp(2rem, 9.4vw, 2.7rem);
      line-height: 1.08;
    }

    .proof-card {
      grid-template-columns: 1fr;
    }

    .about-close__surface a {
      inline-size: 100%;
      justify-content: center;
    }
  }
</style>
